<%- include('../partials/header', {title: 'Email Detail', user: locals.user}) %>

<div class="mb-8">
  <a href="/admin/emails" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] inline-flex items-center gap-1 mb-2">
    <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i>
    Back to Emails
  </a>
  <h1 class="text-page-title flex items-center gap-3">
    <% if (email.type === 'inbound') { %>
    <span class="badge badge-info"><i data-lucide="inbox" class="w-3 h-3 inline -mt-0.5"></i> Inbound</span>
    <% } else { %>
    <span class="badge badge-neutral"><i data-lucide="send" class="w-3 h-3 inline -mt-0.5"></i> Outbound</span>
    <% } %>
    <%= email.subject %>
  </h1>
</div>

<div class="max-w-3xl space-y-5">
  <!-- Email Info -->
  <div class="card">
    <div class="p-5">
      <div class="grid grid-cols-2 gap-3">
        <% if (email.type === 'inbound' && email.metadata && email.metadata.from) { %>
        <div class="detail-item">
          <div class="detail-label">From</div>
          <div class="detail-value"><%= email.metadata.from %></div>
        </div>
        <% } %>
        <div class="detail-item">
          <div class="detail-label">To</div>
          <div class="detail-value"><%= email.to %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Subject</div>
          <div class="detail-value font-medium"><%= email.subject %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Type</div>
          <div class="detail-value"><%= email.type %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Status</div>
          <div class="detail-value">
            <% if (email.status === 'received') { %>
            <span class="badge badge-info"><span class="badge-dot bg-sky-500"></span>Received</span>
            <% } else if (email.status === 'delivered') { %>
            <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Delivered</span>
            <% } else if (email.status === 'bounced') { %>
            <span class="badge badge-danger"><span class="badge-dot bg-rose-500"></span>Bounced</span>
            <% } else { %>
            <span class="badge badge-neutral"><%= email.status %></span>
            <% } %>
          </div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Date</div>
          <div class="detail-value"><%= new Date(email.createdAt).toLocaleString('en-GB') %></div>
        </div>
        <% if (email.user) { %>
        <div class="detail-item">
          <div class="detail-label">User</div>
          <div class="detail-value"><%= email.user.displayName || email.user.username %> (<%= email.user.email %>)</div>
        </div>
        <% } %>
        <% if (email.resendId) { %>
        <div class="detail-item">
          <div class="detail-label">Resend ID</div>
          <div class="detail-value font-mono text-xs"><%= email.resendId %></div>
        </div>
        <% } %>
      </div>

      <!-- Event Timeline -->
      <% if (email.deliveredAt || email.openedAt || email.clickedAt || email.bouncedAt) { %>
      <div class="mt-4 pt-4 border-t border-[var(--border-subtle)]">
        <p class="text-xs font-semibold text-[var(--text-tertiary)] uppercase tracking-wide mb-3">Events</p>
        <div class="flex flex-wrap gap-3 text-xs text-[var(--text-secondary)]">
          <% if (email.deliveredAt) { %>
          <span class="flex items-center gap-1"><i data-lucide="check-circle" class="w-3 h-3 text-emerald-500"></i> Delivered: <%= new Date(email.deliveredAt).toLocaleString('en-GB') %></span>
          <% } %>
          <% if (email.openedAt) { %>
          <span class="flex items-center gap-1"><i data-lucide="eye" class="w-3 h-3 text-sky-500"></i> Opened: <%= new Date(email.openedAt).toLocaleString('en-GB') %></span>
          <% } %>
          <% if (email.clickedAt) { %>
          <span class="flex items-center gap-1"><i data-lucide="mouse-pointer" class="w-3 h-3 text-indigo-500"></i> Clicked: <%= new Date(email.clickedAt).toLocaleString('en-GB') %></span>
          <% } %>
          <% if (email.bouncedAt) { %>
          <span class="flex items-center gap-1"><i data-lucide="alert-triangle" class="w-3 h-3 text-rose-500"></i> Bounced: <%= new Date(email.bouncedAt).toLocaleString('en-GB') %></span>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Email Body (inbound) -->
  <% if (email.metadata && (email.metadata.htmlBody || email.metadata.textBody || email.metadata.body)) { %>
  <div class="card">
    <div class="card-header">
      <h3>Email Body</h3>
      <% if (email.metadata.htmlBody && email.metadata.textBody) { %>
      <div class="flex gap-1">
        <button onclick="showBodyTab('html')" id="tabHtml" class="text-xs font-medium px-2 py-1 rounded bg-[var(--brand-primary)] text-white">HTML</button>
        <button onclick="showBodyTab('text')" id="tabText" class="text-xs font-medium px-2 py-1 rounded bg-[var(--surface-2)] text-[var(--text-secondary)]">Text</button>
      </div>
      <% } %>
    </div>
    <div class="card-body">
      <% if (email.metadata.htmlBody) { %>
      <div id="bodyHtml" class="bg-white dark:bg-slate-900 rounded-lg p-4 border border-[var(--border-subtle)] text-sm overflow-auto max-h-[500px]">
        <%- email.metadata.htmlBody %>
      </div>
      <% } %>
      <% if (email.metadata.textBody) { %>
      <div id="bodyText" class="bg-[var(--surface-1)] rounded-lg p-4 border border-[var(--border-subtle)] text-sm overflow-auto max-h-[500px] whitespace-pre-wrap font-mono" <%= email.metadata.htmlBody ? 'style="display:none"' : '' %>>
        <%= email.metadata.textBody %>
      </div>
      <% } %>
      <%/* Legacy: old body field */ %>
      <% if (!email.metadata.htmlBody && !email.metadata.textBody && email.metadata.body) { %>
      <div class="bg-white dark:bg-slate-900 rounded-lg p-4 border border-[var(--border-subtle)] text-sm overflow-auto max-h-[500px]">
        <%- email.metadata.body %>
      </div>
      <% } %>
    </div>
  </div>
  <% if (email.metadata.htmlBody && email.metadata.textBody) { %>
  <script>
  function showBodyTab(tab) {
    document.getElementById('bodyHtml').style.display = tab === 'html' ? '' : 'none';
    document.getElementById('bodyText').style.display = tab === 'text' ? '' : 'none';
    document.getElementById('tabHtml').className = 'text-xs font-medium px-2 py-1 rounded ' + (tab === 'html' ? 'bg-[var(--brand-primary)] text-white' : 'bg-[var(--surface-2)] text-[var(--text-secondary)]');
    document.getElementById('tabText').className = 'text-xs font-medium px-2 py-1 rounded ' + (tab === 'text' ? 'bg-[var(--brand-primary)] text-white' : 'bg-[var(--surface-2)] text-[var(--text-secondary)]');
  }
  </script>
  <% } %>
  <% } %>

  <!-- Attachments (inbound) -->
  <% if (email.metadata && email.metadata.attachments && email.metadata.attachments.length > 0) { %>
  <div class="card">
    <div class="card-header">
      <h3>Attachments</h3>
      <span class="badge badge-neutral"><%= email.metadata.attachments.length %></span>
    </div>
    <div class="card-body">
      <div class="space-y-2">
        <% email.metadata.attachments.forEach(function(att, idx) { %>
        <div class="flex items-center gap-3 p-2.5 rounded-lg bg-[var(--surface-1)] border border-[var(--border-subtle)]">
          <i data-lucide="paperclip" class="w-4 h-4 text-[var(--text-tertiary)]"></i>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-[var(--text-primary)] truncate"><%= att.filename %></p>
            <p class="text-xs text-[var(--text-tertiary)]"><%= att.content_type %></p>
          </div>
          <a href="/admin/emails/<%= email.id %>/attachment/<%= idx %>" class="btn btn-secondary btn-sm" title="Download">
            <i data-lucide="download" class="w-3.5 h-3.5"></i>
          </a>
        </div>
        <% }) %>
      </div>
      <% if (email.metadata.rawDownloadUrl) { %>
      <div class="mt-3 pt-3 border-t border-[var(--border-subtle)]">
        <a href="<%= email.metadata.rawDownloadUrl %>" target="_blank" class="btn btn-secondary btn-sm">
          <i data-lucide="download" class="w-3.5 h-3.5"></i>
          Download Raw Email (with attachments)
        </a>
        <% if (email.metadata.rawExpiresAt) { %>
        <p class="text-xs text-[var(--text-tertiary)] mt-1">Link expires: <%= new Date(email.metadata.rawExpiresAt).toLocaleString('en-GB') %></p>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>
  <% } else if (email.metadata && email.metadata.rawDownloadUrl) { %>
  <div class="card">
    <div class="card-header">
      <h3>Raw Email</h3>
    </div>
    <div class="card-body">
      <a href="<%= email.metadata.rawDownloadUrl %>" target="_blank" class="btn btn-secondary btn-sm">
        <i data-lucide="download" class="w-3.5 h-3.5"></i>
        Download Raw Email
      </a>
      <% if (email.metadata.rawExpiresAt) { %>
      <p class="text-xs text-[var(--text-tertiary)] mt-1">Link expires: <%= new Date(email.metadata.rawExpiresAt).toLocaleString('en-GB') %></p>
      <% } %>
    </div>
  </div>
  <% } %>

  <!-- Metadata -->
  <% if (email.metadata && email.metadata.error) { %>
  <div class="alert alert-error">
    <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
    <div class="text-sm">
      <p class="font-semibold">Error</p>
      <p><%= email.metadata.error %></p>
    </div>
  </div>
  <% } %>

  <!-- Reply Form (inbound only) -->
  <% if (email.type === 'inbound') { %>
  <div class="card">
    <div class="card-header">
      <h2 class="card-title flex items-center gap-2">
        <i data-lucide="reply" class="w-4 h-4"></i> Reply
      </h2>
    </div>
    <div class="p-5">
      <% if (typeof replied !== 'undefined' && replied) { %>
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4">Reply sent successfully.</div>
      <% } %>
      <% if (typeof error !== 'undefined' && error === 'empty') { %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">Reply body cannot be empty.</div>
      <% } %>
      <form method="post" action="/admin/emails/<%= email.id %>/reply">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="mb-3">
          <label class="block text-sm font-medium mb-1">To</label>
          <input type="text" readonly value="<%= email.metadata?.from || email.to %>" class="input w-full bg-[var(--bg-secondary)]">
        </div>
        <div class="mb-3">
          <label class="block text-sm font-medium mb-1">Subject</label>
          <input type="text" readonly value="Re: <%= email.subject %>" class="input w-full bg-[var(--bg-secondary)]">
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium mb-1">Message</label>
          <textarea name="replyBody" rows="6" required class="input w-full" placeholder="Type your reply..."></textarea>
        </div>
        <div class="flex justify-end">
          <button type="submit" class="btn btn-primary">
            <i data-lucide="send" class="w-4 h-4 inline -mt-0.5"></i> Send Reply
          </button>
        </div>
      </form>
    </div>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
