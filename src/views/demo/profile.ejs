<div class="v2-content">
  <h1 class="v2-page-title v2-anim">Profil</h1>

  <!-- Avatar Section -->
  <div class="v2-avatar-section v2-anim">
    <div class="v2-avatar-lg">T</div>
    <div>
      <div class="v2-avatar-name">Turgut</div>
      <div class="v2-avatar-email">demo@datapatch.co</div>
    </div>
  </div>

  <!-- Cards Grid (2-col on desktop) -->
  <div class="v2-profile-grid">

  <!-- Hesap Bilgileri -->
  <div class="v2-section v2-anim">
    <div class="v2-section-title">Hesap Bilgileri</div>
    <form>
      <div class="v2-input-group">
        <label class="v2-input-label">Gorunen Ad</label>
        <input type="text" class="v2-input" value="Turgut">
      </div>
      <div class="v2-input-group">
        <label class="v2-input-label">E-posta</label>
        <input type="email" class="v2-input" value="demo@datapatch.co">
      </div>
      <div class="v2-input-group">
        <label class="v2-input-label">Telefon</label>
        <input type="tel" class="v2-input" placeholder="+90 5XX XXX XX XX">
      </div>
      <button type="button" class="v2-btn v2-btn-primary">Kaydet</button>
    </form>
  </div>

  <!-- Sifre Degistir -->
  <div class="v2-section v2-anim">
    <div class="v2-section-title">Sifre Degistir</div>
    <form>
      <div class="v2-input-group">
        <label class="v2-input-label">Mevcut Sifre</label>
        <input type="password" class="v2-input" placeholder="••••••••">
      </div>
      <div class="v2-input-group">
        <label class="v2-input-label">Yeni Sifre</label>
        <input type="password" class="v2-input" placeholder="••••••••">
      </div>
      <div class="v2-input-group">
        <label class="v2-input-label">Sifre Tekrar</label>
        <input type="password" class="v2-input" placeholder="••••••••">
      </div>
      <button type="button" class="v2-btn v2-btn-primary">Sifreyi Guncelle</button>
    </form>
  </div>

  <!-- Tercihler -->
  <div class="v2-section v2-anim">
    <div class="v2-section-title">Tercihler</div>
    <div style="display:flex;align-items:center;justify-content:space-between;">
      <div>
        <div style="font-size:14px;font-weight:600;color:var(--color-text);">Tema</div>
        <div style="font-size:12px;color:var(--color-text-muted);">Arayuz gorunumunu ayarla</div>
      </div>
      <div class="v2-toggle">
        <span class="v2-toggle-opt active">Acik</span>
        <span class="v2-toggle-opt">Koyu</span>
      </div>
    </div>
  </div>

  </div><!-- /v2-profile-grid -->
</div>
