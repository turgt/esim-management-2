    <a href="/purchases" class="<%= (title === 'My Datas' || title === 'My Purchases' || title === 'Purchase Status' || title === 'QR Code' || title === 'Payment' || title === 'Payment Result' || title === 'Top-up Data') ? 'active' : '' %>">
