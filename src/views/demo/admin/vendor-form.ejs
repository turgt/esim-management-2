<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
  <a href="/demo/admin/vendors" style="color: #94a3b8; text-decoration: none; font-size: 20px;">&larr;</a>
  <div class="demo-page-title" style="margin-bottom: 0;"><%= locals.vendorName ? 'Vendor Düzenle' : 'Vendor Ekle' %></div>
</div>

<div class="demo-card" style="padding: 24px; max-width: 600px;">
  <form>
    <div style="margin-bottom: 20px;">
      <label class="demo-label">Vendor Adı</label>
      <input type="text" class="demo-input" placeholder="Vendor adını girin" value="<%= locals.vendorName || '' %>">
    </div>

    <div style="margin-bottom: 20px;">
      <label class="demo-label">API URL</label>
      <input type="text" class="demo-input" placeholder="https://api.example.com/v1" value="<%= locals.vendorApiUrl || '' %>">
    </div>

    <div style="margin-bottom: 20px;">
      <label class="demo-label">API Key</label>
      <input type="password" class="demo-input" placeholder="API anahtarını girin">
    </div>

    <div style="margin-bottom: 20px;">
      <label class="demo-label">Komisyon Oranı (%)</label>
      <input type="number" class="demo-input" placeholder="12" value="<%= locals.vendorCommission || '' %>">
    </div>

    <div style="margin-bottom: 24px;">
      <label class="demo-label">Durum</label>
      <select class="demo-input">
        <option value="active" <%= locals.vendorStatus === 'active' || !locals.vendorStatus ? 'selected' : '' %>>Aktif</option>
        <option value="passive" <%= locals.vendorStatus === 'passive' ? 'selected' : '' %>>Pasif</option>
      </select>
    </div>

    <button type="button" class="demo-btn demo-btn-primary demo-btn-block">Kaydet</button>
  </form>
</div>
