<div class="v2-content">
  <h1 class="v2-page-title v2-anim">Odeme Gecmisi</h1>

  <!-- Filters -->
  <div class="v2-filters v2-anim">
    <button class="v2-chip active" onclick="setFilter(this)">Tumu</button>
    <button class="v2-chip" onclick="setFilter(this)">Tamamlandi</button>
    <button class="v2-chip" onclick="setFilter(this)">Bekleyen</button>
    <button class="v2-chip" onclick="setFilter(this)">Basarisiz</button>
  </div>

  <!-- Payment List -->
  <div class="v2-payments">
    <% if (locals.payments && payments.length) { %>
      <% payments.forEach(function(payment) { %>
    <a href="/demo/receipt" class="v2-row v2-anim">
      <div style="width:44px;height:44px;background:var(--gradient-primary);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>
      </div>
      <div class="v2-row-info">
        <div class="v2-row-name"><%= payment.planName %></div>
        <div class="v2-row-meta"><%= payment.date %></div>
      </div>
      <div class="v2-row-right">
        <div class="v2-row-price"><%= payment.amount %></div>
        <% if (payment.status === 'completed') { %>
          <span class="v2-badge v2-badge-success">Tamamlandi</span>
        <% } else if (payment.status === 'pending') { %>
          <span class="v2-badge v2-badge-warning">Bekleyen</span>
        <% } else { %>
          <span class="v2-badge v2-badge-danger">Basarisiz</span>
        <% } %>
      </div>
    </a>
      <% }) %>
    <% } else { %>
    <div style="text-align:center;padding:40px 20px;color:var(--color-text-muted);font-size:14px;">
      Henuz odeme gecmisiniz bulunmuyor.
    </div>
    <% } %>
  </div>
</div>

<script>
function setFilter(el) {
  document.querySelectorAll('.v2-chip').forEach(function(c) { c.classList.remove('active'); });
  el.classList.add('active');
}
</script>
