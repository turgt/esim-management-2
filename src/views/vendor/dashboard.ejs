<%- include('../partials/header', {title: 'Vendor Dashboard', user: locals.user}) %>

<% if (inactive) { %>
<div class="flex flex-col items-center justify-center py-20">
  <div class="stat-icon bg-amber-50 dark:bg-amber-500/10 mb-4" style="width:56px;height:56px;">
    <i data-lucide="alert-triangle" class="w-7 h-7 text-amber-600 dark:text-amber-400"></i>
  </div>
  <h1 class="text-lg font-semibold text-[var(--text-primary)] mb-2">Vendor Account Unavailable</h1>
  <p class="text-sm text-[var(--text-secondary)] text-center max-w-md"><%= message %></p>
</div>
<% } else { %>

<div class="mb-8">
  <h1 class="text-page-title flex items-center gap-3">
    <%= vendor.name %>
    <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Active</span>
  </h1>
  <% if (vendor.contactInfo) { %>
  <p class="text-sm text-[var(--text-secondary)] mt-1"><%= vendor.contactInfo %></p>
  <% } %>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="stat-card">
    <div class="stat-icon bg-sky-50 dark:bg-sky-500/10">
      <i data-lucide="users" class="w-5 h-5 text-sky-600 dark:text-sky-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Referral Users</p>
      <p class="stat-value"><%= stats.totalUsers %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-[var(--brand-light)]">
      <i data-lucide="shopping-bag" class="w-5 h-5 text-[var(--brand-primary)]"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Total Sales</p>
      <p class="stat-value"><%= stats.totalPurchases %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-emerald-50 dark:bg-emerald-500/10">
      <i data-lucide="dollar-sign" class="w-5 h-5 text-emerald-600 dark:text-emerald-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Total Revenue</p>
      <p class="stat-value text-emerald-600 dark:text-emerald-400">$<%= parseFloat(stats.totalRevenue).toFixed(2) %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-amber-50 dark:bg-amber-500/10">
      <i data-lucide="coins" class="w-5 h-5 text-amber-600 dark:text-amber-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Commission (<%= parseFloat(vendor.commissionRate) %>%)</p>
      <p class="stat-value text-amber-600 dark:text-amber-400">$<%= parseFloat(stats.commission).toFixed(2) %></p>
    </div>
  </div>
</div>

<!-- QR Code & Chart -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <!-- Referral Card -->
  <div class="card p-6 text-center">
    <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-4">Referral</h3>
    <img src="<%= qrDataUrl %>" alt="QR Code" class="mx-auto rounded-lg mb-4" style="max-width: 180px;">
    <div class="bg-[var(--surface-2)] rounded-lg p-3 mb-3">
      <p class="text-xs text-[var(--text-tertiary)] mb-1">Referral Code</p>
      <p class="font-mono text-lg font-bold text-[var(--brand-primary)]"><%= vendor.code %></p>
    </div>
    <div class="bg-[var(--surface-2)] rounded-lg p-3 mb-4">
      <p class="text-xs text-[var(--text-tertiary)] mb-1">Referral URL</p>
      <p class="text-xs font-mono text-[var(--text-secondary)] break-all"><%= refUrl %></p>
    </div>
    <div class="flex gap-2 justify-center">
      <button onclick="copyToClipboard('<%= refUrl %>', this)" class="btn btn-primary btn-sm">
        <i data-lucide="copy" class="w-3.5 h-3.5"></i>
        Copy Link
      </button>
      <button onclick="copyToClipboard('<%= vendor.code %>', this)" class="btn btn-secondary btn-sm">
        <i data-lucide="copy" class="w-3.5 h-3.5"></i>
        Copy Code
      </button>
    </div>
  </div>

  <!-- Chart -->
  <div class="card p-6 lg:col-span-2">
    <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-4">Last 30 Days Activity</h3>
    <div class="relative" style="height: 280px;">
      <canvas id="vendorChart"></canvas>
    </div>
    <div class="flex items-center justify-center gap-6 mt-4 text-xs text-[var(--text-secondary)]">
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-[#4f46e5] inline-block"></span> Registrations</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-[#10b981] inline-block"></span> Purchases</span>
    </div>
  </div>
</div>

<!-- Recent Users & Sales -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Recent Users -->
  <div class="table-container">
    <div class="card-header">
      <h3>Recent Registrations</h3>
      <span class="text-xs text-[var(--text-tertiary)]"><%= stats.totalUsers %> total</span>
    </div>
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>User</th>
            <th>Registered</th>
          </tr>
        </thead>
        <tbody>
          <% if (recentUsers.length > 0) { %>
          <% recentUsers.forEach(function(u) { %>
          <tr>
            <td>
              <div class="flex items-center gap-2.5">
                <div class="avatar avatar-sm" style="background: linear-gradient(135deg, #4f46e5, #7c3aed);"><%= (u.displayName || u.username).charAt(0).toUpperCase() %></div>
                <p class="font-medium text-[var(--text-primary)]"><%= u.displayName || u.username %></p>
              </div>
            </td>
            <td class="text-xs text-[var(--text-tertiary)]"><%= new Date(u.createdAt).toLocaleDateString('en-GB') %></td>
          </tr>
          <% }) %>
          <% } else { %>
          <tr>
            <td colspan="2" class="text-center py-6 text-sm text-[var(--text-tertiary)]">
              No users registered yet
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Recent Sales -->
  <div class="table-container">
    <div class="card-header">
      <h3>Recent Sales</h3>
      <span class="text-xs text-[var(--text-tertiary)]"><%= stats.totalPurchases %> total</span>
    </div>
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>Plan</th>
            <th>Amount</th>
            <th>Commission</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (recentSales.length > 0) { %>
          <% recentSales.forEach(function(s) { %>
          <tr>
            <td class="text-sm font-medium text-[var(--text-primary)]"><%= s.planName %></td>
            <td class="text-sm text-[var(--text-secondary)]">$<%= parseFloat(s.amount).toFixed(2) %></td>
            <td class="text-sm text-amber-600 dark:text-amber-400 font-medium">$<%= s.commission.toFixed(2) %></td>
            <td class="text-xs text-[var(--text-tertiary)]"><%= new Date(s.createdAt).toLocaleDateString('en-GB') %></td>
          </tr>
          <% }) %>
          <% } else { %>
          <tr>
            <td colspan="4" class="text-center py-6 text-sm text-[var(--text-tertiary)]">
              No sales yet
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
(function() {
  var rawData = <%- chartData %>;
  var labels = rawData.map(function(d) {
    var parts = d.date.split('-');
    return parts[1] + '/' + parts[2];
  });
  var registrations = rawData.map(function(d) { return d.registrations; });
  var purchases = rawData.map(function(d) { return d.purchases; });

  var isDark = document.documentElement.classList.contains('dark');
  var gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';
  var textColor = isDark ? '#94a3b8' : '#64748b';

  var ctx = document.getElementById('vendorChart').getContext('2d');
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [
        {
          label: 'Registrations',
          data: registrations,
          backgroundColor: isDark ? 'rgba(99,102,241,0.7)' : 'rgba(79,70,229,0.8)',
          borderRadius: 4,
          barPercentage: 0.6
        },
        {
          label: 'Purchases',
          data: purchases,
          backgroundColor: isDark ? 'rgba(52,211,153,0.7)' : 'rgba(16,185,129,0.8)',
          borderRadius: 4,
          barPercentage: 0.6
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: isDark ? '#1e293b' : '#fff',
          titleColor: isDark ? '#e2e8f0' : '#1e293b',
          bodyColor: isDark ? '#94a3b8' : '#64748b',
          borderColor: isDark ? '#334155' : '#e2e8f0',
          borderWidth: 1,
          cornerRadius: 8,
          padding: 10
        }
      },
      scales: {
        x: {
          grid: { display: false },
          ticks: { color: textColor, font: { size: 10 }, maxRotation: 0, autoSkip: true, maxTicksLimit: 10 }
        },
        y: {
          beginAtZero: true,
          grid: { color: gridColor },
          ticks: { color: textColor, font: { size: 11 }, stepSize: 1 }
        }
      }
    }
  });
})();
</script>

<% } %>

<%- include('../partials/footer') %>
