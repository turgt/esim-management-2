<div class="demo-page-title">Kullanıcı Yönetimi</div>

<!-- Add User Form -->
<div class="demo-card" style="padding: 20px; margin-bottom: 24px;">
  <div style="font-size: 16px; font-weight: 600; font-family: var(--demo-font-heading); margin-bottom: 16px;">Yeni Kullanıcı Ekle</div>
  <form style="display: grid; grid-template-columns: 1fr 1fr 1fr auto; gap: 12px; align-items: end;">
    <div>
      <label class="demo-label">Kullanıcı Adı</label>
      <input type="text" class="demo-input" placeholder="Kullanıcı adı">
    </div>
    <div>
      <label class="demo-label">E-posta</label>
      <input type="email" class="demo-input" placeholder="E-posta adresi">
    </div>
    <div>
      <label class="demo-label">Şifre</label>
      <input type="password" class="demo-input" placeholder="Şifre">
    </div>
    <div>
      <button type="button" class="demo-btn demo-btn-primary demo-btn-sm">Ekle</button>
    </div>
  </form>
</div>

<!-- Search -->
<div style="margin-bottom: 16px;">
  <input type="text" class="demo-input" placeholder="Kullanıcı ara..." style="max-width: 400px;">
</div>

<!-- Users Table -->
<div class="demo-card" style="padding: 0; overflow: hidden;">
  <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
    <thead>
      <tr>
        <th style="text-align: left; padding: 12px 16px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; border-bottom: 1px solid #f1f5f9; font-weight: 600;">Kullanıcı</th>
        <th style="text-align: left; padding: 12px 16px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; border-bottom: 1px solid #f1f5f9; font-weight: 600;">E-posta</th>
        <th style="text-align: left; padding: 12px 16px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; border-bottom: 1px solid #f1f5f9; font-weight: 600;">Rol</th>
        <th style="text-align: left; padding: 12px 16px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; border-bottom: 1px solid #f1f5f9; font-weight: 600;">eSIM</th>
        <th style="text-align: left; padding: 12px 16px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; border-bottom: 1px solid #f1f5f9; font-weight: 600;">Durum</th>
        <th style="text-align: left; padding: 12px 16px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: #94a3b8; border-bottom: 1px solid #f1f5f9; font-weight: 600;">İşlemler</th>
      </tr>
    </thead>
    <tbody>
      <% const defaultUsers = [
        { username: 'admin', email: 'admin@datapatch.io', role: 'admin', esimCount: 5, status: 'active' },
        { username: 'ahmet.yilmaz', email: 'ahmet@example.com', role: 'user', esimCount: 3, status: 'active' },
        { username: 'elif.demir', email: 'elif@example.com', role: 'user', esimCount: 2, status: 'active' },
        { username: 'mehmet.kaya', email: 'mehmet@example.com', role: 'user', esimCount: 1, status: 'suspended' },
        { username: 'zeynep.arslan', email: 'zeynep@example.com', role: 'user', esimCount: 4, status: 'active' },
        { username: 'can.ozturk', email: 'can@example.com', role: 'user', esimCount: 0, status: 'active' }
      ]; %>
      <% const userList = locals.users || defaultUsers; %>
      <% userList.forEach(function(u) { %>
        <tr>
          <td style="padding: 12px 16px; border-bottom: 1px solid #f1f5f9; font-weight: 500;"><%= u.username %></td>
          <td style="padding: 12px 16px; border-bottom: 1px solid #f1f5f9; color: #64748b;"><%= u.email %></td>
          <td style="padding: 12px 16px; border-bottom: 1px solid #f1f5f9;">
            <% if (u.role === 'admin') { %>
              <span class="demo-badge demo-badge-gradient">Admin</span>
            <% } else { %>
              <span class="demo-badge demo-badge-dark">User</span>
            <% } %>
          </td>
          <td style="padding: 12px 16px; border-bottom: 1px solid #f1f5f9;"><%= u.esimCount %></td>
          <td style="padding: 12px 16px; border-bottom: 1px solid #f1f5f9;">
            <% if (u.status === 'active') { %>
              <span class="demo-badge demo-badge-success">Aktif</span>
            <% } else { %>
              <span class="demo-badge demo-badge-danger">Askıya Alındı</span>
            <% } %>
          </td>
          <td style="padding: 12px 16px; border-bottom: 1px solid #f1f5f9;">
            <a href="/demo/admin/users/<%= u.username %>" class="demo-btn demo-btn-outline demo-btn-sm">Düzenle</a>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
