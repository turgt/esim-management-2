<%- include('partials/header', {title: 'Offers', user: locals.user}) %>

<div class="mb-6 fade-up">
  <h1 class="text-page-title">Available Plans</h1>
  <p class="text-subtitle mt-1">Choose a data plan for seamless connectivity worldwide</p>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-error mb-6">
  <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
  <%= error %>
</div>
<% } %>

<% if (typeof offers !== 'undefined' && offers && offers.length > 0) { %>

<!-- Country Filter -->
<% if (typeof availableCountries !== 'undefined' && availableCountries && availableCountries.length > 1) { %>
<div class="flex gap-1.5 flex-wrap mb-4 fade-up stagger-0" id="countryChips">
  <a href="/offers" class="filter-chip <%= (!locals.selectedCountry || locals.selectedCountry === '') ? 'active' : '' %>">All Countries</a>
  <% availableCountries.forEach(function(cc) { %>
  <a href="/offers?country=<%= cc %>" class="filter-chip <%= (locals.selectedCountry === cc) ? 'active' : '' %>"><%= cc %></a>
  <% }); %>
</div>
<% } %>

<!-- Filters -->
<div class="flex gap-1.5 flex-wrap mb-4 fade-up stagger-1" id="filterChips">
  <button type="button" class="filter-chip active" data-filter="all" onclick="filterOffers('all', this)">All</button>
  <button type="button" class="filter-chip" data-filter="unlimited" onclick="filterOffers('unlimited', this)">Unlimited</button>
  <button type="button" class="filter-chip" data-filter="gb" onclick="filterOffers('gb', this)">Fixed GB</button>
</div>

<!-- Sort & Results Count -->
<div class="flex items-center justify-between mb-4 fade-up stagger-2">
  <span class="text-xs text-[var(--text-tertiary)]" id="resultsCount"></span>
  <div class="flex items-center gap-2">
    <label for="sortSelect" class="sr-only">Sort plans</label>
    <select id="sortSelect" onchange="sortOffers(this.value)" class="input text-sm !py-2 !px-3 !w-auto !min-w-0">
      <option value="price-asc">Price: Low to High</option>
      <option value="price-desc">Price: High to Low</option>
      <option value="data-desc">Data: Most First</option>
      <option value="data-asc">Data: Least First</option>
      <option value="duration-desc">Duration: Longest</option>
      <option value="duration-asc">Duration: Shortest</option>
    </select>
  </div>
</div>

<!-- Offers Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="offersGrid">
  <% offers.forEach(function(offer, idx) { %>
  <%
    var price = offer.finalPrice ? parseFloat(offer.finalPrice).toFixed(2) : (offer.price ? parseFloat(offer.price).toFixed(2) : null);
    var currency = 'USD';
    var dataLabel = offer.data || null;
    var durationLabel = offer.day ? offer.day + ' days' : '';
    var regionShort = offer.countryCode || '';
    var operatorTitle = offer.operatorTitle || '';
    var type = offer.type || '';
    var detailParts = [];
    if (operatorTitle) detailParts.push(operatorTitle);
    if (type) detailParts.push(type);
    if (offer.isUnlimited) detailParts.push('Unlimited');
    var detailStr = detailParts.join(' · ');
    var priceNum = price ? parseFloat(price) : 0;
    var dataMatch = dataLabel ? dataLabel.match(/(\d+)/) : null;
    var dataNum = offer.isUnlimited ? 99999 : (dataMatch ? parseInt(dataMatch[1]) : 0);
    var durationNum = offer.day || 0;
    var metaParts = [];
    if (offer.isUnlimited) metaParts.push('Unlimited');
    else if (dataLabel) metaParts.push(dataLabel);
    if (durationLabel) metaParts.push(durationLabel);
    var metaStr = metaParts.join(' · ');
  %>
  <%
    var rawOp = (offer.rawData && offer.rawData.operator) || {};
    var activationPolicy = rawOp.activation_policy || '';
    var networkNames = (rawOp.networks || []).map(function(n) { return n.types ? n.types.join('/') : ''; }).filter(Boolean).join(', ');
    var coverageJson = JSON.stringify(offer.coverageCountries || []);
  %>
  <button type="button" class="offer-card fade-up stagger-<%= (idx % 6) + 1 %>"
    data-price="<%= priceNum %>"
    data-data="<%= dataNum %>"
    data-duration="<%= durationNum %>"
    data-unlimited="<%= offer.isUnlimited ? '1' : '0' %>"
    data-subtypes="<%= type %>"
    data-package-id="<%= offer.packageId %>"
    data-operator="<%= (operatorTitle || '').replace(/"/g, '&quot;') %>"
    data-country="<%= regionShort %>"
    data-type="<%= type %>"
    data-data-label="<%= dataLabel || '' %>"
    data-day="<%= offer.day || 0 %>"
    data-speed="<%= offer.bestSpeed || '' %>"
    data-activation="<%= activationPolicy %>"
    data-networks="<%= networkNames %>"
    data-note="<%= (offer.note || '').replace(/"/g, '&quot;') %>"
    data-fair-usage="<%= offer.hasFairUsage ? '1' : '0' %>"
    data-data-title="<%= (offer.dataTitle || '').replace(/"/g, '&quot;') %>"
    data-coverage="<%= coverageJson.replace(/"/g, '&quot;') %>"
    data-price-display="<%= price || '0.00' %>"
    onclick="openPlanPanel(this)">
    <div class="offer-top">
      <div class="offer-flag"><% if (regionShort) { %><img src="https://hatscripts.github.io/circle-flags/flags/<%= regionShort.toLowerCase() %>.svg" alt="<%= regionShort %>"><% } else { %>🌍<% } %></div>
      <div>
        <div class="offer-name">
          <%= offer.dataTitle || dataLabel || regionShort || 'Plan' %>
          <% if (type) { %><span class="offer-type-badge"><%= type %></span><% } %>
          <% if (offer.bestSpeed) { %><span class="offer-speed-badge speed-<%= offer.bestSpeed.toLowerCase() %>"><%= offer.bestSpeed %></span><% } %>
        </div>
        <div class="offer-meta"><%= metaStr %></div>
      </div>
    </div>
    <% if (offer.coverageCountries && offer.coverageCountries.length > 1) { %>
    <div class="offer-extras">
      <div class="offer-coverage">
        <i data-lucide="map-pin" class="w-3 h-3"></i>
        <span><%= offer.coverageCountries.slice(0, 4).join(', ') %><% if (offer.coverageCountries.length > 4) { %> +<%= offer.coverageCountries.length - 4 %> more<% } %></span>
      </div>
    </div>
    <% } %>
    <div class="offer-foot">
      <span class="offer-price"><% if (price) { %>$<%= price %><% } %></span>
      <span class="offer-cta">Buy →</span>
    </div>
  </button>
  <% }) %>
</div>

<!-- No results message -->
<div id="noResults" class="empty-state" style="display:none">
  <div class="empty-icon">
    <i data-lucide="search-x" class="w-6 h-6"></i>
  </div>
  <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-1">No matching plans</h3>
  <p class="text-sm text-[var(--text-secondary)]">Try changing your filters</p>
</div>

<% } else { %>
<div class="empty-state">
  <div class="empty-icon">
    <i data-lucide="globe" class="w-6 h-6"></i>
  </div>
  <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-1">No plans available</h3>
  <p class="text-sm text-[var(--text-secondary)]">Check back later or contact support for assistance.</p>
</div>
<% } %>

<!-- Plan Detail Slide-up Panel -->
<div id="planBackdrop" class="plan-panel-backdrop" style="display:none">
  <div id="planPanel" class="plan-panel">
    <!-- Drag handle -->
    <div class="plan-panel-handle"><div></div></div>

    <!-- Scrollable content -->
    <div class="plan-panel-scroll">

      <!-- Header -->
      <div class="plan-panel-header">
        <div class="plan-panel-header-left">
          <div class="plan-panel-flag" id="ppFlag"></div>
          <div>
            <div class="plan-panel-operator" id="ppOperator"></div>
            <div class="plan-panel-sub" id="ppSub"></div>
          </div>
        </div>
        <div class="plan-panel-price" id="ppPrice"></div>
      </div>

      <!-- Stats grid -->
      <div class="plan-panel-stats">
        <div>
          <div class="plan-panel-stats-label">Data</div>
          <div class="plan-panel-stats-value" id="ppData"></div>
        </div>
        <div>
          <div class="plan-panel-stats-label">Duration</div>
          <div class="plan-panel-stats-value" id="ppDuration"></div>
        </div>
        <div>
          <div class="plan-panel-stats-label">Speed</div>
          <div class="plan-panel-stats-value" id="ppSpeed"></div>
        </div>
      </div>

      <!-- Detail rows -->
      <div class="plan-panel-details" id="ppDetails"></div>

      <!-- Note -->
      <div class="plan-panel-note" id="ppNote" style="display:none">
        <div class="plan-panel-section-label">Note</div>
        <div class="plan-panel-note-text" id="ppNoteText"></div>
      </div>

      <!-- Coverage -->
      <div class="plan-panel-coverage" id="ppCoverage" style="display:none">
        <div class="plan-panel-section-label">Coverage</div>
        <div class="plan-panel-coverage-list" id="ppCoverageList"></div>
      </div>

      <!-- Compatibility check -->
      <div class="plan-panel-compat">
        <div class="plan-panel-section-label">Device Compatibility</div>
        <div class="plan-panel-compat-selects">
          <select id="ppBrand" class="input">
            <option value="">Select brand...</option>
            <% if (typeof compatBrands !== 'undefined' && compatBrands) { %>
            <% compatBrands.forEach(function(b) { %>
            <option value="<%= b %>"><%= b %></option>
            <% }); %>
            <% } %>
          </select>
          <select id="ppModel" class="input" disabled>
            <option value="">Select model...</option>
          </select>
        </div>
        <div id="ppCompatResult"></div>
      </div>

    </div>

    <!-- Purchase button (sticky) -->
    <div class="plan-panel-buy">
      <form id="purchaseForm" method="post" action="/payment/create" data-no-protect="1">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="packageId" id="ppPackageId" value="">
        <input type="hidden" name="vendor" value="airalo">
        <input type="hidden" name="amount" id="ppAmount" value="">
        <input type="hidden" name="currency" value="USD">
        <input type="hidden" name="planName" id="ppPlanName" value="">
        <button type="submit" class="btn btn-primary plan-panel-buy-btn" id="ppBuyBtn">
          Buy for $0.00
        </button>
      </form>
    </div>
  </div>
</div>

<script>
var _currentFilter = 'all';

// Build dynamic subType filter chips
(function() {
  var grid = document.getElementById('offersGrid');
  if (!grid) return;
  var cards = Array.from(grid.querySelectorAll('.offer-card'));
  var allSubTypes = new Set();
  cards.forEach(function(c) {
    var st = c.dataset.subtypes;
    if (st) st.split(',').forEach(function(s) { if (s.trim()) allSubTypes.add(s.trim()); });
  });
  var container = document.getElementById('filterChips');
  if (container && allSubTypes.size > 0) {
    allSubTypes.forEach(function(st) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'filter-chip';
      btn.dataset.filter = 'subtype:' + st;
      btn.textContent = st.charAt(0).toUpperCase() + st.slice(1);
      btn.onclick = function() { filterOffers('subtype:' + st, btn); };
      container.appendChild(btn);
    });
  }
})();

function filterOffers(type, btn) {
  _currentFilter = type;
  document.querySelectorAll('.filter-chip').forEach(function(c) { c.classList.remove('active'); });
  btn.classList.add('active');
  applyFilterAndSort();
}

function sortOffers(value) {
  applyFilterAndSort();
}

function applyFilterAndSort() {
  var grid = document.getElementById('offersGrid');
  var cards = Array.from(grid.querySelectorAll('.offer-card'));
  var sortVal = document.getElementById('sortSelect').value;
  var visibleCount = 0;

  // Filter
  cards.forEach(function(card) {
    var isUnlimited = card.dataset.unlimited === '1';
    var subtypes = card.dataset.subtypes || '';
    var show = true;
    if (_currentFilter === 'unlimited') show = isUnlimited;
    else if (_currentFilter === 'gb') show = !isUnlimited;
    else if (_currentFilter.startsWith('subtype:')) {
      var target = _currentFilter.split(':')[1];
      show = subtypes.split(',').indexOf(target) !== -1;
    }
    card.style.display = show ? '' : 'none';
    card._visible = show;
    if (show) visibleCount++;
  });

  // Sort visible cards
  var sortField = sortVal.split('-')[0];
  var sortDir = sortVal.split('-')[1];
  cards.sort(function(a, b) {
    if (!a._visible && !b._visible) return 0;
    if (!a._visible) return 1;
    if (!b._visible) return -1;
    var va = parseFloat(a.dataset[sortField]) || 0;
    var vb = parseFloat(b.dataset[sortField]) || 0;
    return sortDir === 'asc' ? va - vb : vb - va;
  });

  // Re-append in order
  cards.forEach(function(card) { grid.appendChild(card); });

  // Update count
  document.getElementById('resultsCount').textContent = visibleCount + ' plan' + (visibleCount !== 1 ? 's' : '') + ' found';
  document.getElementById('noResults').style.display = visibleCount === 0 ? 'block' : 'none';
  grid.style.display = visibleCount === 0 ? 'none' : '';
}

// ─── Plan Detail Panel ─────────────────────────────────────────────────────
function openPlanPanel(card) {
  var d = card.dataset;
  var backdrop = document.getElementById('planBackdrop');
  var panel = document.getElementById('planPanel');

  // Header
  var cc = d.country || '';
  var flagEl = document.getElementById('ppFlag');
  while (flagEl.firstChild) flagEl.removeChild(flagEl.firstChild);
  if (cc) {
    var flagImg = document.createElement('img');
    flagImg.src = 'https://hatscripts.github.io/circle-flags/flags/' + cc.toLowerCase() + '.svg';
    flagImg.alt = cc;
    flagEl.appendChild(flagImg);
  } else {
    flagEl.textContent = '🌍';
  }
  document.getElementById('ppOperator').textContent = d.dataTitle || d.dataLabel || cc || 'Plan';
  document.getElementById('ppSub').textContent = [d.operator, cc, d.type].filter(Boolean).join(' · ');
  document.getElementById('ppPrice').textContent = '$' + d.priceDisplay;

  // Stats
  var dataLabel = d.unlimited === '1' ? 'Unlimited' : (d.dataLabel || '—');
  document.getElementById('ppData').textContent = dataLabel;
  document.getElementById('ppDuration').textContent = d.day ? d.day + ' days' : '—';
  var speedVal = d.speed || '';
  document.getElementById('ppSpeed').textContent = speedVal || 'LTE';

  // Details
  var detailsEl = document.getElementById('ppDetails');
  while (detailsEl.firstChild) detailsEl.removeChild(detailsEl.firstChild);
  var activation = d.activation;
  if (activation) {
    var actLabel = activation === 'first-usage' ? 'Starts on first use' : (activation.charAt(0).toUpperCase() + activation.slice(1));
    detailsEl.appendChild(buildDetailRow('zap', 'var(--brand-light)', 'var(--accent)', 'Activation', actLabel));
  }
  if (d.networks) {
    var netDesc = (d.operator ? d.operator + ' · ' : '') + d.networks;
    detailsEl.appendChild(buildDetailRow('signal', 'rgba(99,102,241,0.12)', '#6366f1', 'Network', netDesc));
  }

  // Note / Fair Usage Policy
  var noteEl = document.getElementById('ppNote');
  var noteTextEl = document.getElementById('ppNoteText');
  var noteLabelEl = noteEl.querySelector('.plan-panel-section-label');
  while (noteTextEl.firstChild) noteTextEl.removeChild(noteTextEl.firstChild);
  var isFairUsage = d.fairUsage === '1';
  if (isFairUsage) { noteEl.classList.add('fair-usage'); } else { noteEl.classList.remove('fair-usage'); }
  if (d.note) {
    noteLabelEl.textContent = isFairUsage ? 'Fair Usage Policy' : 'Notes';
    var parts = d.note.split(/\s*—\s*/);
    parts.forEach(function(part) {
      if (!part.trim()) return;
      var items = part.split(/\.\s+/).filter(function(s) { return s.trim(); });
      items.forEach(function(item) {
        var li = document.createElement('div');
        li.className = 'plan-panel-note-item';
        var bullet = document.createElement('span');
        bullet.className = 'plan-panel-note-bullet';
        bullet.textContent = '•';
        var text = document.createElement('span');
        text.textContent = item.replace(/\.$/, '').trim();
        li.appendChild(bullet);
        li.appendChild(text);
        noteTextEl.appendChild(li);
      });
    });
    noteEl.style.display = '';
  } else {
    noteEl.style.display = 'none';
  }

  // Coverage
  var coverageEl = document.getElementById('ppCoverage');
  try {
    var countries = JSON.parse(d.coverage || '[]');
    if (countries.length > 1) {
      document.getElementById('ppCoverageList').textContent = countries.join(', ');
      coverageEl.style.display = '';
    } else {
      coverageEl.style.display = 'none';
    }
  } catch (e) { coverageEl.style.display = 'none'; }

  // Purchase form
  document.getElementById('ppPackageId').value = d.packageId;
  document.getElementById('ppAmount').value = d.priceDisplay;
  document.getElementById('ppPlanName').value = d.dataTitle || d.dataLabel || cc || 'Plan';
  document.getElementById('ppBuyBtn').textContent = 'Buy for $' + d.priceDisplay;
  document.getElementById('ppBuyBtn').disabled = false;

  // Reset compatibility
  document.getElementById('ppBrand').value = '';
  document.getElementById('ppModel').value = '';
  document.getElementById('ppModel').disabled = true;
  var compatResult = document.getElementById('ppCompatResult');
  while (compatResult.firstChild) compatResult.removeChild(compatResult.firstChild);

  // Show panel
  backdrop.style.display = 'flex';
  requestAnimationFrame(function() {
    backdrop.classList.add('active');
    panel.classList.add('active');
  });
  document.body.style.overflow = 'hidden';

  // Render lucide icons in panel
  if (typeof lucide !== 'undefined') lucide.createIcons({ nodes: panel.querySelectorAll('[data-lucide]') });
}

function buildDetailRow(iconName, bgColor, iconColor, title, desc) {
  var row = document.createElement('div');
  row.className = 'plan-panel-detail-row';
  var iconWrap = document.createElement('div');
  iconWrap.className = 'plan-panel-detail-icon';
  iconWrap.style.background = bgColor;
  var icon = document.createElement('i');
  icon.setAttribute('data-lucide', iconName);
  icon.className = 'w-3.5 h-3.5';
  icon.style.color = iconColor;
  iconWrap.appendChild(icon);
  var textWrap = document.createElement('div');
  var titleEl = document.createElement('div');
  titleEl.className = 'plan-panel-detail-title';
  titleEl.textContent = title;
  var descEl = document.createElement('div');
  descEl.className = 'plan-panel-detail-desc';
  descEl.textContent = desc;
  textWrap.appendChild(titleEl);
  textWrap.appendChild(descEl);
  row.appendChild(iconWrap);
  row.appendChild(textWrap);
  return row;
}

function closePlanPanel() {
  var backdrop = document.getElementById('planBackdrop');
  var panel = document.getElementById('planPanel');
  backdrop.classList.remove('active');
  panel.classList.remove('active');
  document.body.style.overflow = '';
  setTimeout(function() { backdrop.style.display = 'none'; }, 300);
}

// Swipe-down to close (touch + mouse) — works from top AND bottom
(function() {
  var panel = document.getElementById('planPanel');
  var scroll = panel.querySelector('.plan-panel-scroll');
  var handle = panel.querySelector('.plan-panel-handle');
  var startY = 0;
  var currentY = 0;
  var dragging = false;

  function isAtTop() { return scroll.scrollTop <= 1; }
  function isAtBottom() { return scroll.scrollTop + scroll.clientHeight >= scroll.scrollHeight - 2; }

  function onStart(y) {
    startY = y;
    currentY = y;
    dragging = true;
    panel.style.transition = 'none';
  }
  function onMove(y, e) {
    if (!dragging) return;
    currentY = y;
    var diff = currentY - startY;
    // Only allow downward drag
    if (diff <= 0) { panel.style.transform = ''; return; }
    // Prevent browser pull-to-refresh
    if (e && e.cancelable) e.preventDefault();
    panel.style.transform = 'translateY(' + diff + 'px)';
  }
  function onEnd() {
    if (!dragging) return;
    dragging = false;
    var diff = currentY - startY;
    panel.style.transition = '';
    panel.style.transform = '';
    if (diff > 80) {
      closePlanPanel();
    }
  }

  // Handle bar: always draggable (primary dismiss gesture)
  handle.addEventListener('touchstart', function(e) {
    onStart(e.touches[0].clientY);
  }, { passive: true });
  handle.addEventListener('touchmove', function(e) {
    onMove(e.touches[0].clientY, e);
  }, { passive: false });
  handle.addEventListener('touchend', onEnd);

  handle.addEventListener('mousedown', function(e) { onStart(e.clientY); });

  // Scroll area: only draggable when at top or bottom edge
  scroll.addEventListener('touchstart', function(e) {
    if (isAtTop() || isAtBottom()) {
      this._edgeStartY = e.touches[0].clientY;
      this._wasAtTop = isAtTop();
      this._wasAtBottom = isAtBottom();
    } else {
      this._edgeStartY = null;
    }
  }, { passive: true });

  scroll.addEventListener('touchmove', function(e) {
    if (dragging) {
      onMove(e.touches[0].clientY, e);
      return;
    }
    if (this._edgeStartY == null) return;
    var touchY = e.touches[0].clientY;
    var diff = touchY - this._edgeStartY;
    // At top, swiping down → drag panel
    if (this._wasAtTop && diff > 10) {
      onStart(this._edgeStartY);
      onMove(touchY, e);
    }
    // At bottom, swiping down → drag panel
    if (this._wasAtBottom && diff > 10) {
      onStart(this._edgeStartY);
      onMove(touchY, e);
    }
  }, { passive: false });

  scroll.addEventListener('touchend', function() {
    this._edgeStartY = null;
    onEnd();
  });

  // Mouse events (desktop)
  document.addEventListener('mousemove', function(e) {
    if (dragging) onMove(e.clientY, e);
  });
  document.addEventListener('mouseup', onEnd);
  scroll.addEventListener('mousedown', function(e) {
    if (isAtTop() || isAtBottom()) onStart(e.clientY);
  });
})();

// Backdrop click
document.getElementById('planBackdrop').addEventListener('click', function(e) {
  if (e.target === this) closePlanPanel();
});
// Escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    var backdrop = document.getElementById('planBackdrop');
    if (backdrop && backdrop.style.display !== 'none') closePlanPanel();
  }
});
// Purchase form submit
document.getElementById('purchaseForm').addEventListener('submit', function() {
  var btn = document.getElementById('ppBuyBtn');
  btn.disabled = true;
  btn.textContent = 'Processing...';
});

// ─── Compatibility Check ───────────────────────────────────────────────────
document.getElementById('ppBrand').addEventListener('change', function() {
  var brand = this.value;
  var modelSel = document.getElementById('ppModel');
  var resultEl = document.getElementById('ppCompatResult');
  modelSel.length = 1; // keep first option
  modelSel.disabled = true;
  while (resultEl.firstChild) resultEl.removeChild(resultEl.firstChild);
  if (!brand) return;

  fetch('/api/compatibility?brand=' + encodeURIComponent(brand))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.models && data.models.length) {
        data.models.forEach(function(m) {
          var name = typeof m === 'string' ? m : m.name;
          var opt = document.createElement('option');
          opt.value = name;
          opt.textContent = name;
          modelSel.appendChild(opt);
        });
        modelSel.disabled = false;
      }
    })
    .catch(function() {});
});

document.getElementById('ppModel').addEventListener('change', function() {
  var brand = document.getElementById('ppBrand').value;
  var model = this.value;
  var resultEl = document.getElementById('ppCompatResult');
  while (resultEl.firstChild) resultEl.removeChild(resultEl.firstChild);
  if (!brand || !model) return;

  fetch('/api/compatibility?brand=' + encodeURIComponent(brand) + '&model=' + encodeURIComponent(model))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var row = document.createElement('div');
      var iconSpan = document.createElement('span');
      iconSpan.className = 'compat-icon';
      var textWrap = document.createElement('div');
      var titleEl = document.createElement('div');
      titleEl.className = 'compat-title';
      var descEl = document.createElement('div');
      descEl.className = 'compat-desc';

      if (data.result) {
        if (data.result.esim) {
          row.className = 'compat-result compat-ok';
          iconSpan.textContent = '✅';
          titleEl.textContent = 'Compatible';
          descEl.textContent = model + ' supports eSIM.' + (data.result.notes ? ' ' + data.result.notes : '');
        } else {
          row.className = 'compat-result compat-fail';
          iconSpan.textContent = '❌';
          titleEl.textContent = 'Not Compatible';
          descEl.textContent = model + ' does not support eSIM.';
        }
      } else {
        row.className = 'compat-result compat-unknown';
        iconSpan.textContent = 'ℹ️';
        titleEl.textContent = 'Not Found';
        descEl.textContent = model + ' is not in our database. Check your device settings for eSIM support.';
      }
      textWrap.appendChild(titleEl);
      textWrap.appendChild(descEl);
      row.appendChild(iconSpan);
      row.appendChild(textWrap);
      resultEl.appendChild(row);
    })
    .catch(function() {
      var row = document.createElement('div');
      row.className = 'compat-result compat-unknown';
      var iconSpan = document.createElement('span');
      iconSpan.className = 'compat-icon';
      iconSpan.textContent = '⚠️';
      var textWrap = document.createElement('div');
      var titleEl = document.createElement('div');
      titleEl.className = 'compat-title';
      titleEl.textContent = 'Error';
      var descEl = document.createElement('div');
      descEl.className = 'compat-desc';
      descEl.textContent = 'Could not check compatibility. Try again.';
      textWrap.appendChild(titleEl);
      textWrap.appendChild(descEl);
      row.appendChild(iconSpan);
      row.appendChild(textWrap);
      resultEl.appendChild(row);
    });
});

// Initial sort
document.addEventListener('DOMContentLoaded', function() {
  applyFilterAndSort();

  // Apply search query from URL if present
  var params = new URLSearchParams(window.location.search);
  var q = params.get('q');
  if (q) {
    var grid = document.getElementById('offersGrid');
    if (!grid) return;
    var cards = Array.from(grid.querySelectorAll('.offer-card'));
    var term = q.toLowerCase();
    var visible = 0;
    cards.forEach(function(card) {
      // Only filter cards that are currently visible (respect active filter)
      if (card.style.display === 'none') return;
      var text = card.textContent.toLowerCase();
      if (text.indexOf(term) === -1) {
        card.style.display = 'none';
      } else {
        visible++;
      }
    });
    // Update results count with search context
    var countEl = document.getElementById('resultsCount');
    if (countEl) {
      countEl.textContent = visible + ' plan' + (visible !== 1 ? 's' : '') + ' found for \u201c' + q + '\u201d';
    }
    // Show/hide no-results message
    var noResults = document.getElementById('noResults');
    if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    if (grid) grid.style.display = visible === 0 ? 'none' : '';
  }
});
</script>

