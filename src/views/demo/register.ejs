<div class="v2-login-wrap">
  <div class="v2-login-card v2-anim">
    <div class="v2-login-logo" style="color: var(--accent);">DataPatch</div>
    <p class="v2-login-sub">Yeni hesap olustur</p>

    <form action="/demo/offers" method="get">
      <div class="v2-input-group">
        <label class="v2-input-label">Kullanici Adi</label>
        <input type="text" class="v2-input" placeholder="kullaniciadi">
      </div>

      <div class="v2-input-group">
        <label class="v2-input-label">E-posta</label>
        <input type="email" class="v2-input" placeholder="ornek@email.com">
      </div>

      <div class="v2-input-group">
        <label class="v2-input-label">Gorunen Ad <span style="font-weight:400;color:var(--color-text-muted);">(istege bagli)</span></label>
        <input type="text" class="v2-input" placeholder="Ad Soyad">
      </div>

      <div class="v2-input-group">
        <label class="v2-input-label">Sifre</label>
        <input type="password" class="v2-input" placeholder="••••••••">
      </div>

      <div class="v2-input-group">
        <label class="v2-input-label">Sifre Tekrar</label>
        <input type="password" class="v2-input" placeholder="••••••••">
      </div>

      <button type="submit" class="v2-btn v2-btn-primary v2-btn-block">Kayit Ol</button>
    </form>

    <div class="v2-login-footer">
      Zaten hesabin var mi? <a href="/demo/login">Giris Yap</a>
    </div>
  </div>
</div>
