<%- include('partials/header', {title: 'Offers', user: locals.user}) %>

<div class="mb-6">
  <h1 class="text-page-title">Available Plans</h1>
  <p class="text-subtitle mt-1">Choose a Data plan for seamless connectivity worldwide</p>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-error mb-6">
  <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
  <%= error %>
</div>
<% } %>

<% if (typeof offers !== 'undefined' && offers && offers.length > 0) { %>

<!-- Filters & Sort Bar -->
<div class="flex flex-col sm:flex-row gap-3 mb-6">
  <!-- Data Type Filter -->
  <div class="flex gap-1.5 flex-wrap flex-1">
    <button type="button" class="filter-chip active" data-filter="all" onclick="filterOffers('all', this)">All</button>
    <button type="button" class="filter-chip" data-filter="unlimited" onclick="filterOffers('unlimited', this)">Unlimited</button>
    <button type="button" class="filter-chip" data-filter="gb" onclick="filterOffers('gb', this)">Fixed GB</button>
  </div>
  <!-- Sort -->
  <div class="flex items-center gap-2">
    <span class="text-xs text-[var(--text-tertiary)]">Sort:</span>
    <select id="sortSelect" onchange="sortOffers(this.value)" class="input text-sm !py-1.5 !px-3 !w-auto !min-w-0">
      <option value="price-asc">Price: Low → High</option>
      <option value="price-desc">Price: High → Low</option>
      <option value="data-desc">Data: Most First</option>
      <option value="data-asc">Data: Least First</option>
      <option value="duration-desc">Duration: Longest</option>
      <option value="duration-asc">Duration: Shortest</option>
    </select>
  </div>
</div>

<!-- Results Count -->
<p class="text-xs text-[var(--text-tertiary)] mb-4" id="resultsCount"></p>

<!-- Offers Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4" id="offersGrid">
  <% offers.forEach(function(offer, idx) { %>
  <%
    var price = offer.price && offer.price.fixed ? (offer.price.fixed / (offer.price.currencyDivisor || 100)).toFixed(2) : null;
    var currency = offer.price ? (offer.price.currency || 'USD') : 'USD';
    var dataLabel = offer.dataGB ? offer.dataGB : null;
    var durationLabel = offer.durationDays ? offer.durationDays + ' days' : '';
    var regionShort = '';
    if (offer.regions && offer.regions.length > 0) {
      regionShort = offer.regions[0];
      if (regionShort.length > 20) regionShort = offer.country || regionShort.substring(0, 18) + '...';
    } else if (offer.country) {
      regionShort = offer.country;
    }
    var speeds = offer.dataSpeeds || [];
    var bestSpeed = speeds.length ? speeds[speeds.length - 1] : '';
    var shortNotes = offer.shortNotes || '';
    var detailParts = [];
    if (speeds.length) detailParts.push('Network: ' + speeds.join(' / '));
    if (offer.dataUnlimited) detailParts.push('Unlimited Data');
    if (offer.voiceUnlimited) detailParts.push('Unlimited Voice');
    else if (offer.voiceMinutes > 0) detailParts.push(offer.voiceMinutes + ' min voice');
    if (offer.smsUnlimited) detailParts.push('Unlimited SMS');
    else if (offer.smsNumber > 0) detailParts.push(offer.smsNumber + ' SMS');
    if (shortNotes) detailParts.push(shortNotes);
    var detailStr = detailParts.join(' · ');
    var priceNum = price ? parseFloat(price) : 0;
    var dataNum = offer.dataUnlimited ? 99999 : (offer.dataGB || 0);
    var durationNum = offer.durationDays || 0;
  %>
  <button type="button" class="offer-card"
    data-price="<%= priceNum %>"
    data-data="<%= dataNum %>"
    data-duration="<%= durationNum %>"
    data-unlimited="<%= offer.dataUnlimited ? '1' : '0' %>"
    onclick="confirmPurchase('<%= offer.offerId %>', '<%= (offer.brandName || offer.brand || 'Data').replace(/'/g, "\\'") %>', '<%= price || '0.00' %>', '<%= currency %>', '<%= detailStr.replace(/'/g, "\\'") %>')">
    <div class="offer-header">
      <span class="offer-region"><%= regionShort || 'Global' %></span>
      <% if (bestSpeed) { %>
      <span class="offer-speed-badge"><%= bestSpeed %></span>
      <% } %>
    </div>
    <div class="offer-body">
      <% if (offer.dataUnlimited) { %>
      <span class="offer-data">Unlimited</span>
      <% } else if (dataLabel) { %>
      <span class="offer-data"><%= dataLabel %></span>
      <span class="offer-data-unit">GB</span>
      <% } else { %>
      <span class="offer-data">Data</span>
      <% } %>
      <% if (durationLabel) { %>
      <span class="offer-duration"><%= durationLabel %></span>
      <% } %>
    </div>
    <div class="offer-footer">
      <div>
        <% if (price) { %>
        <span class="offer-price">$<%= price %></span>
        <span class="offer-price-currency"><%= currency %></span>
        <% } %>
      </div>
      <span class="offer-cta">
        Buy <i data-lucide="arrow-right" class="w-3.5 h-3.5"></i>
      </span>
    </div>
  </button>
  <% }) %>
</div>

<!-- No results message -->
<div id="noResults" class="empty-state" style="display:none">
  <div class="empty-icon">
    <i data-lucide="search-x" class="w-6 h-6"></i>
  </div>
  <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-1">No matching plans</h3>
  <p class="text-sm text-[var(--text-secondary)]">Try changing your filters</p>
</div>

<% } else { %>
<div class="empty-state">
  <div class="empty-icon">
    <i data-lucide="globe" class="w-6 h-6"></i>
  </div>
  <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-1">No plans available</h3>
  <p class="text-sm text-[var(--text-secondary)]">Check back later or contact support for assistance.</p>
</div>
<% } %>

<!-- Purchase Confirmation Modal -->
<div id="purchaseModal" class="modal-backdrop hidden" style="display:none">
  <div class="confirm-modal">
    <div class="flex items-center gap-3 mb-5">
      <div class="w-10 h-10 rounded-xl bg-[var(--brand-light)] flex items-center justify-center">
        <i data-lucide="shopping-cart" class="w-5 h-5 text-[var(--brand-primary)]"></i>
      </div>
      <div>
        <h3 class="text-base font-semibold text-[var(--text-primary)]">Confirm Purchase</h3>
        <p class="text-xs text-[var(--text-secondary)]">Review your selection</p>
      </div>
    </div>
    <div class="p-4 rounded-lg bg-[var(--surface-1)] border border-[var(--border-subtle)] mb-5">
      <p class="text-sm text-[var(--text-secondary)]">Plan: <strong class="text-[var(--text-primary)]" id="modalPlanName"></strong></p>
      <p class="text-lg font-bold text-[var(--brand-primary)] mt-1" id="modalPlanPrice"></p>
      <p class="text-xs text-[var(--text-tertiary)] mt-1.5" id="modalPlanDetails" style="display:none"></p>
    </div>
    <form id="purchaseForm" method="post" action="/payment/create">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="offerId" id="modalOfferId" value="">
      <input type="hidden" name="amount" id="modalAmount" value="">
      <input type="hidden" name="currency" id="modalCurrency" value="">
      <input type="hidden" name="planName" id="modalPlanNameHidden" value="">
      <div class="flex gap-3">
        <button type="button" class="btn btn-secondary flex-1" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary flex-1">
          <i data-lucide="check" class="w-4 h-4"></i>
          Confirm
        </button>
      </div>
    </form>
  </div>
</div>

<script>
var _currentFilter = 'all';

function filterOffers(type, btn) {
  _currentFilter = type;
  // Update active chip
  document.querySelectorAll('.filter-chip').forEach(function(c) { c.classList.remove('active'); });
  btn.classList.add('active');
  applyFilterAndSort();
}

function sortOffers(value) {
  applyFilterAndSort();
}

function applyFilterAndSort() {
  var grid = document.getElementById('offersGrid');
  var cards = Array.from(grid.querySelectorAll('.offer-card'));
  var sortVal = document.getElementById('sortSelect').value;
  var visibleCount = 0;

  // Filter
  cards.forEach(function(card) {
    var isUnlimited = card.dataset.unlimited === '1';
    var show = true;
    if (_currentFilter === 'unlimited') show = isUnlimited;
    else if (_currentFilter === 'gb') show = !isUnlimited;
    card.style.display = show ? '' : 'none';
    card._visible = show;
    if (show) visibleCount++;
  });

  // Sort visible cards
  var sortField = sortVal.split('-')[0];
  var sortDir = sortVal.split('-')[1];
  cards.sort(function(a, b) {
    if (!a._visible && !b._visible) return 0;
    if (!a._visible) return 1;
    if (!b._visible) return -1;
    var va = parseFloat(a.dataset[sortField]) || 0;
    var vb = parseFloat(b.dataset[sortField]) || 0;
    return sortDir === 'asc' ? va - vb : vb - va;
  });

  // Re-append in order
  cards.forEach(function(card) { grid.appendChild(card); });

  // Update count
  document.getElementById('resultsCount').textContent = visibleCount + ' plan' + (visibleCount !== 1 ? 's' : '') + ' found';
  document.getElementById('noResults').style.display = visibleCount === 0 ? 'block' : 'none';
  grid.style.display = visibleCount === 0 ? 'none' : '';
}

function confirmPurchase(offerId, planName, price, currency, details) {
  document.getElementById('modalOfferId').value = offerId;
  document.getElementById('modalAmount').value = price;
  document.getElementById('modalCurrency').value = currency;
  document.getElementById('modalPlanNameHidden').value = planName;
  document.getElementById('modalPlanName').textContent = planName;
  document.getElementById('modalPlanPrice').textContent = price + ' ' + currency;
  var detailsEl = document.getElementById('modalPlanDetails');
  if (details) {
    detailsEl.textContent = details;
    detailsEl.style.display = 'block';
  } else {
    detailsEl.style.display = 'none';
  }
  var modal = document.getElementById('purchaseModal');
  modal.classList.remove('hidden');
  modal.style.display = 'flex';
}
function closeModal() {
  var modal = document.getElementById('purchaseModal');
  modal.classList.add('hidden');
  modal.style.display = 'none';
}
document.getElementById('purchaseModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// Initial sort
document.addEventListener('DOMContentLoaded', function() {
  applyFilterAndSort();
});
</script>

<%- include('partials/footer') %>
