<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — DataPatch Demo</title>
  <link rel="stylesheet" href="/demo/styles.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📱</text></svg>">
</head>
<body class="v2">

<% if (locals.showTopBar !== false) { %>
<div class="v2-topbar">
  <% if (locals.backUrl) { %>
  <a href="<%= backUrl %>" class="v2-topbar-back">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    <%= title %>
  </a>
  <% } else { %>
  <a href="/demo" class="v2-topbar-logo">DataPatch</a>
  <% } %>

  <% if (locals.adminMode) { %>
  <nav class="v2-topbar-nav">
    <a href="/demo/admin/dashboard" class="<%= locals.activeTab === 'dashboard' ? 'active' : '' %>">Dashboard</a>
    <a href="/demo/admin/users" class="<%= locals.activeTab === 'users' ? 'active' : '' %>">Kullanıcılar</a>
    <a href="/demo/admin/esims" class="<%= locals.activeTab === 'esims' ? 'active' : '' %>">eSIM'ler</a>
    <a href="/demo/admin/payments" class="<%= locals.activeTab === 'payments' ? 'active' : '' %>">Ödemeler</a>
    <a href="/demo/admin/vendors" class="<%= locals.activeTab === 'vendors' ? 'active' : '' %>">Vendorlar</a>
    <a href="/demo/admin/emails">E-postalar</a>
  </nav>
  <% } else if (!locals.backUrl) { %>
  <nav class="v2-topbar-nav">
    <a href="/demo/offers" class="<%= locals.activeTab === 'plans' ? 'active' : '' %>">Planlar</a>
    <a href="/demo/purchases" class="<%= locals.activeTab === 'esims' ? 'active' : '' %>">eSIM'lerim</a>
    <a href="/demo/payment-history" class="<%= locals.activeTab === 'payments' ? 'active' : '' %>">Ödemeler</a>
    <a href="/demo/compatibility">Uyumluluk</a>
    <a href="/demo/profile" class="<%= locals.activeTab === 'profile' ? 'active' : '' %>">Profil</a>
  </nav>
  <% } %>

  <div class="v2-topbar-right">
    <div class="v2-topbar-search">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="text" placeholder="Plan, ülke veya eSIM ara...">
    </div>
    <div class="v2-topbar-bell">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
    </div>
    <a href="/demo/profile" class="v2-topbar-avatar">T</a>
  </div>
</div>

<% if (locals.backUrl) { %>
<div class="v2-breadcrumb">
  <a href="/demo">Ana Sayfa</a><span>›</span><%= title %>
</div>
<% } %>
<% } %>

<% if (locals.adminMode) { %>
<div class="v2-content-wide"><%- body %></div>
<% } else { %>
<%- body %>
<% } %>

<% if (locals.showTabBar !== false) { %>
<% if (locals.adminMode) { %>
<nav class="v2-tabbar">
  <a href="/demo/admin/dashboard" class="<%= locals.activeTab === 'dashboard' ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
    <span>Panel</span>
  </a>
  <a href="/demo/admin/users" class="<%= locals.activeTab === 'users' ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
    <span>Kullanıcılar</span>
  </a>
  <a href="/demo/admin/esims" class="<%= locals.activeTab === 'esims' ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></svg>
    <span>eSIM</span>
  </a>
  <a href="/demo/admin/payments" class="<%= locals.activeTab === 'payments' ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>
    <span>Ödeme</span>
  </a>
  <a href="/demo/admin/vendors" class="<%= locals.activeTab === 'vendors' ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M2 7h20"/></svg>
    <span>Vendor</span>
  </a>
</nav>
<% } else { %>
<nav class="v2-tabbar">
  <a href="/demo/offers" class="<%= locals.activeTab === 'plans' ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/></svg>
    <span>Planlar</span>
  </a>
  <a href="/demo/purchases" class="<%= locals.activeTab === 'esims' ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></svg>
    <span>eSIM</span>
  </a>
  <a href="/demo/payment-history" class="<%= locals.activeTab === 'payments' ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>
    <span>Ödeme</span>
  </a>
  <a href="/demo/profile" class="<%= locals.activeTab === 'profile' ? 'active' : '' %>">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 0 0-16 0"/></svg>
    <span>Profil</span>
  </a>
</nav>
<% } %>
<% } %>

</body>
</html>