<div class="v2-login-wrap">
  <div class="v2-login-card v2-anim">
    <div class="v2-login-logo" style="color: var(--accent);">DataPatch</div>
    <p class="v2-login-sub">Yeni sifreni belirle</p>

    <form action="/demo/login" method="get">
      <div class="v2-input-group">
        <label class="v2-input-label">Yeni Sifre</label>
        <input type="password" class="v2-input" placeholder="••••••••">
      </div>

      <div class="v2-input-group">
        <label class="v2-input-label">Sifre Tekrar</label>
        <input type="password" class="v2-input" placeholder="••••••••">
      </div>

      <button type="submit" class="v2-btn v2-btn-primary v2-btn-block">Sifreyi Guncelle</button>
    </form>

    <div class="v2-login-footer">
      <a href="/demo/login">Giris sayfasina don</a>
    </div>
  </div>
</div>
