<!-- Hero -->
<div class="demo-landing-hero">
  <div class="demo-landing-hero-content">
    <h1 class="demo-landing-title demo-animate-in">
      Sınırsız Bağlantı,<br>
      <span class="demo-gradient-text">Sınırsız Keşif</span>
    </h1>
    <p class="demo-landing-subtitle demo-animate-in">
      190+ ülkede anında aktif olan eSIM planlarıyla her zaman bağlı kalın. Fiziksel SIM karta elveda deyin.
    </p>
    <div class="demo-landing-cta-row demo-animate-in">
      <a href="/demo/offers" class="demo-btn demo-btn-primary demo-btn-lg">Planları Keşfet</a>
      <a href="/demo/login" class="demo-btn demo-btn-outline demo-btn-lg">Giriş Yap</a>
    </div>
  </div>
</div>

<!-- Trust Bar -->
<div class="demo-trust-bar">
  <div class="demo-trust-item demo-animate-in">
    <div class="demo-trust-icon">🌍</div>
    <span>190+ Ülke</span>
  </div>
  <div class="demo-trust-item demo-animate-in">
    <div class="demo-trust-icon">⚡</div>
    <span>Anında Aktivasyon</span>
  </div>
  <div class="demo-trust-item demo-animate-in">
    <div class="demo-trust-icon">🔒</div>
    <span>Güvenli Ödeme</span>
  </div>
  <div class="demo-trust-item demo-animate-in">
    <div class="demo-trust-icon">💬</div>
    <span>7/24 Destek</span>
  </div>
</div>

<div class="demo-divider"></div>

<!-- How It Works -->
<div class="demo-section">
  <h2 class="demo-section-title">Nasıl Çalışır?</h2>
  <div class="demo-steps-grid">
    <div class="demo-step-card demo-animate-in">
      <div class="demo-step-card-number">1</div>
      <h3 class="demo-step-card-title">Planını Seç</h3>
      <p class="demo-step-card-desc">Gitmek istediğin ülkeye uygun eSIM planını seç. Fiyatları karşılaştır.</p>
    </div>
    <div class="demo-step-card demo-animate-in">
      <div class="demo-step-card-number">2</div>
      <h3 class="demo-step-card-title">Ödeme Yap</h3>
      <p class="demo-step-card-desc">Güvenli ödeme ile anında satın al. Kredi kartı veya Apple Pay ile öde.</p>
    </div>
    <div class="demo-step-card demo-animate-in">
      <div class="demo-step-card-number">3</div>
      <h3 class="demo-step-card-title">QR ile Yükle</h3>
      <p class="demo-step-card-desc">QR kodu tara veya tek dokunuşla eSIM'ini cihazına yükle. Hemen kullanmaya başla.</p>
    </div>
  </div>
</div>

<div class="demo-divider"></div>

<!-- Featured Plans -->
<div class="demo-landing-plans">
  <div class="demo-plans-header">
    <h2 class="demo-section-title" style="margin-bottom:0;text-align:left;">Popüler Planlar</h2>
    <a href="/demo/offers" class="demo-plans-link">Tümünü Gör →</a>
  </div>

  <div class="demo-offers-list">
    <% plans.slice(0, 3).forEach((plan, i) => { %>
    <a href="/demo/status" class="demo-offer-row demo-animate-in">
      <div class="demo-offer-flag demo-offer-flag-sm" style="background: <%= plan.flagBg %>;">
        <%= plan.flag %>
      </div>
      <div class="demo-offer-row-info">
        <div class="demo-offer-row-name">
          <%= plan.country %>
          <span class="demo-badge demo-badge-<%= plan.network.toLowerCase() %>"><%= plan.network %></span>
        </div>
        <div class="demo-offer-row-meta"><%= plan.data %> • <%= plan.duration %></div>
      </div>
      <div class="demo-offer-row-price demo-gradient-text"><%= plan.price %></div>
      <div class="demo-offer-arrow">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </div>
    </a>
    <% }) %>
  </div>
</div>

<!-- Footer -->
<div class="demo-footer">
  <div class="demo-footer-logo demo-gradient-text">DataPatch</div>
  <p>&copy; 2026 DataPatch. Tüm hakları saklıdır.</p>
</div>
