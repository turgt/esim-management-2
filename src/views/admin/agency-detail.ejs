<%- include('../partials/header', {title: agency.name, user: locals.user}) %>

<div class="mb-8 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
  <div>
    <a href="/admin/agencies" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] inline-flex items-center gap-1 mb-2">
      <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i>
      Back to Agencies
    </a>
    <h1 class="text-page-title flex items-center gap-3">
      <%= agency.name %>
      <% if (agency.status === 'active') { %>
      <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Active</span>
      <% } else { %>
      <span class="badge badge-neutral"><span class="badge-dot bg-gray-400"></span>Suspended</span>
      <% } %>
    </h1>
    <p class="text-sm text-[var(--text-secondary)] mt-1">
      <span class="font-mono text-[var(--brand-primary)]"><%= agency.slug %></span>
      <% if (agency.contactEmail) { %> &bull; <%= agency.contactEmail %><% } %>
    </p>
  </div>
  <div class="flex gap-2 flex-wrap">
    <button onclick="document.getElementById('new-contract-modal').classList.remove('hidden')" class="btn btn-primary">
      <i data-lucide="plus" class="w-4 h-4"></i>
      New Contract
    </button>
    <button onclick="document.getElementById('edit-agency-modal').classList.remove('hidden')" class="btn btn-secondary">
      <i data-lucide="edit" class="w-4 h-4"></i>
      Edit
    </button>
    <form method="post" action="/admin/agencies/<%= agency.id %>/toggle-status" class="inline">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <button type="submit" class="btn btn-secondary">
        <% if (agency.status === 'active') { %>
        <i data-lucide="pause" class="w-4 h-4"></i> Suspend
        <% } else { %>
        <i data-lucide="play" class="w-4 h-4"></i> Activate
        <% } %>
      </button>
    </form>
    <form method="post" action="/admin/agencies/<%= agency.id %>/delete" onsubmit="return confirm('Are you sure you want to delete this agency? All users will be unlinked and active contracts will be terminated.')" class="inline">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <button type="submit" class="btn btn-secondary text-rose-600 dark:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-500/10">
        <i data-lucide="trash-2" class="w-4 h-4"></i>
        Delete
      </button>
    </form>
  </div>
</div>

<!-- Info Cards -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="stat-card">
    <div class="stat-icon bg-[var(--brand-light)]">
      <i data-lucide="file-text" class="w-5 h-5 text-[var(--brand-primary)]"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Total Contracts</p>
      <p class="stat-value"><%= agency.AgencyContracts ? agency.AgencyContracts.length : 0 %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-emerald-50 dark:bg-emerald-500/10">
      <i data-lucide="file-check" class="w-5 h-5 text-emerald-600 dark:text-emerald-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Active Contracts</p>
      <p class="stat-value text-emerald-600 dark:text-emerald-400"><%= agency.AgencyContracts ? agency.AgencyContracts.filter(c => c.status === 'active').length : 0 %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-sky-50 dark:bg-sky-500/10">
      <i data-lucide="users" class="w-5 h-5 text-sky-600 dark:text-sky-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Users</p>
      <p class="stat-value"><%= agency.users ? agency.users.length : 0 %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-violet-50 dark:bg-violet-500/10">
      <i data-lucide="plane" class="w-5 h-5 text-violet-600 dark:text-violet-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Total Bookings</p>
      <% const totalBookings = bookingStats ? bookingStats.reduce((s, b) => s + parseInt(b.count), 0) : 0; %>
      <p class="stat-value"><%= totalBookings %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-amber-50 dark:bg-amber-500/10">
      <i data-lucide="calendar" class="w-5 h-5 text-amber-600 dark:text-amber-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Created</p>
      <p class="stat-value text-sm"><%= new Date(agency.createdAt).toLocaleDateString('en-GB') %></p>
    </div>
  </div>
</div>

<% if (bookingStats && bookingStats.length > 0) { %>
<div class="flex flex-wrap gap-3 mb-8">
  <% bookingStats.forEach(function(bs) { %>
  <div class="flex items-center gap-2 bg-[var(--surface-2)] rounded-lg px-3 py-2">
    <% if (bs.status === 'completed') { %>
    <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
    <% } else if (bs.status === 'pending') { %>
    <span class="w-2 h-2 rounded-full bg-amber-500"></span>
    <% } else if (bs.status === 'cancelled') { %>
    <span class="w-2 h-2 rounded-full bg-rose-500"></span>
    <% } else { %>
    <span class="w-2 h-2 rounded-full bg-gray-400"></span>
    <% } %>
    <span class="text-xs font-medium text-[var(--text-secondary)] capitalize"><%= bs.status %></span>
    <span class="text-xs font-bold text-[var(--text-primary)]"><%= bs.count %></span>
  </div>
  <% }) %>
</div>
<% } %>

<!-- Contracts Section -->
<div class="mb-8">
  <h2 class="text-base font-semibold text-[var(--text-primary)] mb-4 flex items-center gap-2">
    <i data-lucide="file-text" class="w-4 h-4 text-[var(--text-tertiary)]"></i>
    Contracts
  </h2>
  <div class="table-container">
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>Package</th>
            <th>Qty</th>
            <th>Used</th>
            <th>Unit Price</th>
            <th>End Date</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (agency.AgencyContracts && agency.AgencyContracts.length > 0) { %>
          <% agency.AgencyContracts.forEach(function(contract) { %>
          <tr>
            <td>
              <div>
                <p class="font-medium text-[var(--text-primary)]">
                  <%= contract.package ? contract.package.title : 'Package #' + contract.airaloPackageId %>
                </p>
                <% if (contract.package) { %>
                <p class="text-xs text-[var(--text-tertiary)]">
                  <%= contract.package.data %> / <%= contract.package.day %> days
                </p>
                <% } %>
              </div>
            </td>
            <td class="font-semibold"><%= contract.quantity %></td>
            <td>
              <% const pct = contract.quantity > 0 ? Math.round((contract.usedQuantity / contract.quantity) * 100) : 0; %>
              <p class="font-semibold"><%= contract.usedQuantity %></p>
              <div class="w-20 h-1.5 bg-[var(--bg-tertiary)] rounded-full mt-1">
                <div class="h-1.5 rounded-full <%= pct >= 90 ? 'bg-rose-500' : pct >= 70 ? 'bg-amber-500' : 'bg-emerald-500' %>" style="width: <%= pct %>%"></div>
              </div>
            </td>
            <td class="text-sm">
              <span class="font-semibold"><%= Number(contract.unitPriceAmount).toFixed(2) %></span>
              <span class="text-[var(--text-tertiary)]"><%= contract.unitPriceCurrency %></span>
            </td>
            <td class="text-sm text-[var(--text-secondary)]">
              <%= new Date(contract.contractEndAt).toLocaleDateString('en-GB') %>
            </td>
            <td>
              <% if (contract.status === 'active') { %>
              <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Active</span>
              <% } else if (contract.status === 'expired') { %>
              <span class="badge badge-neutral"><span class="badge-dot bg-gray-400"></span>Expired</span>
              <% } else { %>
              <span class="badge badge-neutral"><span class="badge-dot bg-gray-400"></span><%= contract.status %></span>
              <% } %>
            </td>
            <td class="text-right">
              <% if (contract.status === 'active') { %>
              <form method="post" action="/admin/agencies/<%= agency.id %>/contracts/<%= contract.id %>/terminate" onsubmit="return confirm('Are you sure you want to terminate this contract?')" class="inline">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <button type="submit" class="btn btn-secondary btn-sm text-rose-600 dark:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-500/10">
                  <i data-lucide="x-circle" class="w-3.5 h-3.5"></i>
                  Terminate
                </button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% } else { %>
          <tr>
            <td colspan="7" class="text-center py-10 text-sm text-[var(--text-tertiary)]">
              <i data-lucide="file-text" class="w-7 h-7 mx-auto mb-2 opacity-40"></i>
              <p>No contracts yet</p>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Users Section -->
<div class="mb-8">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-base font-semibold text-[var(--text-primary)] flex items-center gap-2">
      <i data-lucide="users" class="w-4 h-4 text-[var(--text-tertiary)]"></i>
      Users
    </h2>
    <button onclick="document.getElementById('assign-user-modal').classList.remove('hidden')" class="btn btn-secondary btn-sm">
      <i data-lucide="user-plus" class="w-3.5 h-3.5"></i>
      Assign User
    </button>
  </div>
  <div class="table-container">
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>User</th>
            <th>Role</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (agency.users && agency.users.length > 0) { %>
          <% agency.users.forEach(function(u) { %>
          <tr>
            <td>
              <div class="flex items-center gap-2.5">
                <div class="avatar avatar-sm" style="background: linear-gradient(135deg, #4f46e5, #7c3aed);"><%= u.username.charAt(0).toUpperCase() %></div>
                <div>
                  <p class="font-medium text-[var(--text-primary)]"><%= u.username %></p>
                  <% if (u.email) { %>
                  <p class="text-xs text-[var(--text-tertiary)]"><%= u.email %></p>
                  <% } %>
                </div>
              </div>
            </td>
            <td>
              <form method="post" action="/admin/agencies/<%= agency.id %>/users/<%= u.id %>/role" class="inline">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <input type="hidden" name="agencyRole" value="<%= u.agencyRole === 'owner' ? 'staff' : 'owner' %>">
                <button type="submit" class="group" title="Click to toggle role">
                  <% if (u.agencyRole === 'owner') { %>
                  <span class="badge badge-success cursor-pointer group-hover:opacity-70"><span class="badge-dot bg-emerald-500"></span>Owner</span>
                  <% } else { %>
                  <span class="badge badge-neutral cursor-pointer group-hover:opacity-70"><span class="badge-dot bg-sky-400"></span>Staff</span>
                  <% } %>
                </button>
              </form>
            </td>
            <td>
              <% if (u.isActive !== false) { %>
              <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Active</span>
              <% } else { %>
              <span class="badge badge-neutral"><span class="badge-dot bg-gray-400"></span>Inactive</span>
              <% } %>
            </td>
            <td class="text-right">
              <form method="post" action="/admin/agencies/<%= agency.id %>/users/<%= u.id %>/remove" onsubmit="return confirm('Remove this user from the agency?')" class="inline">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <button type="submit" class="btn btn-secondary btn-sm text-rose-600 dark:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-500/10">
                  <i data-lucide="user-minus" class="w-3.5 h-3.5"></i>
                </button>
              </form>
            </td>
          </tr>
          <% }) %>
          <% } else { %>
          <tr>
            <td colspan="4" class="text-center py-10 text-sm text-[var(--text-tertiary)]">
              <i data-lucide="users" class="w-7 h-7 mx-auto mb-2 opacity-40"></i>
              <p>No users assigned yet</p>
              <button onclick="document.getElementById('assign-user-modal').classList.remove('hidden')" class="text-[var(--brand-primary)] hover:underline mt-1 inline-block">Assign a user</button>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Edit Agency Modal -->
<div id="edit-agency-modal" class="modal-backdrop hidden" onclick="document.getElementById('edit-agency-modal').classList.add('hidden')">
  <div class="confirm-modal" style="max-width:480px" onclick="event.stopPropagation()">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-lg font-semibold text-[var(--text-primary)]">Edit Agency</h2>
      <button onclick="document.getElementById('edit-agency-modal').classList.add('hidden')" class="text-[var(--text-tertiary)] hover:text-[var(--text-primary)] p-1">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>
    </div>
    <form method="post" action="/admin/agencies/<%= agency.id %>/edit" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div>
        <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Agency Name <span class="text-rose-500">*</span></label>
        <input type="text" name="name" required class="input" value="<%= agency.name %>">
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Contact Name</label>
          <input type="text" name="contactName" class="input" value="<%= agency.contactName || '' %>">
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Phone</label>
          <input type="tel" name="phone" class="input" value="<%= agency.phone || '' %>">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Email <span class="text-rose-500">*</span></label>
        <input type="email" name="contactEmail" required class="input" value="<%= agency.contactEmail %>">
      </div>
      <div class="bg-[var(--surface-2)] rounded-lg p-3">
        <p class="text-xs text-[var(--text-tertiary)]">Slug: <span class="font-mono text-[var(--brand-primary)]"><%= agency.slug %></span> (cannot be changed)</p>
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="document.getElementById('edit-agency-modal').classList.add('hidden')" class="btn btn-secondary">Cancel</button>
        <button type="submit" class="btn btn-primary">
          <i data-lucide="check" class="w-4 h-4"></i>
          Save
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Assign User Modal -->
<div id="assign-user-modal" class="modal-backdrop hidden" onclick="document.getElementById('assign-user-modal').classList.add('hidden')">
  <div class="confirm-modal" style="max-width:420px" onclick="event.stopPropagation()">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-lg font-semibold text-[var(--text-primary)]">Assign User</h2>
      <button onclick="document.getElementById('assign-user-modal').classList.add('hidden')" class="text-[var(--text-tertiary)] hover:text-[var(--text-primary)] p-1">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>
    </div>
    <form method="post" action="/admin/agencies/<%= agency.id %>/users" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div>
        <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">User <span class="text-rose-500">*</span></label>
        <select name="userId" required class="input">
          <option value="">Select user...</option>
          <% if (availableUsers && availableUsers.length > 0) { %>
          <% availableUsers.forEach(function(u) { %>
          <option value="<%= u.id %>"><%= u.username %><% if (u.email) { %> (<%= u.email %>)<% } %></option>
          <% }) %>
          <% } %>
        </select>
        <p class="text-xs text-[var(--text-tertiary)] mt-1">Only active users not assigned to another agency are listed</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Role <span class="text-rose-500">*</span></label>
        <select name="agencyRole" required class="input">
          <option value="staff">Staff</option>
          <option value="owner">Owner</option>
        </select>
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="document.getElementById('assign-user-modal').classList.add('hidden')" class="btn btn-secondary">Cancel</button>
        <button type="submit" class="btn btn-primary">
          <i data-lucide="user-plus" class="w-4 h-4"></i>
          Assign
        </button>
      </div>
    </form>
  </div>
</div>

<!-- New Contract Modal -->
<div id="new-contract-modal" class="modal-backdrop hidden" onclick="document.getElementById('new-contract-modal').classList.add('hidden')">
  <div class="confirm-modal" style="max-width:480px" onclick="event.stopPropagation()">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-lg font-semibold text-[var(--text-primary)]">New Contract</h2>
      <button onclick="document.getElementById('new-contract-modal').classList.add('hidden')" class="text-[var(--text-tertiary)] hover:text-[var(--text-primary)] p-1">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>
    </div>
    <form method="post" action="/admin/agencies/<%= agency.id %>/contracts" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div>
        <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Package <span class="text-rose-500">*</span></label>
        <select name="airaloPackageId" required class="input">
          <option value="">Select package...</option>
          <% if (packages && packages.length > 0) { %>
          <% packages.forEach(function(pkg) { %>
          <option value="<%= pkg.id %>">
            <%= pkg.title %> — <%= pkg.data %> / <%= pkg.day %> days (<%= pkg.countryCode %>)
          </option>
          <% }) %>
          <% } %>
        </select>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Quantity <span class="text-rose-500">*</span></label>
          <input type="number" name="quantity" required min="1" class="input" placeholder="100">
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">End Date <span class="text-rose-500">*</span></label>
          <input type="date" name="contractEndAt" required class="input">
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Unit Price <span class="text-rose-500">*</span></label>
          <input type="number" name="unitPriceAmount" required min="0" step="0.01" class="input" placeholder="12.50">
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Currency</label>
          <select name="unitPriceCurrency" class="input">
            <option value="USD">USD</option>
            <option value="EUR">EUR</option>
            <option value="TRY">TRY</option>
          </select>
        </div>
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="document.getElementById('new-contract-modal').classList.add('hidden')" class="btn btn-secondary">Cancel</button>
        <button type="submit" class="btn btn-primary">
          <i data-lucide="plus" class="w-4 h-4"></i>
          Create Contract
        </button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
