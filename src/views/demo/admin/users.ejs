<div class="demo-page-title">Kullanıcı Yönetimi</div>

<!-- Add User Form -->
<div class="demo-form-card demo-animate-in">
  <div class="demo-form-title">Yeni Kullanıcı Ekle</div>
  <form class="demo-form-grid" style="grid-template-columns: 1fr 1fr 1fr auto;">
    <div class="demo-input-group">
      <label class="demo-input-label">Kullanıcı Adı</label>
      <input type="text" class="demo-input" placeholder="Kullanıcı adı">
    </div>
    <div class="demo-input-group">
      <label class="demo-input-label">E-posta</label>
      <input type="email" class="demo-input" placeholder="E-posta adresi">
    </div>
    <div class="demo-input-group">
      <label class="demo-input-label">Şifre</label>
      <input type="password" class="demo-input" placeholder="Şifre">
    </div>
    <div>
      <button type="button" class="demo-btn demo-btn-primary demo-btn-sm">Ekle</button>
    </div>
  </form>
</div>

<!-- Search -->
<div class="demo-search-wrapper">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
  <input type="text" class="demo-search-input" placeholder="Kullanıcı ara...">
</div>

<!-- Users Table -->
<div class="demo-table-card demo-animate-in">
  <div class="demo-table-responsive">
    <table class="demo-table">
      <thead>
        <tr>
          <th>Kullanıcı</th>
          <th>E-posta</th>
          <th>Rol</th>
          <th>eSIM</th>
          <th>Durum</th>
          <th>İşlemler</th>
        </tr>
      </thead>
      <tbody>
        <% const defaultUsers = [
          { username: 'admin', email: 'admin@datapatch.io', role: 'admin', esimCount: 5, status: 'active' },
          { username: 'ahmet.yilmaz', email: 'ahmet@example.com', role: 'user', esimCount: 3, status: 'active' },
          { username: 'elif.demir', email: 'elif@example.com', role: 'user', esimCount: 2, status: 'active' },
          { username: 'mehmet.kaya', email: 'mehmet@example.com', role: 'user', esimCount: 1, status: 'suspended' },
          { username: 'zeynep.arslan', email: 'zeynep@example.com', role: 'user', esimCount: 4, status: 'active' },
          { username: 'can.ozturk', email: 'can@example.com', role: 'user', esimCount: 0, status: 'active' }
        ]; %>
        <% const userList = locals.users || defaultUsers; %>
        <% userList.forEach(function(u) { %>
          <tr>
            <td><%= u.username %></td>
            <td><%= u.email %></td>
            <td>
              <% if (u.role === 'admin') { %>
                <span class="demo-badge demo-badge-gradient">Admin</span>
              <% } else { %>
                <span class="demo-badge demo-badge-dark">User</span>
              <% } %>
            </td>
            <td><%= u.esimCount %></td>
            <td>
              <% if (u.status === 'active') { %>
                <span class="demo-badge demo-badge-success">Aktif</span>
              <% } else { %>
                <span class="demo-badge demo-badge-danger">Askıya Alındı</span>
              <% } %>
            </td>
            <td>
              <a href="/demo/admin/users/<%= u.username %>" class="demo-table-link">Düzenle</a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
