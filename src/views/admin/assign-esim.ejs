<%- include('../partials/header', {title: 'Assign Data', user: locals.user}) %>

<div class="mb-6">
  <div class="breadcrumb">
    <a href="/admin/dashboard"><i data-lucide="chevron-left" class="w-4 h-4"></i> Back to Dashboard</a>
  </div>
  <h1 class="text-page-title">Assign Data</h1>
  <p class="text-subtitle mt-1">Purchase and assign a Data plan to a user</p>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-error mb-6"><i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i><%= error %></div>
<% } %>
<% if (typeof success !== 'undefined' && success) { %>
<div class="alert alert-success mb-6"><i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i><%= success %></div>
<% } %>

<div class="max-w-2xl">
  <div class="card">
    <div class="card-header">
      <h2>Assignment Details</h2>
    </div>
    <form method="post" action="/admin/assign-esim" class="card-body space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div>
        <label for="assign-user" class="input-label">Select User</label>
        <select id="assign-user" name="userId" required class="input">
          <option value="">Choose a user...</option>
          <% if (typeof users !== 'undefined') { users.forEach(function(u) { %>
          <option value="<%= u.id %>"><%= u.username %> (<%= u.Esims ? u.Esims.length : 0 %> Datas)</option>
          <% }) } %>
        </select>
      </div>
      <div>
        <label for="assign-offer" class="input-label">Select Data Plan</label>
        <select id="assign-offer" name="offerId" required class="input">
          <option value="">Choose a plan...</option>
          <% if (typeof offers !== 'undefined') { offers.forEach(function(offer) { %>
          <option value="<%= offer.offerId %>"><%= offer.brand %> - <%= offer.dataGB %> GB / <%= offer.durationDays %> days (<%= offer.price ? (offer.price.fixed / (offer.price.currencyDivisor || 100)).toFixed(2) + ' ' + (offer.price.currency || 'USD') : 'N/A' %>)</option>
          <% }) } %>
        </select>
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg">
        <i data-lucide="send" class="w-4 h-4"></i>
        Assign Data
      </button>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
