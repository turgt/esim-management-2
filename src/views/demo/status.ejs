<div class="demo-content">

  <!-- Status Banner -->
  <div class="demo-status-banner demo-status-banner-done demo-animate-in">
    <div class="demo-status-icon demo-status-icon-done">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
    </div>
    <div>
      <div class="demo-status-title" style="color: var(--color-success);">Aktif</div>
      <div class="demo-status-message">eSIM başarıyla yüklendi ve kullanıma hazır</div>
    </div>
  </div>

  <!-- Detail Grid -->
  <div class="demo-detail-grid">
    <div class="demo-detail-item demo-animate-in">
      <div class="demo-detail-label">Ülke</div>
      <div class="demo-detail-value">🇹🇷 <%= purchase.country %></div>
    </div>
    <div class="demo-detail-item demo-animate-in">
      <div class="demo-detail-label">Data</div>
      <div class="demo-detail-value"><%= purchase.data %></div>
    </div>
    <div class="demo-detail-item demo-animate-in">
      <div class="demo-detail-label">Süre</div>
      <div class="demo-detail-value"><%= purchase.duration %></div>
    </div>
    <div class="demo-detail-item demo-animate-in">
      <div class="demo-detail-label">Ağ Tipi</div>
      <div class="demo-detail-value"><%= purchase.network %></div>
    </div>
    <div class="demo-detail-item demo-animate-in">
      <div class="demo-detail-label">ICCID</div>
      <div class="demo-detail-value demo-detail-value-mono"><%= purchase.iccid %></div>
    </div>
    <div class="demo-detail-item demo-animate-in">
      <div class="demo-detail-label">Satın Alma</div>
      <div class="demo-detail-value"><%= purchase.date %></div>
    </div>
  </div>

  <!-- Progress Card -->
  <div class="demo-progress-card demo-animate-in">
    <div class="demo-progress-header">
      <div class="demo-progress-title">Data Kullanımı</div>
      <div class="demo-progress-value">3.2 GB / 10 GB</div>
    </div>
    <div class="demo-progress-bar">
      <div class="demo-progress-fill" style="width: 32%;"></div>
    </div>
    <div class="demo-progress-label">Son kullanma: 25 Nisan 2026</div>
  </div>

  <!-- Actions -->
  <div class="demo-action-row demo-animate-in">
    <a href="/demo/qrcode" class="demo-btn demo-btn-primary">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="5" height="5" x="3" y="3" rx="1"/><rect width="5" height="5" x="16" y="3" rx="1"/><rect width="5" height="5" x="3" y="16" rx="1"/><path d="M21 16h-3a2 2 0 0 0-2 2v3"/><path d="M21 21v.01"/><path d="M12 7v3a2 2 0 0 1-2 2H7"/><path d="M3 12h.01"/><path d="M12 3h.01"/><path d="M12 16v.01"/><path d="M16 12h1"/><path d="M21 12v.01"/><path d="M12 21v-1"/></svg>
      QR Kodu Göster
    </a>
    <a href="#" class="demo-btn demo-btn-outline">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      Top-up
    </a>
  </div>

  <!-- Timeline -->
  <div class="demo-timeline demo-animate-in">
    <div class="demo-timeline-title">Aktivite</div>

    <div class="demo-timeline-item">
      <div class="demo-timeline-dot demo-timeline-dot-success">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <div class="demo-timeline-content">
        <div class="demo-timeline-text">eSIM aktif edildi</div>
        <div class="demo-timeline-time">9 Nisan 2026, 10:32</div>
      </div>
    </div>

    <div class="demo-timeline-item">
      <div class="demo-timeline-dot demo-timeline-dot-success">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <div class="demo-timeline-content">
        <div class="demo-timeline-text">eSIM cihaza yüklendi</div>
        <div class="demo-timeline-time">9 Nisan 2026, 10:28</div>
      </div>
    </div>

    <div class="demo-timeline-item">
      <div class="demo-timeline-dot demo-timeline-dot-success">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <div class="demo-timeline-content">
        <div class="demo-timeline-text">Ödeme tamamlandı — $4.99</div>
        <div class="demo-timeline-time">9 Nisan 2026, 10:25</div>
      </div>
    </div>

    <div class="demo-timeline-item">
      <div class="demo-timeline-dot demo-timeline-dot-warning">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
      </div>
      <div class="demo-timeline-content">
        <div class="demo-timeline-text">Sipariş oluşturuldu</div>
        <div class="demo-timeline-time">9 Nisan 2026, 10:24</div>
      </div>
    </div>
  </div>

</div>
