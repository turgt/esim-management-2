<div class="demo-content">
  <h1 class="demo-page-title demo-animate-in">Profil</h1>

  <!-- Avatar Section -->
  <div class="demo-avatar-section demo-animate-in">
    <div class="demo-avatar-lg">T</div>
    <div>
      <div class="demo-avatar-name">Turgut</div>
      <div class="demo-avatar-email">demo@datapatch.co</div>
    </div>
  </div>

  <!-- Hesap Bilgileri -->
  <div class="demo-section-card demo-animate-in">
    <div class="demo-section-card-title">Hesap Bilgileri</div>
    <form>
      <div class="demo-input-group">
        <label class="demo-input-label">Görünen Ad</label>
        <input type="text" class="demo-input" value="Turgut">
      </div>
      <div class="demo-input-group">
        <label class="demo-input-label">E-posta</label>
        <input type="email" class="demo-input" value="demo@datapatch.co">
      </div>
      <div class="demo-input-group">
        <label class="demo-input-label">Telefon</label>
        <input type="tel" class="demo-input" placeholder="+90 5XX XXX XX XX">
      </div>
      <button type="button" class="demo-btn demo-btn-primary">Kaydet</button>
    </form>
  </div>

  <!-- Şifre Değiştir -->
  <div class="demo-section-card demo-animate-in">
    <div class="demo-section-card-title">Şifre Değiştir</div>
    <form>
      <div class="demo-input-group">
        <label class="demo-input-label">Mevcut Şifre</label>
        <input type="password" class="demo-input" placeholder="••••••••">
      </div>
      <div class="demo-input-group">
        <label class="demo-input-label">Yeni Şifre</label>
        <input type="password" class="demo-input" placeholder="••••••••">
      </div>
      <div class="demo-input-group">
        <label class="demo-input-label">Şifre Tekrar</label>
        <input type="password" class="demo-input" placeholder="••••••••">
      </div>
      <button type="button" class="demo-btn demo-btn-primary">Şifreyi Güncelle</button>
    </form>
  </div>

  <!-- Tercihler -->
  <div class="demo-section-card demo-animate-in">
    <div class="demo-section-card-title">Tercihler</div>
    <div style="display:flex;align-items:center;justify-content:space-between;">
      <div>
        <div style="font-size:14px;font-weight:600;color:var(--color-text);">Tema</div>
        <div style="font-size:12px;color:var(--color-text-muted);">Arayüz görünümünü ayarla</div>
      </div>
      <div class="demo-theme-toggle">
        <span class="demo-theme-option active">Acik</span>
        <span class="demo-theme-option">Koyu</span>
      </div>
    </div>
  </div>
</div>
