<%- include('partials/header', {title: 'Verify Email', user: locals.user}) %>

<% if (typeof user !== 'undefined' && user) { %>
<%/* Authenticated layout - content goes in sidebar layout */%>
<div class="max-w-sm mx-auto text-center py-8">
<% } %>

    <div class="card p-6 text-center">
      <% if (success) { %>
      <div class="w-12 h-12 bg-emerald-50 dark:bg-emerald-500/10 rounded-full flex items-center justify-center mx-auto mb-3">
        <i data-lucide="check-circle" class="w-6 h-6 text-emerald-500"></i>
      </div>
      <h1 class="text-xl font-semibold text-[var(--text-primary)] mb-2">Email Verified!</h1>
      <p class="text-sm text-[var(--text-secondary)] mb-6"><%= message %></p>
      <a href="/offers" class="btn btn-primary">Browse eSIM Plans</a>
      <% } else { %>
      <div class="w-12 h-12 bg-red-50 dark:bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-3">
        <i data-lucide="x-circle" class="w-6 h-6 text-red-500"></i>
      </div>
      <h1 class="text-xl font-semibold text-[var(--text-primary)] mb-2">Verification Failed</h1>
      <p class="text-sm text-[var(--text-secondary)] mb-6"><%= message %></p>
      <a href="/auth/login" class="btn btn-secondary">Go to Login</a>
      <% } %>
    </div>

<% if (typeof user !== 'undefined' && user) { %>
</div>
<% } %>

<%- include('partials/footer') %>
