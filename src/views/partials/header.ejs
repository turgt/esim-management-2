            <i data-lucide="globe" class="w-[1.125rem] h-[1.125rem]"></i> Plans
          </a>
          <a href="/purchases" class="sidebar-link <%= typeof title !== 'undefined' && (title === 'My Datas' || title === 'My Purchases' || title === 'Purchase Status' || title === 'QR Code' || title === 'Payment' || title === 'Payment Result' || title === 'Top-up Data') ? 'active' : '' %>">
            <i data-lucide="smartphone" class="w-[1.125rem] h-[1.125rem]"></i> My Datas
          </a>
