<div class="v2-content" style="padding-bottom:40px;">
  <h1 class="v2-page-title v2-anim">Fatura Detayi</h1>

  <!-- Receipt Card -->
  <div class="v2-receipt v2-anim">

    <!-- Header -->
    <div class="v2-receipt-header">
      <div class="v2-receipt-logo" style="color: var(--accent);">DataPatch</div>
      <div class="v2-receipt-number">Fatura No: <strong style="color:var(--color-text);">#DP-2026-0042</strong></div>
    </div>

    <div class="v2-receipt-hr"></div>

    <!-- Detail Grid -->
    <div class="v2-details" style="margin-bottom:16px;">
      <div class="v2-detail">
        <div class="v2-detail-label">Tarih</div>
        <div class="v2-detail-value">9 Nisan 2026</div>
      </div>
      <div class="v2-detail">
        <div class="v2-detail-label">Durum</div>
        <span class="v2-badge v2-badge-success">Tamamlandi</span>
      </div>
      <div class="v2-detail" style="grid-column:1/-1;">
        <div class="v2-detail-label">Odeme Yontemi</div>
        <div class="v2-detail-value">Visa &bull;&bull;&bull;&bull; 4242</div>
      </div>
    </div>

    <div class="v2-receipt-hr"></div>

    <!-- Line Items -->
    <div style="margin-bottom:16px;">
      <div class="v2-receipt-line" style="align-items:center;padding:10px 0;">
        <div>
          <div style="font-size:14px;font-weight:600;color:var(--color-text);">Turkiye 10GB eSIM</div>
          <div style="font-size:12px;color:var(--color-text-muted);">30 gun &bull; 5G</div>
        </div>
        <div class="v2-receipt-line-value">$4.16</div>
      </div>
    </div>

    <div class="v2-receipt-hr"></div>

    <!-- Totals -->
    <div style="display:flex;flex-direction:column;gap:8px;">
      <div class="v2-receipt-line">
        <span class="v2-receipt-line-label">Ara Toplam</span>
        <span class="v2-receipt-line-value">$4.16</span>
      </div>
      <div class="v2-receipt-line">
        <span class="v2-receipt-line-label">KDV (%20)</span>
        <span class="v2-receipt-line-value">$0.83</span>
      </div>
      <div class="v2-receipt-hr"></div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span style="font-family:var(--font-heading);font-size:16px;font-weight:700;">Toplam</span>
        <span class="v2-receipt-total" style="color: var(--accent);">$4.99</span>
      </div>
    </div>
  </div>

  <!-- Download Button -->
  <div class="v2-anim" style="margin-top:20px;">
    <button class="v2-btn v2-btn-secondary v2-btn-block">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Indir
    </button>
  </div>
</div>
