<div class="demo-page-header-row">
  <div class="demo-page-title" style="margin-bottom: 0;">Vendorlar</div>
  <a href="/demo/admin/vendors/new" class="demo-btn demo-btn-primary demo-btn-sm">Yeni Vendor Ekle</a>
</div>

<!-- Vendors Table -->
<div class="demo-table-card demo-animate-in">
  <div class="demo-table-responsive">
    <table class="demo-table">
      <thead>
        <tr>
          <th>Vendor</th>
          <th>API Durumu</th>
          <th>eSIM Sayısı</th>
          <th>Komisyon</th>
          <th>İşlemler</th>
        </tr>
      </thead>
      <tbody>
        <% const defaultVendors = [
          { id: 1, name: 'Zendit', apiStatus: 'connected', esimCount: 245, commission: '%12' },
          { id: 2, name: 'Airalo', apiStatus: 'connected', esimCount: 89, commission: '%15' },
          { id: 3, name: 'eSIMGo', apiStatus: 'disconnected', esimCount: 8, commission: '%10' },
          { id: 4, name: 'RedteaGo', apiStatus: 'connected', esimCount: 56, commission: '%18' }
        ]; %>
        <% const vendorList = locals.vendors || defaultVendors; %>
        <% vendorList.forEach(function(v) { %>
          <tr>
            <td><%= v.name %></td>
            <td>
              <% if (v.apiStatus === 'connected') { %>
                <span class="demo-badge demo-badge-success">Bağlı</span>
              <% } else { %>
                <span class="demo-badge demo-badge-danger">Bağlı Değil</span>
              <% } %>
            </td>
            <td><%= v.esimCount %></td>
            <td><%= v.commission %></td>
            <td>
              <a href="/demo/admin/vendors/<%= v.id %>" class="demo-table-link">Detay</a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
