<%- include('partials/header', {title: 'Top-up Data', user: locals.user}) %>

<div class="mb-6">
  <div class="breadcrumb">
    <a href="/purchases"><i data-lucide="chevron-left" class="w-4 h-4"></i> Back to My Datas</a>
  </div>
  <h1 class="text-page-title">Top-up Data</h1>
  <p class="text-subtitle mt-1">Add more data to your existing Data</p>
</div>

<div class="max-w-4xl mx-auto space-y-6">
  <!-- eSIM Info Card -->
  <div class="card">
    <div class="card-header">
      <h2>Data Information</h2>
      <% if (esim.status === 'completed') { %>
      <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Active</span>
      <% } else if (esim.status === 'pending') { %>
      <span class="badge badge-warning"><span class="badge-dot bg-amber-500 animate-pulse-dot"></span>Pending</span>
      <% } else if (esim.status === 'failed') { %>
      <span class="badge badge-danger"><span class="badge-dot bg-rose-500"></span>Failed</span>
      <% } else { %>
      <span class="badge badge-neutral"><%= esim.status %></span>
      <% } %>
    </div>
    <div class="card-body">
      <div class="detail-grid grid-cols-2">
        <div class="detail-item col-span-2">
          <div class="detail-label">ICCID</div>
          <div class="flex items-center gap-1.5">
            <span class="detail-value font-mono text-xs"><%= esim.iccid %></span>
            <button onclick="copyToClipboard('<%= esim.iccid %>', this)" class="copy-btn" title="Copy ICCID">
              <i data-lucide="copy" class="w-3 h-3"></i>
            </button>
          </div>
        </div>
        <% if (esim.country) { %>
        <div class="detail-item">
          <div class="detail-label">Country</div>
          <div class="detail-value"><%= esim.country %></div>
        </div>
        <% } %>
        <% if (esim.dataGB) { %>
        <div class="detail-item">
          <div class="detail-label">Original Data</div>
          <div class="detail-value font-semibold"><%= esim.dataGB %> GB</div>
        </div>
        <% } %>
      </div>

      <!-- Active Plans -->
      <% if (typeof activePlans !== 'undefined' && activePlans && activePlans.list && activePlans.list.length > 0) { %>
      <div class="mt-4 pt-4 border-t border-[var(--border-subtle)]">
        <p class="text-xs font-semibold text-[var(--text-tertiary)] uppercase tracking-wide mb-2">Current Active Plans</p>
        <div class="space-y-2">
          <% activePlans.list.forEach(function(plan) { %>
          <div class="flex items-center justify-between text-xs p-2.5 rounded-lg bg-[var(--surface-1)] border border-[var(--border-subtle)]">
            <div class="flex-1 min-w-0">
              <% if (plan.unlimited) { %>
              <span class="font-semibold text-[var(--text-primary)]">Unlimited</span>
              <% } else { %>
              <span class="font-semibold text-[var(--text-primary)]"><%= plan.remainingDataGB != null ? plan.remainingDataGB.toFixed(2) : '-' %></span>
              <span class="text-[var(--text-tertiary)]"> / <%= plan.initialDataGB || '-' %> GB remaining</span>
              <% } %>
              <% if (plan.endAt) { %>
              <span class="text-[var(--text-tertiary)] ml-2">expires <%= new Date(plan.endAt).toLocaleDateString('en-GB') %></span>
              <% } %>
            </div>
            <% if (plan.status === 'ACTIVE') { %>
            <span class="badge badge-success text-[10px]"><span class="badge-dot bg-emerald-500"></span>Active</span>
            <% } else if (plan.status === 'QUEUED') { %>
            <span class="badge badge-warning text-[10px]"><span class="badge-dot bg-amber-500"></span>Queued</span>
            <% } else { %>
            <span class="badge text-[10px]"><%= plan.status %></span>
            <% } %>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Available Plans -->
  <div>
    <h2 class="text-lg font-semibold text-[var(--text-primary)] mb-1">Available Top-up Plans</h2>
    <p class="text-sm text-[var(--text-secondary)] mb-4">Select a plan to add more data to this Data</p>

    <% if (typeof offers !== 'undefined' && offers && offers.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% offers.forEach(function(offer, idx) { %>
      <%
        // Support both Airalo and Zendit offer formats
        var isAiraloOffer = !!(offer.id && !offer.offerId);
        var offerId = isAiraloOffer ? offer.id : offer.offerId;
        var price = isAiraloOffer
          ? (offer.price ? parseFloat(offer.price).toFixed(2) : null)
          : (offer.price && offer.price.fixed ? (offer.price.fixed / (offer.price.currencyDivisor || 100)).toFixed(2) : null);
        var currency = isAiraloOffer
          ? (offer.currency || 'USD')
          : (offer.price ? (offer.price.currency || 'USD') : 'USD');
        var dataLabel = isAiraloOffer ? (offer.data || null) : (offer.dataGB || null);
        var dataUnit = dataLabel ? 'GB' : 'Unlimited';
        var durationLabel = isAiraloOffer
          ? (offer.day ? offer.day + ' days' : '')
          : (offer.durationDays ? offer.durationDays + ' days' : '');
        var brandLabel = isAiraloOffer ? (offer.title || 'Data') : (offer.brand || 'Data');
        var regionShort = '';
        if (offer.regions && offer.regions.length > 0) {
          regionShort = offer.regions[0];
          if (regionShort.length > 20) regionShort = offer.country || regionShort.substring(0, 18) + '...';
        } else if (offer.country) {
          regionShort = offer.country;
        }
      %>
      <button type="button" class="offer-card" onclick="confirmTopup('<%= offerId %>', '<%= brandLabel.replace(/'/g, "\\'") %>', '<%= price || '0.00' %>', '<%= currency %>')" data-price="<%= price || '0.00' %>" data-currency="<%= currency %>">
        <div class="offer-header">
          <span class="offer-region"><%= regionShort || 'Global' %></span>
          <% if (durationLabel) { %>
          <span class="offer-duration"><%= durationLabel %></span>
          <% } %>
        </div>
        <div class="offer-body">
          <% if (dataLabel) { %>
          <span class="offer-data"><%= dataLabel %></span>
          <span class="offer-data-unit ml-1">GB</span>
          <% } else { %>
          <span class="offer-data">Unlimited</span>
          <% } %>
        </div>
        <div class="offer-footer">
          <div>
            <% if (price) { %>
            <span class="offer-price">$<%= price %></span>
            <span class="offer-price-currency ml-0.5"><%= currency %></span>
            <% } %>
          </div>
          <span class="offer-cta">
            Top-up <i data-lucide="arrow-right" class="w-3.5 h-3.5"></i>
          </span>
        </div>
      </button>
      <% }) %>
    </div>
    <% } else { %>
    <div class="empty-state">
      <div class="empty-icon">
        <i data-lucide="package" class="w-6 h-6"></i>
      </div>
      <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-1">No top-up plans available</h3>
      <p class="text-sm text-[var(--text-secondary)]">There are no compatible top-up plans for this Data at the moment.</p>
    </div>
    <% } %>
  </div>
</div>

<!-- Top-up Confirmation Modal -->
<div id="topupModal" class="modal-backdrop hidden" style="display:none">
  <div class="confirm-modal">
    <div class="flex items-center gap-3 mb-5">
      <div class="w-10 h-10 rounded-xl bg-[var(--brand-light)] flex items-center justify-center">
        <i data-lucide="refresh-cw" class="w-5 h-5 text-[var(--brand-primary)]"></i>
      </div>
      <div>
        <h3 class="text-base font-semibold text-[var(--text-primary)]">Confirm Top-up</h3>
        <p class="text-xs text-[var(--text-secondary)]">Add data to your Data</p>
      </div>
    </div>
    <div class="p-4 rounded-lg bg-[var(--surface-1)] border border-[var(--border-subtle)] mb-5">
      <p class="text-sm text-[var(--text-secondary)]">Plan: <strong class="text-[var(--text-primary)]" id="modalPlanName"></strong></p>
      <p class="text-lg font-bold text-[var(--brand-primary)] mt-1" id="modalPlanPrice"></p>
      <p class="text-xs text-[var(--text-tertiary)] mt-2 font-mono">ICCID: <%= esim.iccid %></p>
    </div>
    <form id="topupForm" method="post" action="/payment/topup/create" hx-boost="false">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% if (esim.vendor === 'airalo') { %>
      <input type="hidden" name="packageId" id="modalOfferId" value="">
      <% } else { %>
      <input type="hidden" name="offerId" id="modalOfferId" value="">
      <% } %>
      <input type="hidden" name="amount" id="modalAmount" value="">
      <input type="hidden" name="currency" id="modalCurrency" value="">
      <input type="hidden" name="esimId" value="<%= esim.id %>">
      <input type="hidden" name="iccid" value="<%= esim.iccid %>">
      <input type="hidden" name="planName" id="modalPlanNameHidden" value="">
      <div class="flex gap-3">
        <button type="button" class="btn btn-secondary flex-1" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary flex-1">
          <i data-lucide="check" class="w-4 h-4"></i>
          Confirm Top-up
        </button>
      </div>
    </form>
  </div>
</div>

<script>
function confirmTopup(offerId, planName, price, currency) {
  document.getElementById('modalOfferId').value = offerId;
  document.getElementById('modalAmount').value = price;
  document.getElementById('modalCurrency').value = currency;
  document.getElementById('modalPlanNameHidden').value = planName;
  document.getElementById('modalPlanName').textContent = planName;
  document.getElementById('modalPlanPrice').textContent = price + ' ' + currency;
  var modal = document.getElementById('topupModal');
  modal.classList.remove('hidden');
  modal.style.display = 'flex';
}
function closeModal() {
  var modal = document.getElementById('topupModal');
  modal.classList.add('hidden');
  modal.style.display = 'none';
}
document.getElementById('topupModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
</script>

<%- include('partials/footer') %>
