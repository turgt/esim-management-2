<%
  const isEdit = locals.isEdit || false;
  const v = locals.vendor || {};
%>

<div class="v2-page-header">
  <div class="v2-page-title"><%= isEdit ? 'Vendor Duzenle' : 'Vendor Ekle' %></div>
</div>

<div class="v2-form-card v2-anim" style="max-width: 600px;">
  <form>
    <div class="v2-input-group">
      <label class="v2-input-label">Vendor Adi</label>
      <input type="text" class="v2-input" placeholder="Vendor adini girin" value="<%= v.name || '' %>">
    </div>

    <div class="v2-input-group">
      <label class="v2-input-label">API URL</label>
      <input type="text" class="v2-input" placeholder="https://api.example.com/v1" value="<%= v.apiUrl || '' %>">
    </div>

    <div class="v2-input-group">
      <label class="v2-input-label">API Key</label>
      <input type="password" class="v2-input" placeholder="API anahtarini girin">
    </div>

    <div class="v2-input-group">
      <label class="v2-input-label">Komisyon Orani (%)</label>
      <input type="number" class="v2-input" placeholder="12" value="<%= v.commission || '' %>">
    </div>

    <div class="v2-input-group">
      <label class="v2-input-label">Durum</label>
      <select class="v2-input">
        <option value="active" <%= v.status === 'active' || !v.status ? 'selected' : '' %>>Aktif</option>
        <option value="passive" <%= v.status === 'passive' ? 'selected' : '' %>>Pasif</option>
      </select>
    </div>

    <button type="button" class="v2-btn v2-btn-primary v2-btn-block" style="margin-top: 8px;">Kaydet</button>
  </form>
</div>
