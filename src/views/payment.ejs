<%- include('partials/header', {title: 'Payment', user: locals.user}) %>

<div class="mb-6">
  <a href="/offers" class="inline-flex items-center gap-1.5 text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">
    <i data-lucide="arrow-left" class="w-4 h-4"></i> Back to Plans
  </a>
</div>

<div class="max-w-2xl mx-auto">
  <!-- Order Summary -->
  <div class="card mb-4 sm:mb-6">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl bg-[var(--brand-light)] flex items-center justify-center flex-shrink-0">
        <i data-lucide="credit-card" class="w-4 h-4 sm:w-5 sm:h-5 text-[var(--brand-primary)]"></i>
      </div>
      <div class="min-w-0">
        <h2 class="text-base sm:text-lg font-semibold text-[var(--text-primary)]">Order Summary</h2>
        <p class="text-xs text-[var(--text-secondary)]">Complete your payment to activate your Data</p>
      </div>
    </div>

    <div class="p-3 sm:p-4 rounded-lg bg-[var(--surface-1)] border border-[var(--border-subtle)]">
      <div class="flex justify-between items-center mb-2 gap-2">
        <span class="text-sm text-[var(--text-secondary)] flex-shrink-0">Plan</span>
        <span class="text-sm font-medium text-[var(--text-primary)] truncate text-right"><%= offerId %></span>
      </div>
      <div class="flex justify-between items-center mb-2 gap-2">
        <span class="text-sm text-[var(--text-secondary)] flex-shrink-0">Order ID</span>
        <span class="text-[0.6875rem] font-mono text-[var(--text-tertiary)] truncate text-right"><%= payment.merchantOid %></span>
      </div>
      <div class="border-t border-[var(--border-subtle)] mt-3 pt-3">
        <div class="flex justify-between items-center">
          <span class="text-base font-semibold text-[var(--text-primary)]">Total</span>
          <span class="text-lg font-bold text-[var(--brand-primary)]">$<%= parseFloat(amount).toFixed(2) %> <%= currency %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Payment overlay trigger area -->
  <div class="card text-center py-8 sm:py-10" id="paymentStatus">
    <div id="statusLoading">
      <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-full bg-[var(--surface-2)] flex items-center justify-center mx-auto mb-4">
        <i data-lucide="loader-2" class="w-7 h-7 sm:w-8 sm:h-8 text-[var(--brand-primary)] animate-spin"></i>
      </div>
      <h3 class="text-base font-semibold text-[var(--text-primary)] mb-1">Opening Secure Payment</h3>
      <p class="text-sm text-[var(--text-secondary)]">Please wait...</p>
    </div>

    <div id="statusReady" style="display:none;">
      <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-full bg-[var(--brand-light)] flex items-center justify-center mx-auto mb-4">
        <i data-lucide="lock" class="w-7 h-7 sm:w-8 sm:h-8 text-[var(--brand-primary)]"></i>
      </div>
      <h3 class="text-base font-semibold text-[var(--text-primary)] mb-1">Secure Payment Ready</h3>
      <p class="text-sm text-[var(--text-secondary)] mb-5">Your payment form was closed. Click below to reopen.</p>
      <button id="reopenBtn" onclick="openCheckout()" class="btn btn-primary inline-flex items-center gap-2">
        <i data-lucide="credit-card" class="w-4 h-4"></i> Open Payment Form
      </button>
    </div>

    <div id="statusError" style="display:none;">
      <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-full bg-red-100 dark:bg-red-500/20 flex items-center justify-center mx-auto mb-4">
        <i data-lucide="alert-circle" class="w-7 h-7 sm:w-8 sm:h-8 text-red-500"></i>
      </div>
      <h3 class="text-base font-semibold text-[var(--text-primary)] mb-1">Payment Unavailable</h3>
      <p class="text-sm text-[var(--text-secondary)] mb-5" id="errorMsg">Could not load payment form. Please try again.</p>
      <a href="/offers" class="btn btn-secondary inline-flex items-center gap-2">
        <i data-lucide="arrow-left" class="w-4 h-4"></i> Back to Plans
      </a>
    </div>
  </div>

  <p class="text-center text-xs text-[var(--text-tertiary)] mt-3">
    <i data-lucide="shield-check" class="w-3.5 h-3.5 inline-block -mt-0.5 mr-0.5"></i>
    Payments securely processed by Paddle
  </p>
</div>

<script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
<script>
(function () {
  var merchantOid = '<%= payment.merchantOid %>';
  var transactionId = '<%= paddleTransactionId %>';
  var clientToken = '<%= paddleClientToken %>';
  var environment = '<%= paddleEnvironment %>';
  var userEmail = '<%= locals.user && locals.user.email ? locals.user.email : "" %>';

  function showStatus(id) {
    ['statusLoading', 'statusReady', 'statusError'].forEach(function (s) {
      document.getElementById(s).style.display = 'none';
    });
    document.getElementById(id).style.display = 'block';
    lucide.createIcons();
  }

  function openCheckout() {
    var checkoutSettings = { transactionId: transactionId };
    if (userEmail) {
      checkoutSettings.customer = { email: userEmail };
      checkoutSettings.settings = { showAddDiscountCode: true };
    }
    Paddle.Checkout.open(checkoutSettings);
  }

  window.openCheckout = openCheckout;

  if (!clientToken) {
    console.error('Paddle: PADDLE_CLIENT_TOKEN is not configured');
    document.getElementById('errorMsg').textContent = 'Payment not configured (missing client token).';
    showStatus('statusError');
    return;
  }

  try {
    // Must be called BEFORE Paddle.Initialize() for sandbox
    if (environment === 'sandbox') {
      Paddle.Environment.set('sandbox');
    }

    Paddle.Initialize({
      token: clientToken,
      eventCallback: function (data) {
        console.log('Paddle event:', data.name, data);
        if (data.name === 'checkout.completed') {
          window.location.href = '/payment/result/' + merchantOid;
        } else if (data.name === 'checkout.closed') {
          showStatus('statusReady');
        } else if (data.name === 'checkout.loaded') {
          showStatus('statusReady');
        } else if (data.name === 'checkout.error') {
          var msg = (data.data && data.data.message) || 'Could not load payment form. Please try again.';
          console.error('Paddle checkout.error:', data);
          document.getElementById('errorMsg').textContent = msg;
          showStatus('statusError');
        }
      }
    });
    openCheckout();
  } catch (e) {
    console.error('Paddle initialize error:', e);
    document.getElementById('errorMsg').textContent = e.message || 'Failed to initialize payment. Please try again.';
    showStatus('statusError');
  }
})();
</script>

<%- include('partials/footer') %>
