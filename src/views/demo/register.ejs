<div class="demo-login-wrapper">
  <div class="demo-login-card demo-animate-in">
    <div class="demo-login-logo demo-gradient-text">DataPatch</div>
    <p class="demo-login-subtitle">Yeni hesap oluştur</p>

    <form action="/demo/offers" method="get">
      <div class="demo-input-group">
        <label class="demo-input-label">Kullanıcı Adı</label>
        <input type="text" class="demo-input" placeholder="kullaniciadi">
      </div>

      <div class="demo-input-group">
        <label class="demo-input-label">E-posta</label>
        <input type="email" class="demo-input" placeholder="ornek@email.com">
      </div>

      <div class="demo-input-group">
        <label class="demo-input-label">Görünen Ad <span style="font-weight:400;color:var(--color-text-muted);">(isteğe bağlı)</span></label>
        <input type="text" class="demo-input" placeholder="Ad Soyad">
      </div>

      <div class="demo-input-group">
        <label class="demo-input-label">Şifre</label>
        <input type="password" class="demo-input" placeholder="••••••••">
      </div>

      <div class="demo-input-group">
        <label class="demo-input-label">Şifre Tekrar</label>
        <input type="password" class="demo-input" placeholder="••••••••">
      </div>

      <button type="submit" class="demo-btn demo-btn-primary demo-btn-block">Kayıt Ol</button>
    </form>

    <div class="demo-login-footer">
      Zaten hesabın var mı? <a href="/demo/login">Giriş Yap</a>
    </div>
  </div>
</div>
