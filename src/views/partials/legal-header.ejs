<!DOCTYPE html>
<html lang="tr" class="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - DataPatch</title>
  <link rel="icon" type="image/svg+xml" href="/public/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/styles.css">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script>
    (function() {
      var saved = localStorage.getItem('theme');
      if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body class="bg-[var(--surface-1)] text-[var(--text-primary)] font-sans antialiased">
  <div class="min-h-screen flex flex-col">
    <!-- Simple header -->
    <header class="border-b border-[var(--border-default)] bg-[var(--surface-2)]">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 no-underline">
          <div class="sidebar-brand-icon !w-8 !h-8 !rounded-lg" style="box-shadow:none;">
            <i data-lucide="signal" class="w-4 h-4"></i>
          </div>
          <span class="text-lg font-bold text-[var(--text-primary)] tracking-tight">DataPatch</span>
        </a>
        <a href="/auth/login" class="btn btn-secondary text-sm">
          <i data-lucide="log-in" class="w-4 h-4"></i> Giris Yap
        </a>
      </div>
    </header>

    <!-- Legal content container -->
    <main class="flex-1 w-full max-w-3xl mx-auto px-4 sm:px-6 py-8">
