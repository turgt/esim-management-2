<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script>
var SIZE_META = {
  a6: { label: 'A6 • 105 × 148 mm', scale: 4 },
  a5: { label: 'A5 • 148 × 210 mm', scale: 3 },
  a4: { label: 'A4 • 210 × 297 mm', scale: 2 }
};

function setSize(size) {
  if (!SIZE_META[size]) return;
  document.getElementById('cardFrame').setAttribute('data-size', size);
  document.getElementById('pageSizeLabel').textContent = SIZE_META[size].label;
  var buttons = document.querySelectorAll('.btn-size');
  for (var i = 0; i < buttons.length; i++) {
    buttons[i].classList.toggle('active', buttons[i].getAttribute('data-size') === size);
  }
}

async function downloadBrochure() {
  var btn = document.getElementById('downloadBtn');
  var originalText = btn.textContent;
  btn.disabled = true;
  btn.textContent = 'Generating...';
  try {
    var frame = document.getElementById('cardFrame');
    var size = frame.getAttribute('data-size') || 'a6';
    var canvas = await html2canvas(frame, {
      scale: SIZE_META[size].scale,
      useCORS: true,
      backgroundColor: '#ffffff',
      logging: false,
      width: frame.offsetWidth,
      height: frame.offsetHeight
    });
    var link = document.createElement('a');
    link.download = 'datapatch-brochure-' + size + '.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
  } catch (e) {
    alert('Failed to generate image. Please try again.');
  }
  btn.disabled = false;
  btn.textContent = originalText;
}
</script>

