<%- include('../partials/header', {title: 'Admin Dashboard', user: locals.user}) %>

<div class="mb-8 flex items-center justify-between">
  <div>
    <p class="text-sm text-[var(--text-secondary)] mb-1">Welcome back, <span class="font-semibold text-[var(--text-primary)]"><%= user.displayName || user.username %></span></p>
    <h1 class="text-page-title">Dashboard</h1>
  </div>
  <a href="/admin/assign-esim" class="hidden sm:inline-flex btn btn-primary">
    <i data-lucide="plus" class="w-4 h-4"></i>
    Assign Data
  </a>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
  <div class="stat-card">
    <div class="stat-icon bg-[var(--brand-light)]">
      <i data-lucide="wallet" class="w-5 h-5 text-[var(--brand-primary)]"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Zendit Balance</p>
      <p class="stat-value text-[var(--brand-primary)]"><%= typeof balance !== 'undefined' && balance ? '$' + Number((balance.availableBalance / (balance.currencyDivisor || 100)).toFixed(2)).toLocaleString('en-US', {minimumFractionDigits: 2}) : '-' %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-slate-100 dark:bg-slate-500/10">
      <i data-lucide="users" class="w-5 h-5 text-slate-600 dark:text-slate-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Total Users</p>
      <p class="stat-value"><%= typeof stats !== 'undefined' ? stats.totalUsers : 0 %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-sky-50 dark:bg-sky-500/10">
      <i data-lucide="smartphone" class="w-5 h-5 text-sky-600 dark:text-sky-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Total Datas</p>
      <p class="stat-value"><%= typeof stats !== 'undefined' ? stats.totalEsims : 0 %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-emerald-50 dark:bg-emerald-500/10">
      <i data-lucide="check-circle" class="w-5 h-5 text-emerald-600 dark:text-emerald-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Active Datas</p>
      <p class="stat-value text-emerald-600 dark:text-emerald-400"><%= typeof stats !== 'undefined' ? stats.activeEsims : 0 %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-amber-50 dark:bg-amber-500/10">
      <i data-lucide="clock" class="w-5 h-5 text-amber-600 dark:text-amber-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Pending</p>
      <p class="stat-value text-amber-600 dark:text-amber-400"><%= typeof stats !== 'undefined' ? stats.pendingEsims : 0 %></p>
    </div>
  </div>
</div>

<!-- Payment Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="stat-card">
    <div class="stat-icon bg-emerald-50 dark:bg-emerald-500/10">
      <i data-lucide="dollar-sign" class="w-5 h-5 text-emerald-600 dark:text-emerald-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Total Revenue</p>
      <p class="stat-value text-emerald-600 dark:text-emerald-400">$<%= typeof paymentStats !== 'undefined' ? Number(parseFloat(paymentStats.totalRevenue).toFixed(2)).toLocaleString('en-US', {minimumFractionDigits: 2}) : '0.00' %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-sky-50 dark:bg-sky-500/10">
      <i data-lucide="check-circle" class="w-5 h-5 text-sky-600 dark:text-sky-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Paid Orders</p>
      <p class="stat-value"><%= typeof paymentStats !== 'undefined' ? paymentStats.completedPayments : 0 %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-rose-50 dark:bg-rose-500/10">
      <i data-lucide="x-circle" class="w-5 h-5 text-rose-600 dark:text-rose-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Failed</p>
      <p class="stat-value text-rose-600 dark:text-rose-400"><%= typeof paymentStats !== 'undefined' ? paymentStats.failedPayments : 0 %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-amber-50 dark:bg-amber-500/10">
      <i data-lucide="clock" class="w-5 h-5 text-amber-600 dark:text-amber-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Pending</p>
      <p class="stat-value text-amber-600 dark:text-amber-400"><%= typeof paymentStats !== 'undefined' ? paymentStats.pendingPayments : 0 %></p>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="flex flex-wrap gap-3 mb-8">
  <a href="/admin/assign-esim" class="btn btn-secondary">
    <i data-lucide="plus-circle" class="w-4 h-4"></i>
    Assign Data
  </a>
  <a href="/admin/users" class="btn btn-secondary">
    <i data-lucide="users" class="w-4 h-4"></i>
    Manage Users
  </a>
  <a href="/admin/esims" class="btn btn-secondary">
    <i data-lucide="layers" class="w-4 h-4"></i>
    All Datas
  </a>
  <a href="/admin/payments" class="btn btn-secondary">
    <i data-lucide="credit-card" class="w-4 h-4"></i>
    Payments
  </a>
</div>

<!-- Tables -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Recent eSIMs -->
  <div class="table-container">
    <div class="card-header">
      <h3>Recent Data Purchases</h3>
      <a href="/admin/esims" class="text-xs font-semibold text-[var(--brand-primary)] hover:underline">View all</a>
    </div>
    <div class="overflow-x-auto">
      <table class="table">
        <thead><tr>
          <th>User</th>
          <th>Status</th>
          <th>Date</th>
        </tr></thead>
        <tbody>
          <% if (typeof recentEsims !== 'undefined' && recentEsims.length > 0) { %>
          <% recentEsims.forEach(function(esim) { %>
          <tr>
            <td>
              <p class="font-medium text-[var(--text-primary)]"><%= esim.owner ? esim.owner.username : '-' %></p>
              <p class="text-xs text-[var(--text-tertiary)] font-mono truncate max-w-[120px]"><%= esim.offerId %></p>
            </td>
            <td>
              <% if (esim.status === 'completed') { %>
              <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Active</span>
              <% } else if (esim.status === 'pending') { %>
              <span class="badge badge-warning"><span class="badge-dot bg-amber-500"></span>Pending</span>
              <% } else { %>
              <span class="badge badge-danger"><span class="badge-dot bg-rose-500"></span><%= esim.status %></span>
              <% } %>
            </td>
            <td class="text-xs text-[var(--text-tertiary)]"><%= new Date(esim.createdAt).toLocaleDateString('en-GB') %></td>
          </tr>
          <% }) %>
          <% } else { %>
          <tr><td colspan="3" class="text-center py-8 text-sm text-[var(--text-tertiary)]">No Data purchases yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Recent Users -->
  <div class="table-container">
    <div class="card-header">
      <h3>Recent Users</h3>
      <a href="/admin/users" class="text-xs font-semibold text-[var(--brand-primary)] hover:underline">View all</a>
    </div>
    <div class="overflow-x-auto">
      <table class="table">
        <thead><tr>
          <th>User</th>
          <th>Role</th>
          <th>Status</th>
        </tr></thead>
        <tbody>
          <% if (typeof recentUsers !== 'undefined' && recentUsers.length > 0) { %>
          <% recentUsers.forEach(function(u) { %>
          <tr>
            <td>
              <div class="flex items-center gap-2.5">
                <div class="avatar avatar-sm" style="background: linear-gradient(135deg, #4f46e5, #7c3aed);"><%= u.username.charAt(0).toUpperCase() %></div>
                <div>
                  <p class="font-medium text-[var(--text-primary)]"><%= u.username %></p>
                  <p class="text-xs text-[var(--text-tertiary)]"><%= u.email || '-' %></p>
                </div>
              </div>
            </td>
            <td>
              <% if (u.isAdmin) { %>
              <span class="badge badge-warning">Admin</span>
              <% } else { %>
              <span class="badge badge-neutral">User</span>
              <% } %>
            </td>
            <td>
              <% if (u.isActive !== false) { %>
              <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Active</span>
              <% } else { %>
              <span class="badge badge-neutral"><span class="badge-dot bg-gray-400"></span>Inactive</span>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% } else { %>
          <tr><td colspan="3" class="text-center py-8 text-sm text-[var(--text-tertiary)]">No users yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Recent Payments -->
<div class="table-container mt-6">
  <div class="card-header">
    <h3>Recent Payments</h3>
    <a href="/admin/payments" class="text-xs font-semibold text-[var(--brand-primary)] hover:underline">View all</a>
  </div>
  <div class="overflow-x-auto">
    <table class="table">
      <thead><tr>
        <th>User</th>
        <th>Plan</th>
        <th>Amount</th>
        <th>Status</th>
        <th>Date</th>
      </tr></thead>
      <tbody>
        <% if (typeof recentPayments !== 'undefined' && recentPayments.length > 0) { %>
        <% recentPayments.forEach(function(p) { %>
        <tr>
          <td class="font-medium text-[var(--text-primary)]"><%= p.User ? p.User.username : '-' %></td>
          <td class="text-xs text-[var(--text-tertiary)] font-mono truncate max-w-[120px]"><%= p.offerId %></td>
          <td class="font-semibold text-[var(--text-primary)]">$<%= parseFloat(p.amount).toFixed(2) %></td>
          <td>
            <% if (p.metadata && p.metadata.esimPurchaseFailed) { %>
            <span class="badge badge-warning"><span class="badge-dot bg-amber-500"></span>Data Error</span>
            <% } else if (p.status === 'completed') { %>
            <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Paid</span>
            <% } else if (p.status === 'pending') { %>
            <span class="badge badge-warning"><span class="badge-dot bg-amber-500"></span>Pending</span>
            <% } else { %>
            <span class="badge badge-danger"><span class="badge-dot bg-rose-500"></span>Failed</span>
            <% } %>
          </td>
          <td class="text-xs text-[var(--text-tertiary)]"><%= new Date(p.createdAt).toLocaleDateString('en-GB') %></td>
        </tr>
        <% }) %>
        <% } else { %>
        <tr><td colspan="5" class="text-center py-8 text-sm text-[var(--text-tertiary)]">No payments yet</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
