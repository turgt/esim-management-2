<div class="v2-login-wrap">
  <div class="v2-login-card v2-anim">
    <div class="v2-login-logo" style="color: var(--accent);">DataPatch</div>
    <p class="v2-login-sub">Hesabina giris yap</p>

    <form action="/demo/offers" method="get">
      <div class="v2-input-group">
        <label class="v2-input-label">E-posta veya Kullanici Adi</label>
        <input type="text" class="v2-input" placeholder="ornek@email.com" value="demo@datapatch.co">
      </div>

      <div class="v2-input-group">
        <label class="v2-input-label">Sifre</label>
        <input type="password" class="v2-input" placeholder="••••••••" value="demo1234">
      </div>

      <a href="/demo/forgot-password" class="v2-forgot">Sifremi unuttum</a>

      <button type="submit" class="v2-btn v2-btn-primary v2-btn-block">Giris Yap</button>
    </form>

    <div class="v2-login-footer">
      Hesabin yok mu? <a href="/demo/register">Kayit Ol</a>
    </div>
  </div>
</div>
