<div class="demo-content" style="padding-bottom:40px;">
  <h1 class="demo-page-title demo-animate-in">Ödeme</h1>

  <!-- Order Summary -->
  <div class="demo-order-card demo-animate-in">
    <div class="demo-order-plan">
      <div class="demo-offer-flag demo-offer-flag-sm" style="background:<%= locals.order ? order.flagBg : 'var(--gradient-subtle)' %>;">
        <%= locals.order ? order.flag : '🇹🇷' %>
      </div>
      <div class="demo-order-details">
        <div class="demo-order-name"><%= locals.order ? order.planName : 'Turkiye 10GB' %></div>
        <div class="demo-order-meta">
          <%= locals.order ? order.data : '10 GB' %> &bull; <%= locals.order ? order.duration : '30 gun' %>
        </div>
      </div>
    </div>

    <div class="demo-receipt-divider"></div>

    <!-- Price Breakdown -->
    <div style="display:flex;flex-direction:column;gap:10px;">
      <div class="demo-receipt-line">
        <span class="demo-receipt-line-label">Ara Toplam</span>
        <span class="demo-receipt-line-value"><%= locals.order ? order.subtotal : '$4.16' %></span>
      </div>
      <div class="demo-receipt-line">
        <span class="demo-receipt-line-label">KDV (%20)</span>
        <span class="demo-receipt-line-value"><%= locals.order ? order.tax : '$0.83' %></span>
      </div>
      <div class="demo-receipt-divider"></div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span style="font-family:var(--font-heading);font-size:16px;font-weight:700;">Toplam</span>
        <span class="demo-receipt-total demo-gradient-text"><%= locals.order ? order.total : '$4.99' %></span>
      </div>
    </div>
  </div>

  <!-- Pay Button -->
  <a href="/demo/status" class="demo-btn demo-btn-primary demo-btn-block demo-btn-lg demo-animate-in">
    Odemeyi Tamamla
  </a>

  <!-- Security Note -->
  <p class="demo-security-note demo-animate-in">
    Guvenli odeme -- Paddle ile islenir
  </p>
</div>
