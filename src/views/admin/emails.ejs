<%- include('../partials/header', {title: 'Emails', user: locals.user}) %>

<div class="mb-8 flex items-center justify-between">
  <div>
    <p class="text-sm text-[var(--text-secondary)] mb-1">Email Management</p>
    <h1 class="text-page-title">Emails</h1>
  </div>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
  <div class="stat-card">
    <div class="stat-icon bg-[var(--brand-light)]">
      <i data-lucide="mail" class="w-5 h-5 text-[var(--brand-primary)]"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Total</p>
      <p class="stat-value"><%= stats.totalAll %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-sky-50 dark:bg-sky-500/10">
      <i data-lucide="inbox" class="w-5 h-5 text-sky-600 dark:text-sky-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Inbound</p>
      <p class="stat-value text-sky-600 dark:text-sky-400"><%= stats.totalInbound %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-emerald-50 dark:bg-emerald-500/10">
      <i data-lucide="send" class="w-5 h-5 text-emerald-600 dark:text-emerald-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Delivered</p>
      <p class="stat-value text-emerald-600 dark:text-emerald-400"><%= stats.totalDelivered %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-amber-50 dark:bg-amber-500/10">
      <i data-lucide="clock" class="w-5 h-5 text-amber-600 dark:text-amber-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Sent</p>
      <p class="stat-value"><%= stats.totalSent %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-rose-50 dark:bg-rose-500/10">
      <i data-lucide="alert-triangle" class="w-5 h-5 text-rose-600 dark:text-rose-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Bounced</p>
      <p class="stat-value text-rose-600 dark:text-rose-400"><%= stats.totalBounced %></p>
    </div>
  </div>
</div>

<!-- Filters -->
<form method="get" class="mb-6">
  <div class="flex flex-col sm:flex-row gap-3">
    <div class="flex-1 input-icon-wrapper">
      <i data-lucide="search" class="input-icon w-4 h-4"></i>
      <input type="text" name="search" value="<%= search %>" placeholder="Search by email or subject..." class="input">
    </div>
    <label for="emailTypeFilter" class="sr-only">Email Type</label>
    <select name="type" id="emailTypeFilter" class="input !w-auto">
      <option value="">All Types</option>
      <option value="inbound" <%= typeFilter === 'inbound' ? 'selected' : '' %>>Inbound</option>
      <option value="verification" <%= typeFilter === 'verification' ? 'selected' : '' %>>Verification</option>
      <option value="welcome" <%= typeFilter === 'welcome' ? 'selected' : '' %>>Welcome</option>
      <option value="password_reset" <%= typeFilter === 'password_reset' ? 'selected' : '' %>>Password Reset</option>
      <option value="payment_success" <%= typeFilter === 'payment_success' ? 'selected' : '' %>>Payment Success</option>
      <option value="payment_failed" <%= typeFilter === 'payment_failed' ? 'selected' : '' %>>Payment Failed</option>
      <option value="esim_assigned" <%= typeFilter === 'esim_assigned' ? 'selected' : '' %>>eSIM Assigned</option>
      <option value="esim_activation_failed" <%= typeFilter === 'esim_activation_failed' ? 'selected' : '' %>>Activation Failed</option>
    </select>
    <label for="emailStatusFilter" class="sr-only">Email Status</label>
    <select name="status" id="emailStatusFilter" class="input !w-auto">
      <option value="">All Status</option>
      <option value="received" <%= statusFilter === 'received' ? 'selected' : '' %>>Received</option>
      <option value="sent" <%= statusFilter === 'sent' ? 'selected' : '' %>>Sent</option>
      <option value="delivered" <%= statusFilter === 'delivered' ? 'selected' : '' %>>Delivered</option>
      <option value="opened" <%= statusFilter === 'opened' ? 'selected' : '' %>>Opened</option>
      <option value="clicked" <%= statusFilter === 'clicked' ? 'selected' : '' %>>Clicked</option>
      <option value="bounced" <%= statusFilter === 'bounced' ? 'selected' : '' %>>Bounced</option>
      <option value="failed" <%= statusFilter === 'failed' ? 'selected' : '' %>>Failed</option>
    </select>
    <button type="submit" class="btn btn-secondary">Filter</button>
    <% if (search || typeFilter || statusFilter) { %>
    <a href="/admin/emails" class="btn btn-secondary">Clear</a>
    <% } %>
  </div>
</form>

<!-- Emails Table -->
<div class="table-container">
  <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
          <th>Direction</th>
          <th>From / To</th>
          <th>Subject</th>
          <th>Type</th>
          <th>Status</th>
          <th>Date</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (emails.length > 0) { %>
        <% emails.forEach(function(e) { %>
        <tr>
          <td>
            <% if (e.type === 'inbound') { %>
            <span class="badge badge-info inline-flex items-center gap-1"><i data-lucide="inbox" class="w-3 h-3"></i>In</span>
            <% } else { %>
            <span class="badge badge-neutral inline-flex items-center gap-1"><i data-lucide="send" class="w-3 h-3"></i>Out</span>
            <% } %>
          </td>
          <td>
            <% if (e.type === 'inbound') { %>
            <p class="font-medium text-[var(--text-primary)] text-sm"><%= e.metadata && e.metadata.from ? e.metadata.from : '-' %></p>
            <p class="text-xs text-[var(--text-tertiary)]">to: <%= e.to %></p>
            <% } else { %>
            <p class="font-medium text-[var(--text-primary)] text-sm"><%= e.to %></p>
            <% if (e.user) { %>
            <p class="text-xs text-[var(--text-tertiary)]"><%= e.user.displayName || e.user.username %></p>
            <% } %>
            <% } %>
          </td>
          <td class="max-w-[200px]">
            <p class="text-sm text-[var(--text-primary)] truncate"><%= e.subject %></p>
          </td>
          <td>
            <span class="text-xs text-[var(--text-secondary)]"><%= e.type %></span>
          </td>
          <td>
            <% if (e.status === 'received') { %>
            <span class="badge badge-info"><span class="badge-dot bg-sky-500"></span>Received</span>
            <% } else if (e.status === 'delivered') { %>
            <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Delivered</span>
            <% } else if (e.status === 'opened') { %>
            <span class="badge badge-success">Opened</span>
            <% } else if (e.status === 'clicked') { %>
            <span class="badge badge-success">Clicked</span>
            <% } else if (e.status === 'sent') { %>
            <span class="badge badge-warning"><span class="badge-dot bg-amber-500"></span>Sent</span>
            <% } else if (e.status === 'bounced') { %>
            <span class="badge badge-danger"><span class="badge-dot bg-rose-500"></span>Bounced</span>
            <% } else if (e.status === 'failed') { %>
            <span class="badge badge-danger">Failed</span>
            <% } else { %>
            <span class="badge badge-neutral"><%= e.status %></span>
            <% } %>
          </td>
          <td class="text-xs text-[var(--text-tertiary)]"><%= new Date(e.createdAt).toLocaleString('en-GB') %></td>
          <td>
            <a href="/admin/emails/<%= e.id %>" class="btn btn-secondary btn-sm">
              <i data-lucide="eye" class="w-3.5 h-3.5"></i>
            </a>
          </td>
        </tr>
        <% }) %>
        <% } else { %>
        <tr>
          <td colspan="7" class="text-center py-12 text-sm text-[var(--text-tertiary)]">
            <i data-lucide="mail" class="w-8 h-8 mx-auto mb-2 opacity-40"></i>
            <p>No emails found</p>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if (pagination.totalPages > 1) { %>
<%- include('../partials/pagination', { pagination }) %>
<% } %>

<%- include('../partials/footer') %>
