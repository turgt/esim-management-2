  </div>
  </div>
<% } %>

<script>
  if (typeof lucide !== 'undefined') lucide.createIcons();
  // Prevent double-submit on all forms
  document.querySelectorAll('form').forEach(function(form) {
    if (form.dataset.noProtect) return;
    form.addEventListener('submit', function() {
      var btn = form.querySelector('button[type="submit"]');
      if (btn && !btn.disabled) {
        btn.disabled = true;
        setTimeout(function() { btn.disabled = false; }, 5000);
      }
    });
  });

  // HTMX: progress, prefetch, title, errors, reinit
  (function() {
    if (typeof htmx === 'undefined') return;

    // Abort previous navigation when a new one starts
    var activeNavXhr = null;
    document.addEventListener('htmx:beforeRequest', function(e) {
      if (!e.detail.boosted) return;
      if (activeNavXhr && activeNavXhr.readyState < 4) {
        activeNavXhr.abort();
      }
      activeNavXhr = e.detail.xhr;
    });
    document.addEventListener('htmx:afterRequest', function(e) {
      if (e.detail.boosted) activeNavXhr = null;
    });

    // Instant nav highlight on click (before content loads)
    document.addEventListener('click', function(e) {
      var link = e.target.closest('.topbar-nav a, .tabbar a:not(.tabbar-back-app)');
      if (!link) return;
      var nav = link.closest('.topbar-nav, .tabbar');
      if (!nav) return;
      nav.querySelectorAll('a').forEach(function(a) { a.classList.remove('active'); });
      link.classList.add('active');
    });

    // Progress bar
    document.addEventListener('htmx:beforeRequest', function(e) {
      if (!e.detail.boosted) return;
      var bar = document.getElementById('htmx-progress');
      if (bar) bar.classList.add('active');
    });
    document.addEventListener('htmx:afterRequest', function() {
      var bar = document.getElementById('htmx-progress');
      if (bar) bar.classList.remove('active');
    });

    // Error handling
    document.addEventListener('htmx:responseError', function(e) {
      var bar = document.getElementById('htmx-progress');
      if (bar) bar.classList.remove('active');
      var status = e.detail.xhr ? e.detail.xhr.status : 0;
      var msg = status >= 500 ? 'Sunucu hatasi olustu. Lutfen tekrar deneyin.'
              : status === 403 ? 'Oturum suresi dolmus olabilir. Sayfayi yenileyin.'
              : status === 404 ? 'Sayfa bulunamadi.'
              : 'Bir hata olustu. Lutfen tekrar deneyin.';
      if (typeof showToast === 'function') showToast(msg, 'error');
    });
    document.addEventListener('htmx:sendError', function() {
      var bar = document.getElementById('htmx-progress');
      if (bar) bar.classList.remove('active');
      if (typeof showToast === 'function') showToast('Baglanti hatasi. Internet baglantinizi kontrol edin.', 'error');
    });

    // After body swap: title, animation, lucide, tabbar scroll
    document.addEventListener('htmx:afterSettle', function(e) {
      if (!e.detail.boosted) return;
      // Update page title
      var pc = document.getElementById('page-content');
      if (pc && pc.dataset.title) {
        document.title = pc.dataset.title + ' - DataPatch';
      }
      // Fade-in animation on content area
      if (pc) {
        pc.style.animation = 'none';
        void pc.offsetWidth;
        pc.style.animation = 'htmx-fadeIn 0.2s ease-out';
      }
      // Reinit lucide icons
      if (typeof lucide !== 'undefined') lucide.createIcons();
      // Scroll active tab into view on scrollable tabbar
      var activeTab = document.querySelector('.tabbar-scroll a.active');
      if (activeTab) {
        activeTab.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'instant' });
      }
      // Scroll page to top
      window.scrollTo(0, 0);
    });
  })();
</script>
</body>
</html>
