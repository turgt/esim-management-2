<%- include('../partials/header', {title: title, user: locals.user}) %>

<div class="mb-8">
  <a href="/agency/bookings" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] inline-flex items-center gap-1 mb-3">
    <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i>
    Rezervasyonlara Don
  </a>
  <h1 class="text-page-title flex items-center gap-3">
    Rezervasyon #<%= booking.id %>
    <% if (booking.status === 'pending_provisioning') { %>
    <span class="badge badge-warning"><span class="badge-dot bg-amber-500"></span>Bekliyor</span>
    <% } else if (booking.status === 'provisioned') { %>
    <span class="badge badge-info"><span class="badge-dot bg-sky-500"></span>Saglanmis</span>
    <% } else if (booking.status === 'installed') { %>
    <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Aktif</span>
    <% } else if (booking.status === 'cancelled') { %>
    <span class="badge badge-error"><span class="badge-dot bg-rose-500"></span>Iptal</span>
    <% } else { %>
    <span class="badge badge-neutral"><span class="badge-dot bg-gray-400"></span><%= booking.status %></span>
    <% } %>
  </h1>
</div>

<!-- Success Banner -->
<% if (typeof created !== 'undefined' && created) { %>
<div class="alert alert-success mb-6">
  <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
  <div>
    <p class="font-medium">Rezervasyon olusturuldu!</p>
    <p class="text-sm mt-0.5">Token URL asagida gorunmektedir. Yolcuya gonderin.</p>
  </div>
</div>
<% } %>

<% if (typeof success !== 'undefined' && success) { %>
<div class="alert alert-success mb-6">
  <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
  <p><%= success %></p>
</div>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
<div class="alert alert-error mb-6">
  <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
  <p><%= error %></p>
</div>
<% } %>

<div class="grid lg:grid-cols-3 gap-6">

  <!-- Main Info Card -->
  <div class="lg:col-span-2 space-y-5">

    <!-- Traveler & Package Info -->
    <div class="card p-5">
      <h2 class="text-sm font-semibold text-[var(--text-tertiary)] uppercase tracking-wide mb-4">Rezervasyon Bilgileri</h2>
      <dl class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
        <div>
          <dt class="text-[var(--text-tertiary)] mb-0.5">Yolcu</dt>
          <dd class="font-medium text-[var(--text-primary)]"><%= booking.travelerName %></dd>
        </div>
        <% if (booking.agencyBookingRef) { %>
        <div>
          <dt class="text-[var(--text-tertiary)] mb-0.5">Referans No</dt>
          <dd class="font-mono text-[var(--text-primary)]"><%= booking.agencyBookingRef %></dd>
        </div>
        <% } %>
        <% if (booking.travelerEmail) { %>
        <div>
          <dt class="text-[var(--text-tertiary)] mb-0.5">E-posta</dt>
          <dd class="text-[var(--text-primary)]"><%= booking.travelerEmail %></dd>
        </div>
        <% } %>
        <% if (booking.travelerPhone) { %>
        <div>
          <dt class="text-[var(--text-tertiary)] mb-0.5">Telefon</dt>
          <dd class="text-[var(--text-primary)]"><%= booking.travelerPhone %></dd>
        </div>
        <% } %>
        <div>
          <dt class="text-[var(--text-tertiary)] mb-0.5">Aktivasyon Tarihi</dt>
          <dd class="font-medium text-[var(--text-primary)]">
            <%= new Date(booking.dueDate).toLocaleDateString('tr-TR', {day:'numeric', month:'long', year:'numeric'}) %>
            — <%= new Date(booking.dueDate).toLocaleTimeString('tr-TR', {hour:'2-digit', minute:'2-digit'}) %>
          </dd>
        </div>
        <div>
          <dt class="text-[var(--text-tertiary)] mb-0.5">Olusturulma</dt>
          <dd class="text-[var(--text-secondary)]"><%= new Date(booking.createdAt).toLocaleDateString('tr-TR') %></dd>
        </div>
      </dl>
    </div>

    <!-- Package Info -->
    <% if (booking.contract && booking.contract.package) { %>
    <div class="card p-5">
      <h2 class="text-sm font-semibold text-[var(--text-tertiary)] uppercase tracking-wide mb-4">Paket Bilgileri</h2>
      <div class="flex items-center gap-4">
        <% if (booking.contract.package.imageUrl) { %>
        <img src="<%= booking.contract.package.imageUrl %>" alt="<%= booking.contract.package.operatorTitle %>" class="w-12 h-12 object-contain rounded-lg bg-[var(--bg-secondary)] p-1">
        <% } else { %>
        <div class="w-12 h-12 rounded-lg bg-[var(--brand-light)] flex items-center justify-center flex-shrink-0">
          <i data-lucide="sim-card" class="w-6 h-6 text-[var(--brand-primary)]"></i>
        </div>
        <% } %>
        <div>
          <p class="font-semibold text-[var(--text-primary)]"><%= booking.contract.package.title %></p>
          <p class="text-sm text-[var(--text-secondary)]">
            <%= booking.contract.package.data %> / <%= booking.contract.package.day %> gun
            &bull; <%= booking.contract.package.countryCode %>
          </p>
          <% if (booking.contract.package.operatorTitle) { %>
          <p class="text-xs text-[var(--text-tertiary)]"><%= booking.contract.package.operatorTitle %></p>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Token URL Card -->
    <div class="card p-5">
      <h2 class="text-sm font-semibold text-[var(--text-tertiary)] uppercase tracking-wide mb-3">Yolcu Baglantisi</h2>
      <p class="text-xs text-[var(--text-secondary)] mb-3">
        Asagidaki URL'i yolcunuza gonderin. Yolcunuz bu link araciligiyla eSIM kurulum talimatlarini ve QR kodunu gorebilir.
      </p>
      <div class="flex items-center gap-2 p-3 bg-[var(--bg-secondary)] rounded-xl border border-[var(--border-primary)]">
        <i data-lucide="link" class="w-4 h-4 text-[var(--brand-primary)] flex-shrink-0"></i>
        <span id="token-url" class="text-sm font-mono text-[var(--brand-primary)] truncate flex-1"><%= typeof tokenUrl !== 'undefined' ? tokenUrl : '' %></span>
        <button onclick="copyTokenUrl()" class="btn btn-secondary btn-sm flex-shrink-0" id="copy-btn">
          <i data-lucide="copy" id="copy-icon" class="w-3.5 h-3.5"></i>
          <span id="copy-label">Kopyala</span>
        </button>
      </div>
    </div>

  </div>

  <!-- Sidebar: Actions -->
  <div class="space-y-4">

    <!-- eSIM Status -->
    <% if (booking.esim) { %>
    <div class="card p-4">
      <h3 class="text-sm font-semibold text-[var(--text-tertiary)] uppercase tracking-wide mb-3">eSIM</h3>
      <dl class="space-y-2 text-sm">
        <% if (booking.esim.iccid) { %>
        <div>
          <dt class="text-[var(--text-tertiary)] text-xs">ICCID</dt>
          <dd class="font-mono text-xs text-[var(--text-primary)] break-all"><%= booking.esim.iccid %></dd>
        </div>
        <% } %>
        <div>
          <dt class="text-[var(--text-tertiary)] text-xs">Durum</dt>
          <dd class="mt-0.5"><%= booking.esim.status %></dd>
        </div>
      </dl>
    </div>
    <% } %>

    <!-- Action Buttons -->
    <div class="card p-4 space-y-3">
      <h3 class="text-sm font-semibold text-[var(--text-tertiary)] uppercase tracking-wide">Islemler</h3>

      <!-- Change Date -->
      <% if (typeof canChangeDate !== 'undefined' && canChangeDate) { %>
      <button onclick="document.getElementById('change-date-dialog').classList.remove('hidden')"
        class="btn btn-secondary w-full justify-start">
        <i data-lucide="calendar" class="w-4 h-4"></i>
        Tarih Degistir
      </button>
      <% } else if (booking.status === 'pending_provisioning') { %>
      <div class="flex items-center gap-2 text-xs text-[var(--text-tertiary)] p-2 bg-[var(--bg-secondary)] rounded-lg">
        <i data-lucide="clock" class="w-3.5 h-3.5 flex-shrink-0"></i>
        <span>Aktivasyona 72 saatten az kaldi, tarih degistirilemiyor.</span>
      </div>
      <% } %>

      <!-- Cancel -->
      <% if (typeof canCancel !== 'undefined' && canCancel) { %>
      <button onclick="document.getElementById('cancel-dialog').classList.remove('hidden')"
        class="btn btn-secondary w-full justify-start text-rose-600 dark:text-rose-400 hover:bg-rose-50 dark:hover:bg-rose-500/10">
        <i data-lucide="x-circle" class="w-4 h-4"></i>
        Rezervasyonu Iptal Et
      </button>
      <% } %>

      <% if ((typeof canChangeDate === 'undefined' || !canChangeDate) && (typeof canCancel === 'undefined' || !canCancel) && booking.status !== 'pending_provisioning') { %>
      <p class="text-xs text-[var(--text-tertiary)] text-center py-2">Bu rezervasyon icin islem yapilabilecek eylem bulunmuyor.</p>
      <% } %>
    </div>

  </div>
</div>

<!-- Change Date Dialog -->
<% if (typeof canChangeDate !== 'undefined' && canChangeDate) { %>
<div id="change-date-dialog" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="document.getElementById('change-date-dialog').classList.add('hidden')"></div>
  <div class="relative bg-[var(--bg-primary)] rounded-2xl shadow-xl w-full max-w-sm p-6">
    <h2 class="text-lg font-semibold text-[var(--text-primary)] mb-1">Tarih Degistir</h2>
    <p class="text-sm text-[var(--text-secondary)] mb-4">Yeni aktivasyon tarihini secin.</p>
    <form method="post" action="/agency/bookings/<%= booking.id %>/change-date" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div>
        <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Yeni Tarih <span class="text-rose-500">*</span></label>
        <input type="datetime-local" name="newDueDate" required class="input"
          value="<%= new Date(booking.dueDate).toISOString().slice(0,16) %>">
      </div>
      <div class="flex gap-3">
        <button type="button" onclick="document.getElementById('change-date-dialog').classList.add('hidden')" class="btn btn-secondary flex-1">Iptal</button>
        <button type="submit" class="btn btn-primary flex-1">Guncelle</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<!-- Cancel Dialog -->
<% if (typeof canCancel !== 'undefined' && canCancel) { %>
<div id="cancel-dialog" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="document.getElementById('cancel-dialog').classList.add('hidden')"></div>
  <div class="relative bg-[var(--bg-primary)] rounded-2xl shadow-xl w-full max-w-sm p-6">
    <div class="flex items-center gap-3 mb-3">
      <div class="w-10 h-10 rounded-xl bg-rose-50 dark:bg-rose-500/10 flex items-center justify-center flex-shrink-0">
        <i data-lucide="alert-triangle" class="w-5 h-5 text-rose-600 dark:text-rose-400"></i>
      </div>
      <h2 class="text-lg font-semibold text-[var(--text-primary)]">Rezervasyonu Iptal Et</h2>
    </div>
    <p class="text-sm text-[var(--text-secondary)] mb-4">
      Bu rezervasyon iptal edilecek ve eSIM saglama islemi gerceklestirilmeyecektir. Bu islem geri alinamaz.
    </p>
    <form method="post" action="/agency/bookings/<%= booking.id %>/cancel" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div>
        <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Iptal Nedeni</label>
        <input type="text" name="reason" class="input" placeholder="Istege baglidir">
      </div>
      <div class="flex gap-3">
        <button type="button" onclick="document.getElementById('cancel-dialog').classList.add('hidden')" class="btn btn-secondary flex-1">Vazgec</button>
        <button type="submit" class="btn flex-1 bg-rose-600 hover:bg-rose-700 text-white border-rose-600">Iptal Et</button>
      </div>
    </form>
  </div>
</div>
<% } %>

<script>
function copyTokenUrl() {
  const url = document.getElementById('token-url').textContent.trim();
  const label = document.getElementById('copy-label');
  navigator.clipboard.writeText(url).then(function() {
    label.textContent = 'Kopyalandi';
    setTimeout(function() { label.textContent = 'Kopyala'; }, 2000);
  }).catch(function() {
    window.prompt('Kopyalamak icin secin:', url);
  });
}
</script>

<%- include('../partials/footer') %>
