<%- include('partials/header', {title: 'Register', user: null}) %>

    <p class="auth-brand-subtitle">Create your DataPatch account</p>

    <div class="card p-5 sm:p-7 fade-up">
      <div class="text-center mb-6">
        <h1 class="text-xl font-bold text-[var(--text-primary)]">Create account</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1.5">Get started with DataPatch</p>
      </div>

      <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <div class="alert alert-error mb-5">
        <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
        <div class="space-y-1">
          <% errors.forEach(function(err) { %><p><%= err.msg || err %></p><% }) %>
        </div>
      </div>
      <% } %>

      <form method="post" action="/auth/register" class="space-y-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% if (typeof ref !== 'undefined' && ref) { %>
        <input type="hidden" name="ref" value="<%= ref %>">
        <% } %>
        <div>
          <label for="reg-username" class="input-label">Username</label>
          <div class="input-icon-wrapper">
            <i data-lucide="at-sign" class="input-icon w-4 h-4"></i>
            <input type="text" id="reg-username" name="username" required minlength="3" maxlength="30" placeholder="Choose a username" autocomplete="username" class="input">
          </div>
        </div>
        <div>
          <label for="reg-email" class="input-label">Email</label>
          <div class="input-icon-wrapper">
            <i data-lucide="mail" class="input-icon w-4 h-4"></i>
            <input type="email" id="reg-email" name="email" required placeholder="your@email.com" autocomplete="email" class="input">
          </div>
        </div>
        <div>
          <label for="reg-display" class="input-label">Display Name <span class="text-[var(--text-tertiary)] font-normal">(optional)</span></label>
          <input type="text" id="reg-display" name="displayName" maxlength="50" placeholder="How should we call you?" autocomplete="name" class="input">
        </div>
        <div>
          <label for="regPassword" class="input-label">Password</label>
          <div class="input-icon-wrapper relative">
            <i data-lucide="lock" class="input-icon w-4 h-4"></i>
            <input type="password" name="password" id="regPassword" required minlength="8" placeholder="Min 8 characters" autocomplete="new-password" class="input !pr-10" oninput="checkPasswordStrength(this.value)">
            <button type="button" onclick="togglePwVisibility('regPassword', this)" class="absolute right-2.5 top-1/2 -translate-y-1/2 text-[var(--text-tertiary)] hover:text-[var(--text-primary)]" aria-label="Toggle password visibility">
              <i data-lucide="eye" class="w-4 h-4"></i>
            </button>
          </div>
          <div class="password-strength" id="pwStrength">
            <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
          </div>
          <p class="text-xs mt-1" id="pwLabel" style="display:none"></p>
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">Create Account</button>
      </form>
    </div>

    <p class="auth-footer">
      Already have an account? <a href="/auth/login">Sign in</a>
    </p>

<script>
function checkPasswordStrength(pw) {
  var el = document.getElementById('pwStrength');
  var label = document.getElementById('pwLabel');
  var s = 0;
  if (pw.length >= 8) s++;
  if (/[A-Z]/.test(pw)) s++;
  if (/[0-9]/.test(pw)) s++;
  if (/[^A-Za-z0-9]/.test(pw)) s++;
  el.className = 'password-strength' + (s > 0 ? ' str-' + s : '');
  var labels = ['', 'Weak', 'Fair', 'Good', 'Strong'];
  var colors = ['', 'color:var(--danger)', 'color:#f59e0b', 'color:#22c55e', 'color:#10b981'];
  if (pw.length > 0) {
    label.textContent = labels[s] || 'Too short';
    label.style.cssText = (colors[s] || 'color:var(--text-tertiary)') + ';display:block';
  } else {
    label.style.display = 'none';
  }
}
function togglePwVisibility(inputId, btn) {
  var input = document.getElementById(inputId);
  var icon = btn.querySelector('[data-lucide]');
  if (input.type === 'password') {
    input.type = 'text';
    icon.setAttribute('data-lucide', 'eye-off');
  } else {
    input.type = 'password';
    icon.setAttribute('data-lucide', 'eye');
  }
  lucide.createIcons();
}
</script>

<%- include('partials/footer') %>
