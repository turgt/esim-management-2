# Database
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Zendit API
ZENDIT_API_BASE=https://api.zendit.io/v1
ZENDIT_API_KEY=sand_XXXXXXXXXXXXXXXX

# Server
PORT=3000
COUNTRY=TR
OFFERS_LIMIT=100
SESSION_SECRET=change-me-to-a-strong-random-string

# Logging
LOG_LEVEL=info

# Admin Bootstrap (optional, defaults to admin123)
ADMIN_PASSWORD=change-me-in-production

# SMTP (Email) - Leave empty if not configured
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=app-specific-password
SMTP_FROM=eSIM Hub <noreply@yourdomain.com>

# Application URL
APP_URL=http://localhost:3000
