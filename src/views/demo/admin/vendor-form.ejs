<div class="demo-page-title"><%= locals.vendorName ? 'Vendor Düzenle' : 'Vendor Ekle' %></div>

<div class="demo-form-card demo-animate-in" style="max-width: 600px;">
  <form>
    <div class="demo-input-group">
      <label class="demo-input-label">Vendor Adı</label>
      <input type="text" class="demo-input" placeholder="Vendor adını girin" value="<%= locals.vendorName || '' %>">
    </div>

    <div class="demo-input-group">
      <label class="demo-input-label">API URL</label>
      <input type="text" class="demo-input" placeholder="https://api.example.com/v1" value="<%= locals.vendorApiUrl || '' %>">
    </div>

    <div class="demo-input-group">
      <label class="demo-input-label">API Key</label>
      <input type="password" class="demo-input" placeholder="API anahtarını girin">
    </div>

    <div class="demo-input-group">
      <label class="demo-input-label">Komisyon Oranı (%)</label>
      <input type="number" class="demo-input" placeholder="12" value="<%= locals.vendorCommission || '' %>">
    </div>

    <div class="demo-input-group">
      <label class="demo-input-label">Durum</label>
      <select class="demo-input">
        <option value="active" <%= locals.vendorStatus === 'active' || !locals.vendorStatus ? 'selected' : '' %>>Aktif</option>
        <option value="passive" <%= locals.vendorStatus === 'passive' ? 'selected' : '' %>>Pasif</option>
      </select>
    </div>

    <button type="button" class="demo-btn demo-btn-primary demo-btn-block" style="margin-top: 8px;">Kaydet</button>
  </form>
</div>
