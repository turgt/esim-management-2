    <form action="/demo/login" method="get">
      <div class="v2-input-group">
        <label class="v2-input-label">E-posta</label>
        <input type="email" class="v2-input" placeholder="ornek@email.com">
      </div>

      <button type="submit" class="v2-btn v2-btn-primary v2-btn-block">Link Gonder</button>
    </form>

    <div class="v2-login-footer">
      <a href="/demo/login">Giris sayfasina don</a>
    </div>
  </div>
</div>
