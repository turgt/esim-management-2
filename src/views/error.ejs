<%- include('partials/header', {title: 'Error', user: locals.user}) %>

<% if (typeof user !== 'undefined' && user) { %>
<div class="flex items-center justify-center" style="min-height: calc(100vh - 16rem);">
<% } %>

  <div class="w-full max-w-md text-center relative">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none" aria-hidden="true">
      <span class="text-[10rem] font-black text-[var(--text-primary)] opacity-[0.03]"><%= typeof title !== 'undefined' && title.match && title.match(/\d{3}/) ? title.match(/\d{3}/)[0] : '!' %></span>
    </div>

    <div class="card p-8 relative z-10">
      <div class="w-14 h-14 bg-red-50 dark:bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
        <i data-lucide="alert-triangle" class="w-7 h-7 text-red-500"></i>
      </div>

      <h1 class="text-xl font-semibold text-[var(--text-primary)] mb-2"><%= typeof errorTitle !== 'undefined' ? errorTitle : 'Something went wrong' %></h1>
      <p class="text-sm text-[var(--text-secondary)] mb-6"><%= typeof errorMessage !== 'undefined' ? errorMessage : 'An unexpected error occurred' %></p>

      <div class="flex items-center justify-center gap-3">
        <button onclick="history.back()" class="btn btn-ghost">Go Back</button>
        <a href="/" class="btn btn-primary">Go Home</a>
      </div>
    </div>
  </div>

<% if (typeof user !== 'undefined' && user) { %>
</div>
<% } %>

<%- include('partials/footer') %>
