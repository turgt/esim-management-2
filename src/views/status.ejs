<%- include('partials/header', {title: 'Purchase Status', user: locals.user}) %>

<div class="mb-6">
  <div class="breadcrumb">
    <a href="/purchases"><i data-lucide="chevron-left" class="w-4 h-4"></i> Back to My eSIMs</a>
  </div>
  <h1 class="text-page-title">Purchase Status</h1>
</div>

<div class="max-w-2xl space-y-5">
  <!-- Status Banner -->
  <div class="card overflow-hidden">
    <% if (status.status === 'DONE' || status.status === 'completed') { %>
    <div class="px-5 py-4 flex items-center gap-3 bg-emerald-50 dark:bg-emerald-500/10 border-b border-emerald-200 dark:border-emerald-500/20">
      <div class="w-8 h-8 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
        <i data-lucide="check" class="w-4 h-4 text-white"></i>
      </div>
      <div>
        <p class="text-sm font-semibold text-emerald-700 dark:text-emerald-400">eSIM Ready</p>
        <p class="text-xs text-emerald-600 dark:text-emerald-500">Your eSIM has been activated and is ready to use</p>
      </div>
    </div>
    <% } else if (status.status === 'PENDING' || status.status === 'pending') { %>
    <div class="px-5 py-4 flex items-center gap-3 bg-amber-50 dark:bg-amber-500/10 border-b border-amber-200 dark:border-amber-500/20">
      <div class="w-8 h-8 rounded-full bg-amber-500 flex items-center justify-center flex-shrink-0">
        <i data-lucide="loader" class="w-4 h-4 text-white animate-spin"></i>
      </div>
      <div>
        <p class="text-sm font-semibold text-amber-700 dark:text-amber-400">Processing</p>
        <p class="text-xs text-amber-600 dark:text-amber-500">Your eSIM is being set up, this usually takes a few minutes</p>
      </div>
    </div>
    <% } else if (status.status === 'FAILED' || status.status === 'failed') { %>
    <div class="px-5 py-4 flex items-center gap-3 bg-red-50 dark:bg-red-500/10 border-b border-red-200 dark:border-red-500/20">
      <div class="w-8 h-8 rounded-full bg-red-500 flex items-center justify-center flex-shrink-0">
        <i data-lucide="x" class="w-4 h-4 text-white"></i>
      </div>
      <div>
        <p class="text-sm font-semibold text-red-700 dark:text-red-400">Activation Failed</p>
        <p class="text-xs text-red-600 dark:text-red-500">Please contact support for assistance</p>
      </div>
    </div>
    <% } else { %>
    <div class="px-5 py-4 flex items-center gap-3 bg-blue-50 dark:bg-blue-500/10 border-b border-blue-200 dark:border-blue-500/20">
      <div class="w-8 h-8 rounded-full bg-blue-500 flex items-center justify-center flex-shrink-0">
        <i data-lucide="loader" class="w-4 h-4 text-white animate-spin"></i>
      </div>
      <div>
        <p class="text-sm font-semibold text-blue-700 dark:text-blue-400"><%= status.status %></p>
        <p class="text-xs text-blue-600 dark:text-blue-500">Your eSIM is being prepared</p>
      </div>
    </div>
    <% } %>

    <!-- Details Grid -->
    <div class="p-5 grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
      <div>
        <p class="text-xs text-[var(--text-tertiary)] mb-0.5">Transaction ID</p>
        <p class="font-mono text-xs text-[var(--text-primary)] truncate"><%= status.transactionId %></p>
      </div>
      <div>
        <p class="text-xs text-[var(--text-tertiary)] mb-0.5">Offer</p>
        <p class="text-[var(--text-primary)] truncate"><%= status.offerId %></p>
      </div>
      <% if (status.brandName || (esim && esim.brandName)) { %>
      <div>
        <p class="text-xs text-[var(--text-tertiary)] mb-0.5">Provider</p>
        <p class="text-[var(--text-primary)]"><%= status.brandName || esim.brandName || '-' %></p>
      </div>
      <% } %>
      <% if (status.country || (esim && esim.country)) { %>
      <div>
        <p class="text-xs text-[var(--text-tertiary)] mb-0.5">Region</p>
        <p class="text-[var(--text-primary)]"><%= status.country || esim.country || '-' %></p>
      </div>
      <% } %>
      <% if (status.durationDays || (esim && esim.durationDays)) { %>
      <div>
        <p class="text-xs text-[var(--text-tertiary)] mb-0.5">Duration</p>
        <p class="font-semibold text-[var(--text-primary)]"><%= status.durationDays || esim.durationDays %> days</p>
      </div>
      <% } %>
      <div>
        <p class="text-xs text-[var(--text-tertiary)] mb-0.5">Data</p>
        <p class="font-semibold text-[var(--text-primary)]"><%= status.dataUnlimited ? 'Unlimited' : (status.dataGB || (esim && esim.dataGB) ? (status.dataGB || esim.dataGB) + ' GB' : '-') %></p>
      </div>
      <% if (esim && esim.iccid) { %>
      <div class="col-span-2">
        <p class="text-xs text-[var(--text-tertiary)] mb-0.5">ICCID</p>
        <div class="flex items-center gap-1.5">
          <p class="font-mono text-xs text-[var(--text-primary)]"><%= esim.iccid %></p>
          <button onclick="copyToClipboard('<%= esim.iccid %>', this)" class="copy-btn" title="Copy ICCID">
            <i data-lucide="copy" class="w-3 h-3"></i>
          </button>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Activity Log -->
  <% if (status.log && status.log.length > 0) { %>
  <div class="card">
    <div class="card-header">
      <h3>Activity Log</h3>
    </div>
    <div class="card-body">
      <div class="relative">
        <% status.log.forEach(function(entry, index) { %>
        <div class="flex gap-3 <%= index < status.log.length - 1 ? 'pb-4' : '' %>">
          <div class="flex flex-col items-center">
            <%
              var isDone = ['DONE','ACCEPTED','completed'].includes(entry.status);
              var isPending = ['PENDING','pending'].includes(entry.status);
              var isProgress = ['AUTHORIZED','IN_PROGRESS','processing'].includes(entry.status);
              var isFailed = ['FAILED','CANCELLED','REJECTED','ERROR','failed'].includes(entry.status);
            %>
            <% if (isDone) { %>
            <div class="w-5 h-5 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
              <i data-lucide="check" class="w-2.5 h-2.5 text-white"></i>
            </div>
            <% } else if (isPending) { %>
            <div class="w-5 h-5 rounded-full bg-amber-500 flex items-center justify-center flex-shrink-0">
              <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
            </div>
            <% } else if (isProgress) { %>
            <div class="w-5 h-5 rounded-full bg-blue-500 flex items-center justify-center flex-shrink-0">
              <div class="w-1.5 h-1.5 rounded-full bg-white"></div>
            </div>
            <% } else if (isFailed) { %>
            <div class="w-5 h-5 rounded-full bg-red-500 flex items-center justify-center flex-shrink-0">
              <i data-lucide="x" class="w-2.5 h-2.5 text-white"></i>
            </div>
            <% } else { %>
            <div class="w-5 h-5 rounded-full bg-[var(--surface-2)] border border-[var(--border-default)] flex items-center justify-center flex-shrink-0">
              <div class="w-1.5 h-1.5 rounded-full bg-[var(--text-tertiary)]"></div>
            </div>
            <% } %>
            <% if (index < status.log.length - 1) { %>
            <div class="w-px flex-1 bg-[var(--border-default)] min-h-[12px]"></div>
            <% } %>
          </div>
          <div class="min-w-0 -mt-0.5">
            <p class="text-sm font-medium text-[var(--text-primary)]"><%= entry.status %></p>
            <p class="text-xs text-[var(--text-secondary)]"><%= entry.statusMessage %></p>
            <p class="text-xs text-[var(--text-tertiary)] mt-0.5"><%= new Date(entry.dateTime).toLocaleString() %></p>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Actions -->
  <div class="flex flex-col sm:flex-row gap-3">
    <% if (isQrReady) { %>
    <a href="/qrcode/<%= status.transactionId %>" class="flex-1 btn btn-primary">Download QR Code</a>
    <% } %>
    <button onclick="location.reload()" class="flex-1 btn btn-secondary">Refresh Status</button>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    showToast('eSIM purchased successfully!', 'success');
    history.replaceState(null, '', window.location.pathname);
  }

  var currentStatus = '<%= status.status %>';
  var pendingStates = ['pending', 'processing', 'installing', 'PENDING', 'AUTHORIZED', 'IN_PROGRESS'];
  if (pendingStates.includes(currentStatus)) {
    var count = 0;
    var timer = setInterval(function() {
      count++;
      if (count >= 10) { clearInterval(timer); return; }
      window.location.reload();
    }, 30000);
  }
});
</script>

<%- include('partials/footer') %>
