<%- include('partials/header', {title: 'Forgot Password', user: null}) %>

    <div class="card p-7">
      <div class="text-center mb-6">
        <div class="w-12 h-12 rounded-xl bg-[var(--brand-light)] flex items-center justify-center mx-auto mb-4">
          <i data-lucide="key" class="w-6 h-6 text-[var(--brand-primary)]"></i>
        </div>
        <h1 class="text-xl font-bold text-[var(--text-primary)]">Forgot Password</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1.5">Enter your email to receive a reset link</p>
      </div>

      <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success mb-5">
        <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
        If an account exists with that email, a reset link has been sent.
      </div>
      <% } %>

      <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <div class="alert alert-error mb-5">
        <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
        <div class="space-y-1">
          <% errors.forEach(function(err) { %><p><%= err.msg || err %></p><% }) %>
        </div>
      </div>
      <% } %>

      <form method="post" action="/auth/forgot-password" class="space-y-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div>
          <label for="fp-email" class="input-label">Email address</label>
          <div class="input-icon-wrapper">
            <i data-lucide="mail" class="input-icon w-4 h-4"></i>
            <input type="email" id="fp-email" name="email" required placeholder="your@email.com" class="input">
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">Send Reset Link</button>
      </form>
    </div>

    <p class="mt-5 text-center text-sm text-[var(--text-tertiary)]">
      Remember your password? <a href="/auth/login" class="font-semibold text-[var(--brand-primary)] hover:underline">Sign in</a>
    </p>

<%- include('partials/footer') %>
