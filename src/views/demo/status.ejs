<div class="v2-content">

  <!-- Status Banner -->
  <div class="v2-banner v2-banner-done v2-anim">
    <div class="v2-banner-icon v2-banner-icon-done">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
    </div>
    <div>
      <div class="v2-banner-title" style="color: var(--color-success);">Aktif</div>
      <div class="v2-banner-message">eSIM basariyla yuklendi ve kullanima hazir</div>
    </div>
  </div>

  <!-- Detail Grid -->
  <div class="v2-details">
    <div class="v2-detail v2-anim">
      <div class="v2-detail-label">Ulke</div>
      <div class="v2-detail-value">🇹🇷 <%= purchase.country %></div>
    </div>
    <div class="v2-detail v2-anim">
      <div class="v2-detail-label">Data</div>
      <div class="v2-detail-value"><%= purchase.data %></div>
    </div>
    <div class="v2-detail v2-anim">
      <div class="v2-detail-label">Sure</div>
      <div class="v2-detail-value"><%= purchase.duration %></div>
    </div>
    <div class="v2-detail v2-anim">
      <div class="v2-detail-label">Ag Tipi</div>
      <div class="v2-detail-value"><%= purchase.network %></div>
    </div>
    <div class="v2-detail v2-anim">
      <div class="v2-detail-label">ICCID</div>
      <div class="v2-detail-value" style="font-family:'SF Mono','Fira Code',monospace;font-size:12px;"><%= purchase.iccid %></div>
    </div>
    <div class="v2-detail v2-anim">
      <div class="v2-detail-label">Satin Alma</div>
      <div class="v2-detail-value"><%= purchase.date %></div>
    </div>
  </div>

  <!-- Progress Card -->
  <div class="v2-progress v2-anim">
    <div class="v2-progress-header">
      <div class="v2-progress-title">Data Kullanimi</div>
      <div class="v2-progress-value">3.2 GB / 10 GB</div>
    </div>
    <div class="v2-progress-bar">
      <div class="v2-progress-fill" style="width: 32%;"></div>
    </div>
    <div class="v2-progress-label">Son kullanma: 25 Nisan 2026</div>
  </div>

  <!-- Actions -->
  <div class="v2-actions v2-anim">
    <a href="/demo/qrcode" class="v2-btn v2-btn-primary">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="5" height="5" x="3" y="3" rx="1"/><rect width="5" height="5" x="16" y="3" rx="1"/><rect width="5" height="5" x="3" y="16" rx="1"/><path d="M21 16h-3a2 2 0 0 0-2 2v3"/><path d="M21 21v.01"/><path d="M12 7v3a2 2 0 0 1-2 2H7"/><path d="M3 12h.01"/><path d="M12 3h.01"/><path d="M12 16v.01"/><path d="M16 12h1"/><path d="M21 12v.01"/><path d="M12 21v-1"/></svg>
      QR Kodu Goster
    </a>
    <a href="#" class="v2-btn v2-btn-secondary">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      Top-up
    </a>
  </div>

  <!-- Timeline -->
  <div class="v2-timeline v2-anim">
    <div class="v2-timeline-title">Aktivite</div>

    <div class="v2-timeline-item">
      <div class="v2-timeline-dot v2-timeline-dot-success">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <div class="v2-timeline-content">
        <div class="v2-timeline-text">eSIM aktif edildi</div>
        <div class="v2-timeline-time">9 Nisan 2026, 10:32</div>
      </div>
    </div>

    <div class="v2-timeline-item">
      <div class="v2-timeline-dot v2-timeline-dot-success">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <div class="v2-timeline-content">
        <div class="v2-timeline-text">eSIM cihaza yuklendi</div>
        <div class="v2-timeline-time">9 Nisan 2026, 10:28</div>
      </div>
    </div>

    <div class="v2-timeline-item">
      <div class="v2-timeline-dot v2-timeline-dot-success">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <div class="v2-timeline-content">
        <div class="v2-timeline-text">Odeme tamamlandi — $4.99</div>
        <div class="v2-timeline-time">9 Nisan 2026, 10:25</div>
      </div>
    </div>

    <div class="v2-timeline-item">
      <div class="v2-timeline-dot v2-timeline-dot-warning">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
      </div>
      <div class="v2-timeline-content">
        <div class="v2-timeline-text">Siparis olusturuldu</div>
        <div class="v2-timeline-time">9 Nisan 2026, 10:24</div>
      </div>
    </div>
  </div>

</div>
