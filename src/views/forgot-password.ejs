<%- include('partials/header', {title: 'Forgot Password', user: null}) %>

    <div class="card p-6">
      <div class="text-center mb-6">
        <h1 class="text-xl font-semibold text-[var(--text-primary)]">Forgot Password</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1">Enter your email to receive a reset link</p>
      </div>

      <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success mb-4">
        <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
        If an account exists with that email, a reset link has been sent.
      </div>
      <% } %>

      <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <div class="alert alert-error mb-4">
        <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
        <div class="space-y-1">
          <% errors.forEach(function(err) { %><p><%= err.msg || err %></p><% }) %>
        </div>
      </div>
      <% } %>

      <form method="post" action="/auth/forgot-password" class="space-y-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div>
          <label class="input-label">Email address</label>
          <input type="email" name="email" required placeholder="your@email.com" class="input">
        </div>
        <button type="submit" class="btn btn-primary btn-block">Send Reset Link</button>
      </form>
    </div>

    <p class="mt-4 text-center text-sm text-[var(--text-tertiary)]">
      Remember your password? <a href="/auth/login" class="font-medium text-[var(--brand-primary)]">Sign in</a>
    </p>

<%- include('partials/footer') %>
