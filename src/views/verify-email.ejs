<%- include('partials/header', {title: 'Verify Email', user: locals.user}) %>

<% if (typeof user !== 'undefined' && user) { %>
<div class="max-w-sm mx-auto text-center py-8">
<% } %>

    <div class="card p-7 text-center">
      <% if (success) { %>
      <div class="w-16 h-16 rounded-2xl bg-[var(--success-light)] flex items-center justify-center mx-auto mb-5">
        <i data-lucide="check-circle" class="w-8 h-8 text-[var(--success)]"></i>
      </div>
      <h1 class="text-xl font-bold text-[var(--text-primary)] mb-2">Email Verified!</h1>
      <p class="text-sm text-[var(--text-secondary)] mb-6"><%= message %></p>
      <a href="/offers" class="btn btn-primary btn-lg">
        <i data-lucide="globe" class="w-4 h-4"></i>
        Browse Data Plans
      </a>
      <% } else { %>
      <div class="w-16 h-16 rounded-2xl bg-[var(--danger-light)] flex items-center justify-center mx-auto mb-5">
        <i data-lucide="x-circle" class="w-8 h-8 text-[var(--danger)]"></i>
      </div>
      <h1 class="text-xl font-bold text-[var(--text-primary)] mb-2">Verification Failed</h1>
      <p class="text-sm text-[var(--text-secondary)] mb-6"><%= message %></p>
      <a href="/auth/login" class="btn btn-secondary">Go to Login</a>
      <% } %>
    </div>

<% if (typeof user !== 'undefined' && user) { %>
</div>
<% } %>

<%- include('partials/footer') %>
