<%- include('partials/header', {title: 'Profile', user: locals.user}) %>

<div class="mb-8 fade-up">
  <div class="flex items-center gap-4">
    <div class="avatar avatar-lg" style="background: linear-gradient(135deg, #4f46e5, #7c3aed);">
      <%= (user.displayName || user.username).charAt(0).toUpperCase() %>
    </div>
    <div>
      <h1 class="text-page-title"><%= user.displayName || user.username %></h1>
      <p class="text-subtitle">@<%= user.username %></p>
    </div>
  </div>
</div>

<% if (typeof user !== 'undefined' && user && user.mustChangePassword) { %>
<div class="alert alert-error mb-6">
  <i data-lucide="shield-alert" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
  <div>
    <p class="font-semibold text-sm">Security Warning: Default Password Detected</p>
    <p class="mt-1 text-sm opacity-80">You are using the default password. Please change it immediately.</p>
  </div>
</div>
<% } %>

<% if (typeof success !== 'undefined' && success) { %>
<div class="alert alert-success mb-6">
  <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
  <%= success %>
</div>
<% } %>

<% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
<div class="alert alert-error mb-6">
  <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
  <div class="space-y-1">
    <% errors.forEach(function(err) { %><p><%= err.msg || err %></p><% }) %>
  </div>
</div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Account Info -->
  <div class="section-card fade-up stagger-1">
    <div class="section-card-title">Account Information</div>
    <form method="post" action="/profile" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div>
        <label for="prof-username" class="input-label">Username</label>
        <input type="text" id="prof-username" value="<%= user.username %>" disabled class="input">
      </div>
      <div>
        <label for="prof-displayname" class="input-label">Display Name</label>
        <input type="text" id="prof-displayname" name="displayName" value="<%= user.displayName || '' %>" maxlength="50" placeholder="Your display name" class="input">
      </div>
      <div>
        <label for="prof-email" class="input-label">Email</label>
        <input type="email" id="prof-email" name="email" value="<%= user.email || '' %>" placeholder="your@email.com" class="input">
      </div>
      <div>
        <label for="prof-phone" class="input-label">Phone</label>
        <input type="text" id="prof-phone" name="phone" value="<%= user.phone || '' %>" placeholder="+90 555 123 4567" class="input">
      </div>
      <button type="submit" class="btn btn-primary">
        <i data-lucide="save" class="w-4 h-4"></i>
        Save Changes
      </button>
    </form>
  </div>

  <!-- Change Password -->
  <div class="section-card fade-up stagger-2">
    <div class="section-card-title">Change Password</div>
    <form method="post" action="/profile/password" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div>
        <label for="prof-curpw" class="input-label">Current Password</label>
        <input type="password" id="prof-curpw" name="currentPassword" required class="input">
      </div>
      <div>
        <label for="prof-newpw" class="input-label">New Password</label>
        <input type="password" id="prof-newpw" name="newPassword" required minlength="8" class="input">
      </div>
      <div>
        <label for="prof-confirmpw" class="input-label">Confirm Password</label>
        <input type="password" id="prof-confirmpw" name="confirmPassword" required minlength="8" class="input">
      </div>
      <button type="submit" class="btn btn-secondary">
        <i data-lucide="key" class="w-4 h-4"></i>
        Update Password
      </button>
    </form>
  </div>

  <!-- Preferences -->
  <div class="section-card fade-up stagger-3">
    <div class="section-card-title">Preferences</div>
    <div class="flex items-center justify-between">
      <div>
        <div class="text-sm font-semibold" style="color: var(--text-primary);">Theme</div>
        <div class="text-xs" style="color: var(--text-tertiary);">Adjust interface appearance</div>
      </div>
      <form method="post" action="/profile" class="flex items-center gap-2">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="displayName" value="<%= user.displayName || '' %>">
        <input type="hidden" name="email" value="<%= user.email || '' %>">
        <input type="hidden" name="phone" value="<%= user.phone || '' %>">
        <select id="prof-theme" name="theme" class="input" onchange="this.form.submit()">
          <option value="light" <%= user.theme === 'light' ? 'selected' : '' %>>Light</option>
          <option value="dark" <%= user.theme === 'dark' ? 'selected' : '' %>>Dark</option>
        </select>
      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
