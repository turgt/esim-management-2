<%- include('../partials/header', {title: 'eSIM Detail', user: locals.user}) %>

<div class="mb-6">
  <div class="breadcrumb">
    <a href="/admin/dashboard">Dashboard</a>
    <span class="separator"><i data-lucide="chevron-right" class="w-3.5 h-3.5"></i></span>
    <a href="/admin/esims">All eSIMs</a>
    <span class="separator"><i data-lucide="chevron-right" class="w-3.5 h-3.5"></i></span>
    <span class="text-[var(--text-primary)] font-medium">#<%= esim.id %></span>
  </div>
  <div class="flex items-center gap-3">
    <h1 class="text-page-title">eSIM #<%= esim.id %></h1>
    <% if (esim.status === 'completed') { %>
    <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Active</span>
    <% } else if (esim.status === 'pending') { %>
    <span class="badge badge-warning"><span class="badge-dot bg-amber-500"></span>Pending</span>
    <% } else { %>
    <span class="badge badge-danger"><%= esim.status %></span>
    <% } %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <!-- Main Info -->
    <div class="card">
      <div class="card-header">
        <h2>Details</h2>
      </div>
      <div class="card-body detail-grid grid-cols-2">
        <div class="detail-item">
          <div class="detail-label">ICCID</div>
          <div class="detail-value font-mono text-xs flex items-center gap-1">
            <%= esim.iccid || 'N/A' %>
            <% if (esim.iccid) { %>
            <button onclick="copyToClipboard('<%= esim.iccid %>', this)" class="copy-btn"><i data-lucide="copy" class="w-3 h-3"></i></button>
            <% } %>
          </div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Owner</div>
          <div class="detail-value"><%= esim.owner ? esim.owner.username : '-' %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Country</div>
          <div class="detail-value"><%= esim.country || '-' %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Data</div>
          <div class="detail-value"><%= esim.dataGB ? esim.dataGB + ' GB' : '-' %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Duration</div>
          <div class="detail-value"><%= esim.durationDays ? esim.durationDays + ' days' : '-' %></div>
        </div>
        <div class="detail-item">
          <div class="detail-label">Transaction ID</div>
          <div class="detail-value font-mono text-xs flex items-center gap-1 truncate">
            <%= esim.transactionId %>
            <button onclick="copyToClipboard('<%= esim.transactionId %>', this)" class="copy-btn"><i data-lucide="copy" class="w-3 h-3"></i></button>
          </div>
        </div>
        <% if (esim.assigner) { %>
        <div class="detail-item">
          <div class="detail-label">Assigned By</div>
          <div class="detail-value"><%= esim.assigner.username %></div>
        </div>
        <% } %>
        <% if (esim.priceAmount) { %>
        <div class="detail-item">
          <div class="detail-label">Price</div>
          <div class="detail-value"><%= esim.priceAmount %> <%= esim.priceCurrency || 'USD' %></div>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Activation -->
    <% if (esim.smdpAddress || esim.activationCode) { %>
    <div class="card">
      <div class="card-header">
        <h2>Activation Details</h2>
      </div>
      <div class="card-body space-y-3">
        <% if (esim.smdpAddress) { %>
        <div class="detail-item">
          <div class="detail-label">SM-DP+ Address</div>
          <div class="detail-value font-mono text-xs break-all flex items-center gap-1">
            <%= esim.smdpAddress %>
            <button onclick="copyToClipboard('<%= esim.smdpAddress %>', this)" class="copy-btn"><i data-lucide="copy" class="w-3 h-3"></i></button>
          </div>
        </div>
        <% } %>
        <% if (esim.activationCode) { %>
        <div class="detail-item">
          <div class="detail-label">Activation Code</div>
          <div class="detail-value font-mono text-xs break-all flex items-center gap-1">
            <%= esim.activationCode %>
            <button onclick="copyToClipboard('<%= esim.activationCode %>', this)" class="copy-btn"><i data-lucide="copy" class="w-3 h-3"></i></button>
          </div>
        </div>
        <% } %>
      </div>
    </div>
    <% } %>

    <!-- Active Plans -->
    <% if (typeof activePlans !== 'undefined' && activePlans && activePlans.list && activePlans.list.length > 0) { %>
    <div class="table-container">
      <div class="card-header">
        <h2>Active Plans</h2>
      </div>
      <table class="table">
        <thead><tr>
          <th>Offer</th>
          <th>Data</th>
          <th>Status</th>
          <th>Period</th>
        </tr></thead>
        <tbody>
          <% activePlans.list.forEach(function(plan) { %>
          <tr>
            <td class="font-mono text-xs"><%= plan.offerId %></td>
            <td>
              <% if (plan.unlimited) { %>
              <span class="text-sm font-semibold">Unlimited</span>
              <% } else { %>
              <span class="text-sm font-semibold"><%= plan.remainingDataGB != null ? plan.remainingDataGB.toFixed(2) : '-' %></span>
              <span class="text-xs text-[var(--text-tertiary)]"> / <%= plan.initialDataGB || '-' %> GB</span>
              <% } %>
            </td>
            <td>
              <% if (plan.status === 'ACTIVE') { %>
              <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Active</span>
              <% } else if (plan.status === 'QUEUED') { %>
              <span class="badge badge-warning"><span class="badge-dot bg-amber-500"></span>Queued</span>
              <% } else { %>
              <span class="badge"><%= plan.status %></span>
              <% } %>
            </td>
            <td class="text-xs text-[var(--text-tertiary)]">
              <% if (plan.startAt) { %><%= new Date(plan.startAt).toLocaleDateString() %><% } %>
              <% if (plan.startAt && plan.endAt) { %> — <% } %>
              <% if (plan.endAt) { %><%= new Date(plan.endAt).toLocaleDateString() %><% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- Usage -->
    <% if (typeof usage !== 'undefined' && usage) { %>
    <div class="card">
      <div class="card-header">
        <h2>Usage Information</h2>
      </div>
      <div class="card-body">
        <pre class="text-xs font-mono bg-[var(--surface-inset)] p-4 rounded-lg overflow-x-auto text-[var(--text-secondary)]"><%= JSON.stringify(usage, null, 2) %></pre>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Actions -->
    <div class="card p-5 space-y-3">
      <h3 class="text-section-title">Actions</h3>
      <% if (esim.iccid) { %>
      <a href="/admin/topup/<%= esim.id %>" class="btn btn-primary btn-block">
        <i data-lucide="plus-circle" class="w-4 h-4"></i>
        Top-up
      </a>
      <% } %>
      <a href="/status/<%= esim.transactionId %>" class="btn btn-secondary btn-block">
        <i data-lucide="external-link" class="w-4 h-4"></i>
        View Status
      </a>
    </div>

    <!-- Top-up History -->
    <% if (typeof topups !== 'undefined' && topups && topups.length > 0) { %>
    <div class="card">
      <div class="card-header">
        <h3>Top-up History</h3>
      </div>
      <div class="p-4 space-y-2">
        <% topups.forEach(function(t) { %>
        <div class="flex items-center justify-between text-xs p-3 rounded-lg bg-[var(--surface-1)] border border-[var(--border-subtle)]">
          <span class="font-mono text-[var(--text-secondary)] truncate max-w-[120px]"><%= t.offerId %></span>
          <span class="capitalize text-[var(--text-primary)] font-semibold"><%= t.status %></span>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
