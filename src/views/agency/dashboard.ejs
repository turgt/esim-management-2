<%- include('../partials/header', {title: 'Agency Dashboard', user: locals.user}) %>

<div class="mb-8">
  <p class="text-sm text-[var(--text-secondary)] mb-1">Hos Geldiniz</p>
  <h1 class="text-page-title"><%= locals.agency ? locals.agency.name : 'Agency Panel' %></h1>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="stat-card">
    <div class="stat-icon bg-[var(--brand-light)]">
      <i data-lucide="file-text" class="w-5 h-5 text-[var(--brand-primary)]"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Total Contracts</p>
      <p class="stat-value"><%= typeof totalContracts !== 'undefined' ? totalContracts : 0 %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-sky-50 dark:bg-sky-500/10">
      <i data-lucide="calendar" class="w-5 h-5 text-sky-600 dark:text-sky-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Bu Hafta</p>
      <p class="stat-value text-sky-600 dark:text-sky-400"><%= typeof thisWeekBookings !== 'undefined' ? thisWeekBookings : 0 %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-amber-50 dark:bg-amber-500/10">
      <i data-lucide="clock" class="w-5 h-5 text-amber-600 dark:text-amber-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Yaklasan</p>
      <p class="stat-value text-amber-600 dark:text-amber-400"><%= typeof upcomingBookings !== 'undefined' ? (Array.isArray(upcomingBookings) ? upcomingBookings.length : upcomingBookings) : 0 %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-emerald-50 dark:bg-emerald-500/10">
      <i data-lucide="file-check" class="w-5 h-5 text-emerald-600 dark:text-emerald-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Active Contracts</p>
      <p class="stat-value text-emerald-600 dark:text-emerald-400"><%= typeof activeContracts !== 'undefined' ? activeContracts : 0 %></p>
    </div>
  </div>
</div>

<div class="grid lg:grid-cols-2 gap-6">

  <!-- Active Contracts with Progress Bars -->
  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-[var(--text-primary)] flex items-center gap-2">
        <i data-lucide="file-text" class="w-4 h-4 text-[var(--text-tertiary)]"></i>
        Active Contractslar
      </h2>
      <a href="/agency/contracts" class="text-sm text-[var(--brand-primary)] hover:underline">Tümünü gör</a>
    </div>
    <% if (typeof contractList !== 'undefined' && contractList && contractList.length > 0) { %>
    <div class="space-y-3">
      <% contractList.forEach(function(contract) { %>
      <div class="card p-4">
        <div class="flex items-start justify-between mb-2">
          <div class="flex-1 min-w-0">
            <p class="font-medium text-[var(--text-primary)] truncate">
              <%= contract.package ? contract.package.title : 'Contract #' + contract.id %>
            </p>
            <% if (contract.package) { %>
            <p class="text-xs text-[var(--text-tertiary)]">
              <%= contract.package.data %> / <%= contract.package.day %> days &bull; <%= contract.package.countryCode %>
            </p>
            <% } %>
          </div>
          <% if (contract.status === 'active') { %>
          <span class="badge badge-success ml-2 flex-shrink-0"><span class="badge-dot bg-emerald-500"></span>Active</span>
          <% } else { %>
          <span class="badge badge-neutral ml-2 flex-shrink-0"><span class="badge-dot bg-gray-400"></span><%= contract.status %></span>
          <% } %>
        </div>
        <div class="flex items-center justify-between text-xs text-[var(--text-tertiary)] mb-1.5">
          <span><%= contract.usedQuantity %> / <%= contract.quantity %> kullanildi</span>
          <% const pct = contract.quantity > 0 ? Math.round((contract.usedQuantity / contract.quantity) * 100) : 0; %>
          <span class="font-medium <%= pct >= 90 ? 'text-rose-500' : pct >= 70 ? 'text-amber-500' : 'text-emerald-600 dark:text-emerald-400' %>">%<%= pct %></span>
        </div>
        <div class="w-full h-2 bg-[var(--bg-tertiary)] rounded-full">
          <div class="h-2 rounded-full transition-all <%= pct >= 90 ? 'bg-rose-500' : pct >= 70 ? 'bg-amber-500' : 'bg-emerald-500' %>" style="width: <%= pct %>%"></div>
        </div>
        <p class="text-xs text-[var(--text-tertiary)] mt-2">
          Ends: <%= new Date(contract.contractEndAt).toLocaleDateString('en-GB') %>
        </p>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="card p-8 text-center">
      <i data-lucide="file-text" class="w-8 h-8 mx-auto mb-2 opacity-40 text-[var(--text-tertiary)]"></i>
      <p class="text-sm text-[var(--text-tertiary)]">No active contracts found</p>
    </div>
    <% } %>
  </div>

  <!-- Upcoming Activations -->
  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-[var(--text-primary)] flex items-center gap-2">
        <i data-lucide="clock" class="w-4 h-4 text-[var(--text-tertiary)]"></i>
        Yaklasan Aktivasyonlar
      </h2>
      <a href="/agency/bookings" class="text-sm text-[var(--brand-primary)] hover:underline">Tümünü gör</a>
    </div>
    <% if (typeof upcomingBookings !== 'undefined' && Array.isArray(upcomingBookings) && upcomingBookings.length > 0) { %>
    <div class="space-y-3">
      <% upcomingBookings.forEach(function(booking) { %>
      <a href="/agency/bookings/<%= booking.id %>" class="card p-4 flex items-center gap-4 hover:shadow-md transition-shadow block">
        <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-amber-50 dark:bg-amber-500/10 flex items-center justify-center">
          <i data-lucide="user" class="w-5 h-5 text-amber-600 dark:text-amber-400"></i>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-medium text-[var(--text-primary)] truncate"><%= booking.travelerName %></p>
          <% if (booking.contract && booking.contract.package) { %>
          <p class="text-xs text-[var(--text-tertiary)] truncate"><%= booking.contract.package.title %></p>
          <% } %>
        </div>
        <div class="text-right flex-shrink-0">
          <p class="text-sm font-medium text-amber-600 dark:text-amber-400">
            <%= new Date(booking.dueDate).toLocaleDateString('en-GB') %>
          </p>
          <p class="text-xs text-[var(--text-tertiary)]">
            <%= new Date(booking.dueDate).toLocaleTimeString('tr-TR', {hour: '2-digit', minute: '2-digit'}) %>
          </p>
        </div>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <div class="card p-8 text-center">
      <i data-lucide="clock" class="w-8 h-8 mx-auto mb-2 opacity-40 text-[var(--text-tertiary)]"></i>
      <p class="text-sm text-[var(--text-tertiary)]">Yaklasan aktivasyon yok</p>
      <a href="/agency/bookings/new" class="text-sm text-[var(--brand-primary)] hover:underline mt-1 inline-block">Create a new booking</a>
    </div>
    <% } %>
  </div>

</div>

<%- include('../partials/footer') %>
