      <span>Users</span>
    </a>
    <a href="/admin/esims" class="<%= (title === 'All Datas' || title === 'Data Detail' || title === 'Assign Data' || (typeof title === 'string' && (title.indexOf('Top-up') !== -1 || title.indexOf('Top Up') !== -1))) ? 'active' : '' %>">
