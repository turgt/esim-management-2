<%- include('partials/header', {title: 'Login', user: null}) %>

    <p class="auth-brand-subtitle">Sign in to manage your eSIMs</p>

    <div class="card p-5 sm:p-7 fade-up">
      <div class="text-center mb-6">
        <h1 class="text-xl font-bold text-[var(--text-primary)]">Welcome back</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1.5">Sign in to manage your Datas</p>
      </div>

      <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success mb-5">
        <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
        <%= success %>
      </div>
      <% } %>

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error mb-5">
        <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
        <%= error %>
      </div>
      <% } %>

      <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <div class="alert alert-error mb-5">
        <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
        <div class="space-y-1">
          <% errors.forEach(function(err) { %>
          <p><%= err.msg || err %></p>
          <% }) %>
        </div>
      </div>
      <% } %>

      <form method="post" action="/auth/login" class="space-y-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div>
          <label for="username" class="input-label">Username or Email</label>
          <div class="input-icon-wrapper">
            <i data-lucide="user" class="input-icon w-4 h-4"></i>
            <input type="text" id="username" name="username" required autocomplete="username" placeholder="Enter your username or email" class="input">
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1">
            <label for="password" class="input-label mb-0">Password</label>
            <a href="/auth/forgot-password" class="auth-forgot">Forgot password?</a>
          </div>
          <div class="input-icon-wrapper relative">
            <i data-lucide="lock" class="input-icon w-4 h-4"></i>
            <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="Enter your password" class="input !pr-10">
            <button type="button" onclick="togglePw()" class="absolute right-2.5 top-1/2 -translate-y-1/2 text-[var(--text-tertiary)] hover:text-[var(--text-primary)]" aria-label="Toggle password visibility">
              <i data-lucide="eye" class="w-4 h-4" id="pwEyeIcon"></i>
            </button>
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">Sign In</button>
      </form>
    </div>

    <p class="auth-footer">
      Don't have an account? <a href="/auth/register">Create account</a>
    </p>

<script>
function togglePw() {
  var input = document.getElementById('password');
  var icon = document.getElementById('pwEyeIcon');
  if (input.type === 'password') { input.type = 'text'; icon.setAttribute('data-lucide', 'eye-off'); }
  else { input.type = 'password'; icon.setAttribute('data-lucide', 'eye'); }
  lucide.createIcons();
}
</script>

<%- include('partials/footer') %>
