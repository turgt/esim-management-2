<div class="demo-content" style="padding-bottom:40px;">
  <h1 class="demo-page-title demo-animate-in">Fatura Detayı</h1>

  <!-- Receipt Card -->
  <div class="demo-card demo-animate-in" style="padding:24px;">

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <div class="demo-gradient-text" style="font-family:var(--font-heading);font-size:20px;font-weight:800;">DataPatch</div>
      <div style="font-size:12px;color:var(--color-text-muted);">Fatura No: <strong style="color:var(--color-text);">#DP-2026-0042</strong></div>
    </div>

    <!-- Divider -->
    <div style="height:1px;background:var(--color-border);margin-bottom:16px;"></div>

    <!-- Detail Grid -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
      <div>
        <div style="font-size:10px;text-transform:uppercase;font-weight:600;color:var(--color-text-muted);letter-spacing:0.5px;margin-bottom:4px;">Tarih</div>
        <div style="font-size:14px;font-weight:600;color:var(--color-text);">9 Nisan 2026</div>
      </div>
      <div>
        <div style="font-size:10px;text-transform:uppercase;font-weight:600;color:var(--color-text-muted);letter-spacing:0.5px;margin-bottom:4px;">Durum</div>
        <span class="demo-badge" style="background:var(--color-success-bg);color:var(--color-success);padding:4px 10px;border-radius:var(--radius-full);font-size:11px;">Tamamlandı</span>
      </div>
      <div style="grid-column:1/-1;">
        <div style="font-size:10px;text-transform:uppercase;font-weight:600;color:var(--color-text-muted);letter-spacing:0.5px;margin-bottom:4px;">Ödeme Yöntemi</div>
        <div style="font-size:14px;font-weight:600;color:var(--color-text);">Visa &bull;&bull;&bull;&bull; 4242</div>
      </div>
    </div>

    <!-- Divider -->
    <div style="height:1px;background:var(--color-border);margin-bottom:16px;"></div>

    <!-- Line Items -->
    <div style="margin-bottom:16px;">
      <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;">
        <div>
          <div style="font-size:14px;font-weight:600;color:var(--color-text);">Türkiye 10GB eSIM</div>
          <div style="font-size:12px;color:var(--color-text-muted);">30 gün &bull; 5G</div>
        </div>
        <div style="font-size:14px;font-weight:600;color:var(--color-text);">$4.16</div>
      </div>
    </div>

    <!-- Divider -->
    <div style="height:1px;background:var(--color-border);margin-bottom:16px;"></div>

    <!-- Totals -->
    <div style="display:flex;flex-direction:column;gap:8px;">
      <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--color-text-secondary);">
        <span>Ara Toplam</span>
        <span>$4.16</span>
      </div>
      <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--color-text-secondary);">
        <span>KDV (%20)</span>
        <span>$0.83</span>
      </div>
      <div style="height:1px;background:var(--color-border);margin:4px 0;"></div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span style="font-family:var(--font-heading);font-size:16px;font-weight:700;">Toplam</span>
        <span class="demo-gradient-text" style="font-family:var(--font-heading);font-size:22px;font-weight:800;">$4.99</span>
      </div>
    </div>
  </div>

  <!-- Download Button -->
  <div class="demo-animate-in" style="margin-top:20px;">
    <button class="demo-btn demo-btn-outline demo-btn-block">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      İndir
    </button>
  </div>
</div>
