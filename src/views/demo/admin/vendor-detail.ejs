<%
  const v = locals.vendor || {
    name: 'Zendit',
    apiUrl: 'https://api.zendit.io/v1',
    apiStatus: 'connected',
    lastConnection: '2026-04-09 15:42',
    esimCount: 245,
    commission: '%12',
    totalSales: 245,
    revenue: '$6,240',
    activeEsims: 198
  };
%>

<div class="v2-page-header" style="display:flex;align-items:center;gap:12px;">
  <div class="v2-page-title" style="margin-bottom:0;"><%= v.name %></div>
  <% if (v.apiStatus === 'connected') { %>
    <span class="v2-badge v2-badge-success">Bagli</span>
  <% } else { %>
    <span class="v2-badge v2-badge-danger">Bagli Degil</span>
  <% } %>
</div>

<!-- Detail Grid -->
<div class="v2-details v2-anim">
  <div class="v2-detail">
    <div class="v2-detail-label">Vendor Adi</div>
    <div class="v2-detail-value"><%= v.name %></div>
  </div>
  <div class="v2-detail">
    <div class="v2-detail-label">API URL</div>
    <div class="v2-detail-value v2-detail-mono"><%= v.apiUrl %></div>
  </div>
  <div class="v2-detail">
    <div class="v2-detail-label">API Durumu</div>
    <div class="v2-detail-value">
      <% if (v.apiStatus === 'connected') { %>
        <span class="v2-vendor-status"><span class="v2-dot v2-dot-ok"></span> Bagli</span>
      <% } else { %>
        <span class="v2-vendor-status"><span class="v2-dot v2-dot-no"></span> Bagli Degil</span>
      <% } %>
    </div>
  </div>
  <div class="v2-detail">
    <div class="v2-detail-label">Son Baglanti</div>
    <div class="v2-detail-value"><%= v.lastConnection %></div>
  </div>
  <div class="v2-detail">
    <div class="v2-detail-label">Toplam eSIM</div>
    <div class="v2-detail-value"><%= v.esimCount %></div>
  </div>
  <div class="v2-detail">
    <div class="v2-detail-label">Komisyon Orani</div>
    <div class="v2-detail-value"><%= v.commission %></div>
  </div>
</div>

<!-- Sales Stats -->
<div class="v2-stats v2-anim" style="grid-template-columns: repeat(3, 1fr);">
  <div class="v2-stat">
    <div class="v2-stat-icon v2-stat-icon-orange">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
    </div>
    <div class="v2-stat-label">Satis</div>
    <div class="v2-stat-value"><%= v.totalSales %></div>
  </div>
  <div class="v2-stat">
    <div class="v2-stat-icon v2-stat-icon-green">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    </div>
    <div class="v2-stat-label">Gelir</div>
    <div class="v2-stat-value"><%= v.revenue %></div>
  </div>
  <div class="v2-stat">
    <div class="v2-stat-icon v2-stat-icon-green">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></svg>
    </div>
    <div class="v2-stat-label">Aktif eSIM</div>
    <div class="v2-stat-value"><%= v.activeEsims %></div>
  </div>
</div>

<!-- Actions -->
<div class="v2-actions v2-anim">
  <a href="/demo/admin/vendors/1/edit" class="v2-btn v2-btn-primary">Duzenle</a>
</div>
