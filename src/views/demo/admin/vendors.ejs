<div class="v2-page-header" style="display:flex;align-items:center;justify-content:space-between;">
  <div class="v2-page-title" style="margin-bottom:0;">Vendorlar</div>
  <a href="/demo/admin/vendors/new" class="v2-btn v2-btn-primary v2-btn-sm">Yeni Vendor Ekle</a>
</div>

<!-- Vendors Table -->
<div class="v2-table-wrap v2-anim">
  <div class="v2-table-responsive">
    <table class="v2-table">
      <thead>
        <tr>
          <th>Vendor</th>
          <th>API Durumu</th>
          <th>eSIM Sayisi</th>
          <th>Komisyon</th>
          <th>Islemler</th>
        </tr>
      </thead>
      <tbody>
        <% const defaultVendors = [
          { id: 1, name: 'Zendit', apiStatus: 'connected', esimCount: 245, commission: '%12' },
          { id: 2, name: 'Airalo', apiStatus: 'connected', esimCount: 89, commission: '%15' },
          { id: 3, name: 'eSIMGo', apiStatus: 'disconnected', esimCount: 8, commission: '%10' },
          { id: 4, name: 'RedteaGo', apiStatus: 'connected', esimCount: 56, commission: '%18' }
        ]; %>
        <% const vendorList = locals.vendors || defaultVendors; %>
        <% vendorList.forEach(function(v) { %>
          <tr>
            <td><%= v.name %></td>
            <td>
              <% if (v.apiStatus === 'connected') { %>
                <span class="v2-vendor-status"><span class="v2-dot v2-dot-ok"></span> Bagli</span>
              <% } else { %>
                <span class="v2-vendor-status"><span class="v2-dot v2-dot-no"></span> Bagli Degil</span>
              <% } %>
            </td>
            <td><%= v.esimCount %></td>
            <td><%= v.commission %></td>
            <td>
              <a href="/demo/admin/vendors/<%= v.id %>" class="v2-table-link">Detay</a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
