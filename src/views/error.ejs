<%- include('partials/header', {title: 'Error', user: locals.user}) %>

<% if (typeof user !== 'undefined' && user) { %>
<div class="flex items-center justify-center" style="min-height: calc(100vh - 16rem);">
<% } %>

  <div class="w-full max-w-md text-center">
    <div class="card p-8">
      <div class="w-16 h-16 rounded-2xl bg-[var(--danger-light)] flex items-center justify-center mx-auto mb-5">
        <i data-lucide="alert-triangle" class="w-8 h-8 text-[var(--danger)]"></i>
      </div>

      <div class="mb-1 text-5xl font-black text-[var(--text-primary)] opacity-10">
        <%= typeof title !== 'undefined' && title.match && title.match(/\d{3}/) ? title.match(/\d{3}/)[0] : '!' %>
      </div>

      <h1 class="text-xl font-bold text-[var(--text-primary)] mb-2"><%= typeof errorTitle !== 'undefined' ? errorTitle : 'Something went wrong' %></h1>
      <p class="text-sm text-[var(--text-secondary)] mb-6"><%= typeof errorMessage !== 'undefined' ? errorMessage : 'An unexpected error occurred' %></p>

      <div class="flex items-center justify-center gap-3">
        <button onclick="history.back()" class="btn btn-secondary">
          <i data-lucide="arrow-left" class="w-4 h-4"></i>
          Go Back
        </button>
        <a href="/" class="btn btn-primary">
          <i data-lucide="home" class="w-4 h-4"></i>
          Go Home
        </a>
      </div>
    </div>
  </div>

<% if (typeof user !== 'undefined' && user) { %>
</div>
<% } %>

<%- include('partials/footer') %>
