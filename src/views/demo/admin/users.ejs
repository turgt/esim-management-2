<div class="v2-page-header">
  <div class="v2-page-title">Kullanici Yonetimi</div>
</div>

<!-- Add User Form -->
<div class="v2-form-card v2-anim">
  <div class="v2-form-title">Yeni Kullanici Ekle</div>
  <form class="v2-form-grid" style="grid-template-columns: 1fr 1fr 1fr auto;">
    <div class="v2-input-group" style="margin-bottom:0;">
      <label class="v2-input-label">Kullanici Adi</label>
      <input type="text" class="v2-input" placeholder="Kullanici adi">
    </div>
    <div class="v2-input-group" style="margin-bottom:0;">
      <label class="v2-input-label">E-posta</label>
      <input type="email" class="v2-input" placeholder="E-posta adresi">
    </div>
    <div class="v2-input-group" style="margin-bottom:0;">
      <label class="v2-input-label">Sifre</label>
      <input type="password" class="v2-input" placeholder="Sifre">
    </div>
    <div style="display:flex;align-items:flex-end;">
      <button type="button" class="v2-btn v2-btn-primary v2-btn-sm">Ekle</button>
    </div>
  </form>
</div>

<!-- Search -->
<div class="v2-search-wrap v2-anim">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
  <input type="text" class="v2-search-input" placeholder="Kullanici ara...">
</div>

<!-- Users Table -->
<div class="v2-table-wrap v2-anim">
  <div class="v2-table-responsive">
    <table class="v2-table">
      <thead>
        <tr>
          <th>Kullanici</th>
          <th>E-posta</th>
          <th>Rol</th>
          <th>eSIM</th>
          <th>Durum</th>
          <th>Islemler</th>
        </tr>
      </thead>
      <tbody>
        <% const defaultUsers = [
          { username: 'admin', email: 'admin@datapatch.io', role: 'admin', esimCount: 5, status: 'active' },
          { username: 'ahmet.yilmaz', email: 'ahmet@example.com', role: 'user', esimCount: 3, status: 'active' },
          { username: 'elif.demir', email: 'elif@example.com', role: 'user', esimCount: 2, status: 'active' },
          { username: 'mehmet.kaya', email: 'mehmet@example.com', role: 'user', esimCount: 1, status: 'suspended' },
          { username: 'zeynep.arslan', email: 'zeynep@example.com', role: 'user', esimCount: 4, status: 'active' },
          { username: 'can.ozturk', email: 'can@example.com', role: 'user', esimCount: 0, status: 'active' }
        ]; %>
        <% const userList = locals.users || defaultUsers; %>
        <% userList.forEach(function(u) { %>
          <tr>
            <td><%= u.username %></td>
            <td><%= u.email %></td>
            <td>
              <% if (u.role === 'admin') { %>
                <span class="v2-badge v2-badge-info">Admin</span>
              <% } else { %>
                <span class="v2-badge v2-badge-neutral">User</span>
              <% } %>
            </td>
            <td><%= u.esimCount %></td>
            <td>
              <% if (u.status === 'active') { %>
                <span class="v2-badge v2-badge-success">Aktif</span>
              <% } else { %>
                <span class="v2-badge v2-badge-danger">Askiya Alindi</span>
              <% } %>
            </td>
            <td>
              <a href="/demo/admin/users/<%= u.username %>" class="v2-table-link">Duzenle</a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
