<%- include('partials/header', {title: 'QR Code', user: locals.user, backUrl: '/purchases'}) %>

<%
  // Vendor-aware field extraction
  var computedLpa = null;
  var computedMatchingId = null;
  var computedQrcodeUrl = null;
  var computedDirectAppleUrl = null;
  var smdpAddress = null;
  var activationCode = null;
  var planName = '';
  var dataMeta = '';

  if (typeof esim !== 'undefined' && esim) {
    planName = esim.planName || esim.offerId || '';
    dataMeta = [esim.dataAmount, esim.duration, esim.price].filter(Boolean).join(' · ');

    if (esim.vendor === 'airalo' && esim.vendorData) {
      computedLpa = (typeof lpa !== 'undefined' && lpa) || esim.vendorData.lpa || null;
      computedMatchingId = (typeof matchingId !== 'undefined' && matchingId) || esim.vendorData.matchingId || null;
      computedQrcodeUrl = (typeof qrcodeUrl !== 'undefined' && qrcodeUrl) || esim.vendorData.qrcodeUrl || esim.vendorData.qrcode || null;
      computedDirectAppleUrl = (typeof directAppleUrl !== 'undefined' && directAppleUrl) || esim.vendorData.directAppleUrl || null;
      smdpAddress = esim.vendorData.smdpAddress || null;
      activationCode = esim.vendorData.activationCode || computedMatchingId || null;
    } else if (esim.smdpAddress && esim.activationCode) {
      computedLpa = 'LPA:1$' + esim.smdpAddress + '$' + esim.activationCode;
      smdpAddress = esim.smdpAddress;
      activationCode = esim.activationCode;
    }
  }

  // Use computed values as fallbacks for template variables
  if (typeof qrcodeUrl === 'undefined' || !qrcodeUrl) qrcodeUrl = computedQrcodeUrl;
  if (typeof lpa === 'undefined' || !lpa) lpa = computedLpa;
  if (typeof matchingId === 'undefined' || !matchingId) matchingId = computedMatchingId;
  if (typeof directAppleUrl === 'undefined' || !directAppleUrl) directAppleUrl = computedDirectAppleUrl;

  // Determine QR image source
  var qrImageSrc = null;
  if (qrcodeUrl) {
    qrImageSrc = qrcodeUrl;
  } else if (typeof qr !== 'undefined' && qr && qr.imageBase64) {
    qrImageSrc = 'data:image/png;base64,' + qr.imageBase64;
  }

  // Build direct install links for Zendit
  var appleLink = null;
  var androidLink = null;
  if (smdpAddress && activationCode) {
    var lpaString = 'LPA:1$' + smdpAddress + '$' + activationCode;
    appleLink = 'https://esimsetup.apple.com/esim_qrcode_provisioning?carddata=' + lpaString;
    androidLink = 'https://esimsetup.android.com/esim_qrcode_provisioning?carddata=' + lpaString;
  }
  if (directAppleUrl) {
    appleLink = directAppleUrl;
  }
%>

<% if (qrImageSrc) { %>
<div class="max-w-lg mx-auto space-y-5">

  <!-- QR Card -->
  <div class="card text-center p-6 fade-up stagger-1">
    <div class="inline-block bg-white p-4 rounded-2xl shadow-lg border border-gray-100 mb-4">
      <img src="<%= qrImageSrc %>" alt="eSIM QR Code" class="qr-image w-56 h-56 mx-auto" style="max-width:224px;" />
    </div>
    <% if (planName) { %>
    <h2 class="text-lg font-bold text-[var(--text-primary)]"><%= planName %></h2>
    <% } %>
    <% if (dataMeta) { %>
    <p class="text-sm text-[var(--text-secondary)] mt-1"><%= dataMeta %></p>
    <% } %>
  </div>

  <!-- Tab Toggle -->
  <div class="tab-group fade-up stagger-2">
    <button class="tab-item active" onclick="switchTab('auto', this)">Auto Install</button>
    <button class="tab-item" onclick="switchTab('manual', this)">Manual Install</button>
  </div>

  <!-- Auto Install Tab -->
  <div id="tab-auto" class="fade-up stagger-3">
    <div class="card p-5 space-y-0">
      <% if (appleLink || androidLink) { %>
      <div id="directInstallBtns" style="display:none; margin-bottom:16px;">
        <% if (appleLink) { %>
        <a href="<%= appleLink %>" id="iosDirectBtn" class="btn btn-primary btn-lg btn-block mb-2" style="display:none;">
          <i data-lucide="smartphone" class="w-4 h-4"></i> Install on iPhone (iOS 17.4+)
        </a>
        <% } %>
        <% if (androidLink) { %>
        <a href="<%= androidLink %>" id="androidDirectBtn" class="btn btn-primary btn-lg btn-block mb-2" style="display:none;">
          <i data-lucide="smartphone" class="w-4 h-4"></i> Install on Android
        </a>
        <% } %>
        <p class="text-xs text-[var(--text-tertiary)] text-center mt-2" id="directNote"></p>
      </div>
      <script>
      (function(){
        var ua = navigator.userAgent || '';
        var isIOS = /iPhone|iPad|iPod/.test(ua);
        var isAndroid = /Android/.test(ua);
        var wrapper = document.getElementById('directInstallBtns');
        if (isIOS && document.getElementById('iosDirectBtn')) {
          wrapper.style.display = 'block';
          document.getElementById('iosDirectBtn').style.display = 'flex';
          document.getElementById('directNote').textContent = 'Requires iOS 17.4+ and Safari.';
        } else if (isAndroid && document.getElementById('androidDirectBtn')) {
          wrapper.style.display = 'block';
          document.getElementById('androidDirectBtn').style.display = 'flex';
          document.getElementById('directNote').textContent = 'Requires Android 10+ with Google Play services.';
        }
        if (typeof lucide !== 'undefined') lucide.createIcons();
      })();
      </script>
      <% } %>

      <ol class="space-y-4" role="list">
        <li class="stepper-item">
          <div class="stepper-number">1</div>
          <div class="pb-3">
            <p class="font-semibold text-[var(--text-primary)] text-sm">Open Settings</p>
            <p class="text-sm text-[var(--text-secondary)] mt-0.5">Go to <strong>Settings</strong> and navigate to <strong>Cellular</strong> (or Mobile Data).</p>
          </div>
        </li>
        <li class="stepper-item">
          <div class="stepper-number">2</div>
          <div class="pb-3">
            <p class="font-semibold text-[var(--text-primary)] text-sm">Add eSIM</p>
            <p class="text-sm text-[var(--text-secondary)] mt-0.5">Tap <strong>Add eSIM</strong>. Your device will open the QR code scanner automatically.</p>
          </div>
        </li>
        <li class="stepper-item">
          <div class="stepper-number">3</div>
          <div>
            <p class="font-semibold text-[var(--text-primary)] text-sm">Scan QR Code</p>
            <p class="text-sm text-[var(--text-secondary)] mt-0.5">Scan the <strong>QR code</strong> above. The eSIM will install in a few seconds.</p>
          </div>
        </li>
      </ol>
    </div>

    <!-- Platform buttons -->
    <div class="flex gap-3 mt-4">
      <a href="#" class="flex-1 btn btn-secondary btn-sm text-center" onclick="return false;">
        <i data-lucide="apple" class="w-4 h-4"></i> iOS Settings
      </a>
      <a href="#" class="flex-1 btn btn-secondary btn-sm text-center" onclick="return false;">
        <i data-lucide="smartphone" class="w-4 h-4"></i> Android Settings
      </a>
    </div>
  </div>

  <!-- Manual Install Tab -->
  <div id="tab-manual" style="display:none;" class="fade-up stagger-3">
    <div class="card p-5 space-y-4">
      <% if (smdpAddress || lpa) { %>
      <div>
        <div class="copy-field-label">SM-DP+ Address</div>
        <div class="copy-field">
          <div class="copy-field-value"><%= smdpAddress || (lpa ? lpa.split('$')[1] : 'N/A') %></div>
          <button class="copy-btn" onclick="copyToClipboard('<%= smdpAddress || (lpa ? lpa.split("$")[1] : "") %>', this)" title="Copy">
            <i data-lucide="copy" class="w-4 h-4"></i>
          </button>
        </div>
      </div>
      <% } %>

      <% if (activationCode || matchingId) { %>
      <div>
        <div class="copy-field-label">Activation Code</div>
        <div class="copy-field">
          <div class="copy-field-value"><%= activationCode || matchingId %></div>
          <button class="copy-btn" onclick="copyToClipboard('<%= activationCode || matchingId %>', this)" title="Copy">
            <i data-lucide="copy" class="w-4 h-4"></i>
          </button>
        </div>
      </div>
      <% } %>

      <% if (lpa && !smdpAddress && !activationCode) { %>
      <div>
        <div class="copy-field-label">LPA String</div>
        <div class="copy-field">
          <div class="copy-field-value"><%= lpa %></div>
          <button class="copy-btn" onclick="copyToClipboard('<%= lpa %>', this)" title="Copy">
            <i data-lucide="copy" class="w-4 h-4"></i>
          </button>
        </div>
      </div>
      <% } %>

      <ol class="space-y-4 mt-2" role="list">
        <li class="stepper-item">
          <div class="stepper-number">1</div>
          <div class="pb-3">
            <p class="font-semibold text-[var(--text-primary)] text-sm">Open eSIM Settings</p>
            <p class="text-sm text-[var(--text-secondary)] mt-0.5">Go to <strong>Settings > Cellular > Add eSIM</strong> and select <strong>"Enter Details Manually"</strong>.</p>
          </div>
        </li>
        <li class="stepper-item">
          <div class="stepper-number">2</div>
          <div class="pb-3">
            <p class="font-semibold text-[var(--text-primary)] text-sm">Paste Details</p>
            <p class="text-sm text-[var(--text-secondary)] mt-0.5">Paste the <strong>SM-DP+ address</strong> and <strong>activation code</strong> into the corresponding fields.</p>
          </div>
        </li>
        <li class="stepper-item">
          <div class="stepper-number">3</div>
          <div>
            <p class="font-semibold text-[var(--text-primary)] text-sm">Complete Setup</p>
            <p class="text-sm text-[var(--text-secondary)] mt-0.5">Tap <strong>Continue</strong>. The eSIM will install in a few seconds.</p>
          </div>
        </li>
      </ol>
    </div>
  </div>

  <!-- Tips -->
  <div class="alert alert-warning fade-up stagger-4">
    <i data-lucide="lightbulb" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
    <div class="text-sm space-y-1">
      <p>Make sure you have a stable internet connection</p>
      <p>Installation may take a few minutes</p>
      <p>Keep this QR code private and secure</p>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex flex-col sm:flex-row gap-3 fade-up stagger-5">
    <button onclick="downloadQR()" class="flex-1 btn btn-primary btn-lg">
      <i data-lucide="download" class="w-4 h-4"></i>
      Save QR Code
    </button>
    <a href="/purchases" class="flex-1 btn btn-secondary btn-lg">
      <i data-lucide="arrow-left" class="w-4 h-4"></i>
      Back to Purchases
    </a>
  </div>
</div>

<% } else { %>
<div class="empty-state">
  <div class="empty-icon">
    <i data-lucide="qr-code" class="w-6 h-6"></i>
  </div>
  <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-1">QR Code Not Available</h3>
  <p class="text-sm text-[var(--text-secondary)] mb-5">The QR code is not yet available. Please check back later.</p>
  <a href="/purchases" class="btn btn-primary">Back to My Datas</a>
</div>
<% } %>

<script>
function switchTab(tab, el) {
  document.querySelectorAll('.tab-item').forEach(function(t) { t.classList.remove('active'); });
  el.classList.add('active');
  document.getElementById('tab-auto').style.display = tab === 'auto' ? 'block' : 'none';
  document.getElementById('tab-manual').style.display = tab === 'manual' ? 'block' : 'none';
}

function downloadQR() {
  var img = document.querySelector('.qr-image');
  if (!img) return;
  var canvas = document.createElement('canvas');
  var ctx = canvas.getContext('2d');
  canvas.width = img.naturalWidth || 256;
  canvas.height = img.naturalHeight || 256;
  ctx.drawImage(img, 0, 0);
  var link = document.createElement('a');
  link.download = 'esim-qr-code.png';
  link.href = canvas.toDataURL();
  link.click();
}

function copyToClipboard(text, btn) {
  navigator.clipboard.writeText(text).then(function() {
    var original = btn.querySelector('i');
    btn.textContent = '';
    var check = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    check.setAttribute('width', '16');
    check.setAttribute('height', '16');
    check.setAttribute('viewBox', '0 0 24 24');
    check.setAttribute('fill', 'none');
    check.setAttribute('stroke', 'var(--accent)');
    check.setAttribute('stroke-width', '2');
    check.setAttribute('stroke-linecap', 'round');
    check.setAttribute('stroke-linejoin', 'round');
    var polyline = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');
    polyline.setAttribute('points', '20 6 9 17 4 12');
    check.appendChild(polyline);
    btn.appendChild(check);

    setTimeout(function() {
      btn.textContent = '';
      var icon = document.createElement('i');
      icon.setAttribute('data-lucide', 'copy');
      icon.className = 'w-4 h-4';
      btn.appendChild(icon);
      if (typeof lucide !== 'undefined') lucide.createIcons();
    }, 1500);
  });
}
</script>

<%- include('partials/footer') %>