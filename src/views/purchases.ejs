<%- include('partials/header', {title: 'My Datas', user: locals.user}) %>

<div class="mb-8 fade-up">
  <h1 class="text-page-title">My Datas</h1>
</div>

<% if (purchases.length > 0) { %>

<!-- Stats -->
<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="stat-card fade-up stagger-1" style="border-left: 3px solid var(--brand-primary);">
    <div class="stat-content">
      <div class="stat-label">Total</div>
      <div class="stat-value"><%= purchases.length %></div>
    </div>
  </div>
  <div class="stat-card fade-up stagger-2" style="border-left: 3px solid var(--success);">
    <div class="stat-content">
      <div class="stat-label">Active</div>
      <div class="stat-value" style="color: var(--success);"><%= purchases.filter(p => p.status === 'completed').length %></div>
    </div>
  </div>
  <div class="stat-card fade-up stagger-3" style="border-left: 3px solid var(--warning);">
    <div class="stat-content">
      <div class="stat-label">Pending</div>
      <div class="stat-value" style="color: var(--warning);"><%= purchases.filter(p => p.status === 'pending').length %></div>
    </div>
  </div>
</div>

<!-- Purchase List -->
<div class="flex flex-col gap-2 fade-up stagger-4">
  <% purchases.forEach(function(purchase, idx) { %>
  <a href="/status/<%= purchase.transactionId %>" class="purchase-card fade-up stagger-<%= (idx % 6) + 1 %>" style="display: flex; align-items: center; gap: 14px; padding: 14px 16px; text-decoration: none; cursor: pointer;">
    <!-- Flag circle -->
    <div style="width: 42px; height: 42px; min-width: 42px; border-radius: 50%; background: var(--brand-primary); display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 16px;">
      <%= (purchase.country || purchase.brandName || 'E').charAt(0).toUpperCase() %>
    </div>
    <!-- Info -->
    <div style="flex: 1; min-width: 0;">
      <div style="font-weight: 600; color: var(--text-primary); font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
        <%= purchase.country || purchase.brandName || 'Data Plan' %>
      </div>
      <% if (purchase.iccid) { %>
      <div style="font-family: 'SF Mono', 'Fira Code', monospace; font-size: 11px; color: var(--text-muted); margin-top: 2px;">
        <%= purchase.iccid %>
      </div>
      <% } %>
    </div>
    <!-- Status badge -->
    <% if (purchase.status === 'completed') { %>
    <span class="badge badge-success">Active</span>
    <% } else if (purchase.status === 'pending') { %>
    <span class="badge badge-warning">Pending</span>
    <% } else if (purchase.status === 'failed') { %>
    <span class="badge badge-danger">Failed</span>
    <% } else { %>
    <span class="badge badge-neutral"><%= purchase.status %></span>
    <% } %>
    <!-- Arrow -->
    <div style="color: var(--text-muted); width: 18px; height: 18px; flex-shrink: 0;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 18px; height: 18px;"><path d="m9 18 6-6-6-6"/></svg>
    </div>
  </a>
  <% }) %>
</div>

<% } else { %>
<div style="text-align: center; padding: 60px 20px; color: var(--text-muted); font-size: 14px;" class="fade-up">
  <p style="margin-bottom: 16px;">No Datas yet. Start by browsing available plans.</p>
  <a href="/offers" class="btn btn-primary">
    Browse Plans
  </a>
</div>
<% } %>

<%- include('partials/footer') %>
