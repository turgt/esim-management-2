<div class="demo-content">
  <h1 class="demo-page-title demo-animate-in">Cihaz Uyumluluğu</h1>

  <!-- Search -->
  <div class="demo-search-wrapper demo-animate-in">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    <input type="text" class="demo-search-input" placeholder="Cihaz ara...">
  </div>

  <!-- Brand Filters -->
  <div class="demo-filters demo-animate-in">
    <button class="demo-filter-chip active" onclick="setFilter(this)">Tümü</button>
    <button class="demo-filter-chip" onclick="setFilter(this)">Apple</button>
    <button class="demo-filter-chip" onclick="setFilter(this)">Samsung</button>
    <button class="demo-filter-chip" onclick="setFilter(this)">Google</button>
    <button class="demo-filter-chip" onclick="setFilter(this)">Huawei</button>
    <button class="demo-filter-chip" onclick="setFilter(this)">Xiaomi</button>
  </div>

  <!-- Device Accordion -->
  <div class="demo-accordion">
    <% if (locals.brands && brands.length) { %>
      <% brands.forEach(function(brand) { %>
    <details class="demo-animate-in">
      <summary>
        <div style="display:flex;align-items:center;gap:12px;flex:1;">
          <div style="width:40px;height:40px;background:var(--gradient-subtle);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;"><%= brand.icon || '📱' %></div>
          <span style="flex:1;"><%= brand.name %></span>
          <span style="font-size:12px;color:var(--color-text-muted);font-weight:500;"><%= brand.models.length %> model</span>
        </div>
      </summary>
      <div class="demo-accordion-body">
        <% brand.models.forEach(function(model) { %>
        <div class="demo-device-item">
          <% if (model.compatible) { %>
            <span class="demo-device-dot demo-device-dot-ok"></span>
          <% } else { %>
            <span class="demo-device-dot demo-device-dot-no"></span>
          <% } %>
          <span><%= model.name %></span>
        </div>
        <% }) %>
      </div>
    </details>
      <% }) %>
    <% } %>
  </div>
</div>

<script>
function setFilter(el) {
  document.querySelectorAll('.demo-filter-chip').forEach(function(c) { c.classList.remove('active'); });
  el.classList.add('active');
}
</script>
