            <i data-lucide="user" class="w-[1.125rem] h-[1.125rem]"></i> Profile
          </a>

          <% if (user.isAdmin) { %>
          <div class="sidebar-section">Admin</div>
          <a href="/admin/dashboard" class="sidebar-link <%= typeof title !== 'undefined' && title.includes && title.includes('Dashboard') ? 'active' : '' %>">
            <i data-lucide="layout-dashboard" class="w-[1.125rem] h-[1.125rem]"></i> Dashboard
          </a>
          <a href="/admin/users" class="sidebar-link <%= typeof title !== 'undefined' && title.includes && (title.includes('User') || title === 'Manage Users' || title === 'Admin Panel') ? 'active' : '' %>">
            <i data-lucide="users" class="w-[1.125rem] h-[1.125rem]"></i> Users
          </a>
          <a href="/admin/esims" class="sidebar-link <%= typeof title !== 'undefined' && title.includes && (title === 'All Datas' || title === 'Data Detail' || title === 'Assign Data' || title.includes('Top-up') || title.includes('Top Up')) ? 'active' : '' %>">
            <i data-lucide="layers" class="w-[1.125rem] h-[1.125rem]"></i> All Datas
          </a>
          <a href="/admin/payments" class="sidebar-link <%= typeof title !== 'undefined' && title === 'Admin Payments' ? 'active' : '' %>">
            <i data-lucide="credit-card" class="w-[1.125rem] h-[1.125rem]"></i> Payments
          </a>
          <a href="/admin/vendors" class="sidebar-link <%= typeof title !== 'undefined' && title.includes && (title === 'Vendors' || title === 'Vendor Detail' || title === 'Create Vendor' || title === 'Edit Vendor') ? 'active' : '' %>">
            <i data-lucide="store" class="w-[1.125rem] h-[1.125rem]"></i> Vendors
          </a>
          <a href="/admin/emails" class="sidebar-link <%= typeof title !== 'undefined' && (title === 'Emails' || title === 'Email Detail') ? 'active' : '' %>">
            <i data-lucide="mail" class="w-[1.125rem] h-[1.125rem]"></i> Emails
          </a>
