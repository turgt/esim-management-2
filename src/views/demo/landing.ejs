<!-- Hero -->
<div class="v2-hero">
  <div class="v2-hero-content">
    <h1 class="v2-hero-title v2-anim">
      Sinirsiz Baglanti,<br>
      <span style="color: var(--accent);">Sinirsiz Kesif</span>
    </h1>
    <p class="v2-hero-sub v2-anim">
      190+ ulkede aninda aktif olan eSIM planlariyla her zaman bagli kalin. Fiziksel SIM karta elveda deyin.
    </p>
    <div class="v2-hero-ctas v2-anim">
      <a href="/demo/offers" class="v2-btn v2-btn-primary v2-btn-lg">Planlari Kesfet</a>
      <a href="/demo/login" class="v2-btn v2-btn-secondary v2-btn-lg">Giris Yap</a>
    </div>
  </div>
</div>

<!-- Trust Bar -->
<div class="v2-trust">
  <div class="v2-trust-item v2-anim">
    <div class="v2-trust-icon">🌍</div>
    <span>190+ Ulke</span>
  </div>
  <div class="v2-trust-item v2-anim">
    <div class="v2-trust-icon">⚡</div>
    <span>Aninda Aktivasyon</span>
  </div>
  <div class="v2-trust-item v2-anim">
    <div class="v2-trust-icon">🔒</div>
    <span>Guvenli Odeme</span>
  </div>
  <div class="v2-trust-item v2-anim">
    <div class="v2-trust-icon">💬</div>
    <span>7/24 Destek</span>
  </div>
</div>

<div class="v2-divider"></div>

<!-- How It Works -->
<div class="v2-landing-section">
  <h2 class="v2-landing-section-title">Nasil Calisir?</h2>
  <div class="v2-steps-grid">
    <div class="v2-step-card v2-anim">
      <div class="v2-step-card-num">1</div>
      <h3 class="v2-step-card-title">Planini Sec</h3>
      <p class="v2-step-card-desc">Gitmek istedigin ulkeye uygun eSIM planini sec. Fiyatlari karsilastir.</p>
    </div>
    <div class="v2-step-card v2-anim">
      <div class="v2-step-card-num">2</div>
      <h3 class="v2-step-card-title">Odeme Yap</h3>
      <p class="v2-step-card-desc">Guvenli odeme ile aninda satin al. Kredi karti veya Apple Pay ile ode.</p>
    </div>
    <div class="v2-step-card v2-anim">
      <div class="v2-step-card-num">3</div>
      <h3 class="v2-step-card-title">QR ile Yukle</h3>
      <p class="v2-step-card-desc">QR kodu tara veya tek dokunusla eSIM'ini cihazina yukle. Hemen kullanmaya basla.</p>
    </div>
  </div>
</div>

<div class="v2-divider"></div>

<!-- Featured Plans -->
<div class="v2-landing-plans">
  <div class="v2-plans-head">
    <h2 class="v2-landing-section-title" style="margin-bottom:0;text-align:left;">Populer Planlar</h2>
    <a href="/demo/offers" class="v2-plans-link">Tumunu Gor →</a>
  </div>

  <div class="v2-offers">
    <% plans.slice(0, 3).forEach((plan, i) => { %>
    <a href="/demo/status" class="v2-offer v2-anim">
      <div class="v2-offer-top">
        <div class="v2-offer-flag"><%= plan.flag %></div>
        <div>
          <div class="v2-offer-name"><%= plan.country %> <span class="v2-badge v2-badge-<%= plan.network.toLowerCase() %>"><%= plan.network %></span></div>
          <div class="v2-offer-meta"><%= plan.data %> · <%= plan.duration %></div>
        </div>
      </div>
      <div class="v2-offer-foot">
        <div class="v2-offer-price"><%= plan.price %></div>
        <span class="v2-offer-cta">Satin Al →</span>
      </div>
    </a>
    <% }) %>
  </div>
</div>

<!-- Footer -->
<div class="v2-footer">
  <div class="v2-footer-logo" style="color: var(--accent);">DataPatch</div>
  <p>&copy; 2026 DataPatch. Tum haklari saklidir.</p>
</div>
