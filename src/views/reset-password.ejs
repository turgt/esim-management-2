<%- include('partials/header', {title: 'Reset Password', user: null}) %>

    <div class="card p-7">
      <div class="text-center mb-6">
        <div class="w-12 h-12 rounded-xl bg-[var(--brand-light)] flex items-center justify-center mx-auto mb-4">
          <i data-lucide="lock" class="w-6 h-6 text-[var(--brand-primary)]"></i>
        </div>
        <h1 class="text-xl font-bold text-[var(--text-primary)]">Reset Password</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1.5">Enter your new password below</p>
      </div>

      <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <div class="alert alert-error mb-5">
        <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
        <div class="space-y-1">
          <% errors.forEach(function(err) { %><p><%= err.msg || err %></p><% }) %>
        </div>
      </div>
      <% } %>

      <% if (typeof validToken !== 'undefined' && validToken) { %>
      <form method="post" action="/auth/reset-password/<%= token %>" class="space-y-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div>
          <label for="rp-pw" class="input-label">New Password</label>
          <div class="input-icon-wrapper">
            <i data-lucide="lock" class="input-icon w-4 h-4"></i>
            <input type="password" id="rp-pw" name="password" required minlength="8" placeholder="Min 8 characters" class="input">
          </div>
        </div>
        <div>
          <label for="rp-cpw" class="input-label">Confirm Password</label>
          <div class="input-icon-wrapper">
            <i data-lucide="lock" class="input-icon w-4 h-4"></i>
            <input type="password" id="rp-cpw" name="confirmPassword" required minlength="8" placeholder="Confirm your password" class="input">
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">Reset Password</button>
      </form>
      <% } else { %>
      <div class="text-center py-4">
        <div class="w-14 h-14 rounded-2xl bg-[var(--danger-light)] flex items-center justify-center mx-auto mb-4">
          <i data-lucide="x-circle" class="w-7 h-7 text-[var(--danger)]"></i>
        </div>
        <p class="text-sm text-[var(--text-secondary)] mb-5">This reset link is invalid or has expired.</p>
        <a href="/auth/forgot-password" class="btn btn-primary">Request a new link</a>
      </div>
      <% } %>
    </div>

<%- include('partials/footer') %>
