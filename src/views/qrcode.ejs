<%- include('partials/header', {title: 'QR Code', user: locals.user}) %>

<div class="mb-6">
  <div class="breadcrumb">
    <a href="/purchases"><i data-lucide="chevron-left" class="w-4 h-4"></i> Back to My Datas</a>
  </div>
  <h1 class="text-page-title">Your Data QR Code</h1>
  <p class="text-subtitle mt-1">Scan this code with your device to install the Data</p>
</div>

<% if (qr.imageBase64) { %>
<div class="max-w-2xl space-y-6">
  <!-- QR Code Card -->
  <div class="card">
    <div class="p-6 text-center border-b border-[var(--border-subtle)] bg-[var(--surface-1)]">
      <div class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-[var(--brand-light)] mb-3">
        <i data-lucide="qr-code" class="w-5 h-5 text-[var(--brand-primary)]"></i>
      </div>
      <h2 class="text-lg font-bold text-[var(--text-primary)]">Ready to Install</h2>
      <p class="text-sm text-[var(--text-secondary)] mt-1">Scan the QR code below with your device camera</p>
    </div>

    <div class="p-8 flex justify-center">
      <div class="bg-white p-5 rounded-2xl shadow-lg border border-gray-100">
        <img src="data:image/png;base64,<%= qr.imageBase64 %>" alt="Data QR Code" class="qr-image w-64 h-64" />
      </div>
    </div>
  </div>

  <% if (esim && esim.smdpAddress && esim.activationCode) { %>
  <%
    var lpaString = 'LPA:1$' + esim.smdpAddress + '$' + esim.activationCode;
    var appleLink = 'https://esimsetup.apple.com/esim_qrcode_provisioning?carddata=' + encodeURIComponent(lpaString);
    var androidLink = 'https://esimsetup.android.com/esim_qrcode_provisioning?carddata=' + encodeURIComponent(lpaString);
  %>
  <!-- Direct Install (Same Device) -->
  <div class="card" id="directInstallCard">
    <div class="card-header">
      <h3>Install on This Device</h3>
      <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Recommended</span>
    </div>
    <div class="card-body">
      <!-- Desktop -->
      <div id="desktopInstallMsg" style="display:none">
        <div class="alert alert-warning mb-0">
          <i data-lucide="monitor" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
          <div class="text-sm">
            <p class="font-semibold">You're on a computer</p>
            <p class="mt-0.5">Open this page on your iPhone (Safari) or Android to install directly, or scan the QR code above.</p>
          </div>
        </div>
      </div>
      <!-- iOS Safari -->
      <div id="iosSafariInstall" style="display:none">
        <p class="text-sm text-[var(--text-secondary)] mb-4">Tap below to install the eSIM directly — no QR scanning needed.</p>
        <a href="<%= appleLink %>" class="btn btn-primary btn-lg btn-block">
          <i data-lucide="smartphone" class="w-4 h-4"></i>
          Install eSIM Now
        </a>
        <p class="text-xs text-[var(--text-tertiary)] mt-3">Requires iOS 17.4 or later.</p>
      </div>
      <!-- iOS non-Safari (Chrome, Firefox etc.) -->
      <div id="iosNonSafariInstall" style="display:none">
        <div class="alert alert-warning mb-4">
          <i data-lucide="alert-triangle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
          <div class="text-sm">
            <p class="font-semibold">Safari required</p>
            <p class="mt-0.5">eSIM direct install only works in Safari on iPhone. Copy the link below and open it in Safari.</p>
          </div>
        </div>
        <div class="bg-[var(--surface-1)] rounded-lg p-3 border border-[var(--border-subtle)] mb-3">
          <div class="detail-label mb-1">Install Link</div>
          <div class="flex items-center gap-1.5">
            <span class="text-xs font-mono text-[var(--text-secondary)] break-all flex-1" id="iosLinkText"><%= appleLink %></span>
            <button onclick="copyToClipboard(document.getElementById('iosLinkText').textContent.trim(), this)" class="copy-btn flex-shrink-0" title="Copy link">
              <i data-lucide="copy" class="w-3.5 h-3.5"></i>
            </button>
          </div>
        </div>
        <p class="text-xs text-[var(--text-tertiary)]">Copy this link, open Safari, paste it in the address bar and go.</p>
      </div>
      <!-- Android -->
      <div id="androidInstall" style="display:none">
        <p class="text-sm text-[var(--text-secondary)] mb-4">Tap below to install the eSIM directly — no QR scanning needed.</p>
        <a href="<%= androidLink %>" class="btn btn-primary btn-lg btn-block">
          <i data-lucide="smartphone" class="w-4 h-4"></i>
          Install eSIM Now
        </a>
        <p class="text-xs text-[var(--text-tertiary)] mt-3">Requires Google Play services 25.14 or later.</p>
      </div>
    </div>
  </div>

  <!-- Manual Entry -->
  <div class="card">
    <div class="card-header">
      <h3>Manual Entry</h3>
    </div>
    <div class="card-body space-y-3">
      <p class="text-sm text-[var(--text-secondary)]">You can also enter these details manually: Settings > Cellular > Add eSIM > Enter Details Manually.</p>
      <div class="bg-[var(--surface-1)] rounded-lg p-3 border border-[var(--border-subtle)]">
        <div class="detail-label mb-1">SM-DP+ Address</div>
        <div class="flex items-center gap-1.5">
          <span class="text-sm font-mono text-[var(--text-primary)] break-all"><%= esim.smdpAddress %></span>
          <button onclick="copyToClipboard('<%= esim.smdpAddress %>', this)" class="copy-btn flex-shrink-0" title="Copy">
            <i data-lucide="copy" class="w-3 h-3"></i>
          </button>
        </div>
      </div>
      <div class="bg-[var(--surface-1)] rounded-lg p-3 border border-[var(--border-subtle)]">
        <div class="detail-label mb-1">Activation Code</div>
        <div class="flex items-center gap-1.5">
          <span class="text-sm font-mono text-[var(--text-primary)] break-all"><%= esim.activationCode %></span>
          <button onclick="copyToClipboard('<%= esim.activationCode %>', this)" class="copy-btn flex-shrink-0" title="Copy">
            <i data-lucide="copy" class="w-3 h-3"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
  (function() {
    var ua = navigator.userAgent || '';
    var isIOS = /iPhone|iPad|iPod/.test(ua);
    var isAndroid = /Android/.test(ua);
    // Safari on iOS: has Safari in UA but NOT CriOS (Chrome) / FxiOS (Firefox) / EdgiOS (Edge) / OPiOS (Opera)
    var isSafari = isIOS && /Safari/.test(ua) && !/CriOS|FxiOS|EdgiOS|OPiOS|GSA/.test(ua);

    if (isIOS && isSafari) {
      document.getElementById('iosSafariInstall').style.display = 'block';
    } else if (isIOS) {
      document.getElementById('iosNonSafariInstall').style.display = 'block';
    } else if (isAndroid) {
      document.getElementById('androidInstall').style.display = 'block';
    } else {
      document.getElementById('desktopInstallMsg').style.display = 'block';
    }
    lucide.createIcons();
  })();
  </script>
  <% } %>

  <!-- Installation Steps (QR) -->
  <div class="card">
    <div class="card-header">
      <h3>Install via QR Code</h3>
    </div>
    <div class="card-body space-y-4">
      <p class="text-sm text-[var(--text-secondary)] mb-2">If you want to install on a different device, scan the QR code above.</p>
      <div class="stepper-item">
        <div class="stepper-number">1</div>
        <div class="pb-3">
          <p class="font-semibold text-[var(--text-primary)] text-sm">Open Settings</p>
          <p class="text-sm text-[var(--text-secondary)] mt-0.5">Go to Settings > Cellular/Mobile Data</p>
        </div>
      </div>
      <div class="stepper-item">
        <div class="stepper-number">2</div>
        <div class="pb-3">
          <p class="font-semibold text-[var(--text-primary)] text-sm">Add eSIM</p>
          <p class="text-sm text-[var(--text-secondary)] mt-0.5">Tap "Add Cellular Plan" or "Add eSIM"</p>
        </div>
      </div>
      <div class="stepper-item">
        <div class="stepper-number">3</div>
        <div class="pb-3">
          <p class="font-semibold text-[var(--text-primary)] text-sm">Scan QR Code</p>
          <p class="text-sm text-[var(--text-secondary)] mt-0.5">Use your camera to scan the QR code above</p>
        </div>
      </div>
      <div class="stepper-item">
        <div class="stepper-number">4</div>
        <div>
          <p class="font-semibold text-[var(--text-primary)] text-sm">Complete Setup</p>
          <p class="text-sm text-[var(--text-secondary)] mt-0.5">Follow the on-screen instructions to activate</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Tips -->
  <div class="alert alert-warning">
    <i data-lucide="lightbulb" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
    <div class="text-sm space-y-1">
      <p>Make sure you have a stable internet connection</p>
      <p>Installation may take a few minutes</p>
      <p>Keep this QR code private and secure</p>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex flex-col sm:flex-row gap-3">
    <button onclick="downloadQR()" class="flex-1 btn btn-primary btn-lg">
      <i data-lucide="download" class="w-4 h-4"></i>
      Save QR Code
    </button>
    <button onclick="printQR()" class="flex-1 btn btn-secondary btn-lg">
      <i data-lucide="printer" class="w-4 h-4"></i>
      Print QR Code
    </button>
  </div>
</div>

<% } else { %>
<div class="empty-state">
  <div class="empty-icon">
    <i data-lucide="qr-code" class="w-6 h-6"></i>
  </div>
  <h3 class="text-lg font-semibold text-[var(--text-primary)] mb-1">QR Code Not Available</h3>
  <p class="text-sm text-[var(--text-secondary)] mb-5">The QR code is not yet available. Please check back later.</p>
  <a href="/purchases" class="btn btn-primary">Back to My Datas</a>
</div>
<% } %>

<script>
function downloadQR() {
  var img = document.querySelector('.qr-image');
  var canvas = document.createElement('canvas');
  var ctx = canvas.getContext('2d');
  canvas.width = img.naturalWidth;
  canvas.height = img.naturalHeight;
  ctx.drawImage(img, 0, 0);
  var link = document.createElement('a');
  link.download = 'esim-qr-code.png';
  link.href = canvas.toDataURL();
  link.click();
}

function printQR() {
  var qrImg = document.querySelector('.qr-image').src;
  var printWindow = window.open('', '_blank');
  printWindow.document.write(
    '<html><head><title>Data QR Code</title>' +
    '<style>body{margin:0;padding:40px;text-align:center;font-family:Inter,Arial,sans-serif}' +
    '.c{max-width:400px;margin:0 auto}img{width:100%;max-width:300px;margin:20px 0}' +
    'h1{color:#0f172a;margin-bottom:10px;font-size:1.5rem}p{color:#475569;margin-bottom:20px}</style></head>' +
    '<body><div class="c"><h1>Data QR Code</h1><p>Scan this code to install your Data</p>' +
    '<img src="' + qrImg + '" alt="Data QR Code">' +
    '<p><small>Keep this QR code private and secure</small></p></div></body></html>'
  );
  printWindow.document.close();
  printWindow.focus();
  printWindow.print();
  printWindow.close();
}
</script>

<%- include('partials/footer') %>
