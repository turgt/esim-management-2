<%- include('partials/header', {title: 'Payment', user: locals.user}) %>

<div class="mb-6">
  <a href="/offers" class="inline-flex items-center gap-1.5 text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">
    <i data-lucide="arrow-left" class="w-4 h-4"></i> Back to Plans
  </a>
</div>

<div class="max-w-2xl mx-auto">
  <!-- Order Summary -->
  <div class="card mb-4 sm:mb-6">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl bg-[var(--brand-light)] flex items-center justify-center flex-shrink-0">
        <i data-lucide="credit-card" class="w-4 h-4 sm:w-5 sm:h-5 text-[var(--brand-primary)]"></i>
      </div>
      <div class="min-w-0">
        <h2 class="text-base sm:text-lg font-semibold text-[var(--text-primary)]">Order Summary</h2>
        <p class="text-xs text-[var(--text-secondary)]">Complete your payment to activate your eSIM</p>
      </div>
    </div>

    <div class="p-3 sm:p-4 rounded-lg bg-[var(--surface-1)] border border-[var(--border-subtle)]">
      <div class="flex justify-between items-center mb-2 gap-2">
        <span class="text-sm text-[var(--text-secondary)] flex-shrink-0">Plan</span>
        <span class="text-sm font-medium text-[var(--text-primary)] truncate text-right"><%= offerId %></span>
      </div>
      <div class="flex justify-between items-center mb-2 gap-2">
        <span class="text-sm text-[var(--text-secondary)] flex-shrink-0">Order ID</span>
        <span class="text-[0.6875rem] font-mono text-[var(--text-tertiary)] truncate text-right"><%= payment.merchantOid %></span>
      </div>
      <div class="border-t border-[var(--border-subtle)] mt-3 pt-3">
        <div class="flex justify-between items-center">
          <span class="text-base font-semibold text-[var(--text-primary)]">Total</span>
          <span class="text-lg font-bold text-[var(--brand-primary)]">$<%= parseFloat(amount).toFixed(2) %> <%= currency %></span>
        </div>
      </div>
    </div>
  </div>

  <!-- PayTR iFrame -->
  <div class="card">
    <h3 class="text-sm sm:text-base font-semibold text-[var(--text-primary)] mb-3 sm:mb-4">
      <i data-lucide="lock" class="w-4 h-4 inline-block -mt-0.5 mr-1"></i>
      Secure Payment
    </h3>
    <div class="rounded-lg overflow-hidden border border-[var(--border-subtle)] -mx-2 sm:mx-0" style="min-height: 400px;">
      <script src="https://www.paytr.com/js/iframeResizer.min.js"></script>
      <iframe src="https://www.paytr.com/odeme/guvenli/<%= iframeToken %>" id="paytriframe" frameborder="0" scrolling="yes" style="width: 100%; min-height: 400px;"></iframe>
      <script>
        try { iFrameResize({ checkOrigin: false, heightCalculationMethod: 'lowestElement' }, '#paytriframe'); } catch(e) {}
      </script>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
