<%- include('partials/header', {title: 'Payment', user: locals.user, backUrl: '/offers'}) %>

<% const isTurInvoiceQr = (typeof paymentMode !== 'undefined' && paymentMode === 'turinvoice-qr'); %>
<% const isMethodSelection = (typeof paymentMode !== 'undefined' && paymentMode === 'method-selection'); %>
<% const showMethodSelector = (isMethodSelection || !isTurInvoiceQr) && (typeof turInvoiceEnabled !== 'undefined' && turInvoiceEnabled); %>
<% const skipPaddleJs = isTurInvoiceQr || isMethodSelection; %>

<% if (isTurInvoiceQr) { %>
  <div class="max-w-lg mx-auto px-4 py-8">
    <div class="mb-4">
      <a href="javascript:history.back()" class="text-sm text-[var(--brand-primary)] hover:underline">&larr; Yontemi Degistir</a>
    </div>

    <div class="flex items-center justify-between mb-4 pb-3 border-b border-[var(--border-primary)]">
      <span class="text-sm text-[var(--text-secondary)]"><%= payment.metadata?.planName || 'eSIM' %></span>
      <span class="text-lg font-bold"><%= currency %> <%= Number(amount).toFixed(2) %></span>
    </div>

    <div class="card p-6 text-center mb-4">
      <div style="width:200px;height:200px;margin:0 auto 16px;position:relative;">
        <img id="qrImage" src="/payment/turinvoice/qr/<%= turInvoiceIdOrder %>"
             alt="QR Code" style="width:100%;height:100%;object-fit:contain;border-radius:8px;"
             onerror="document.getElementById('qrError').style.display='block';this.style.display='none';">
        <div id="qrError" style="display:none;" class="text-sm text-red-500 mt-4">
          QR kodu yuklenemedi.
          <a href="<%= turInvoicePaymentUrl %>" class="text-[var(--brand-primary)] underline block mt-2">Kart ile ode &rarr;</a>
        </div>
      </div>
      <p class="font-semibold text-[var(--text-primary)]">Banka Uygulamani Ac</p>
      <p class="text-sm text-[var(--text-secondary)]">QR kodu tarayarak odemeyi tamamla</p>
    </div>

    <div id="turPaymentStatus" class="bg-amber-50 border border-amber-200 rounded-lg p-3 flex items-center gap-3 mb-4">
      <div style="width:8px;height:8px;border-radius:50%;background:#f97316;" class="animate-pulse"></div>
      <span class="text-sm text-amber-800" id="turStatusText">Odeme bekleniyor... Otomatik onaylanacak.</span>
    </div>

    <div class="flex items-center gap-3 my-4">
      <div class="flex-1 h-px bg-[var(--border-primary)]"></div>
      <span class="text-xs text-[var(--text-secondary)]">veya</span>
      <div class="flex-1 h-px bg-[var(--border-primary)]"></div>
    </div>

    <div class="text-center">
      <a href="<%= turInvoicePaymentUrl %>" class="text-sm text-[var(--brand-primary)] hover:underline">Kart bilgileri ile ode &rarr;</a>
      <p class="text-xs text-[var(--text-secondary)] mt-1">TurInvoice guvenli odeme sayfasina yonlendirileceksin</p>
    </div>

    <script>
      (function() {
        var merchantOid = '<%= payment.merchantOid %>';
        var statusEl = document.getElementById('turStatusText');
        var containerEl = document.getElementById('turPaymentStatus');
        var pollInterval = setInterval(function() {
          fetch('/payment/status/' + merchantOid)
            .then(function(r) { return r.json(); })
            .then(function(d) {
              if (d.status === 'completed') {
                clearInterval(pollInterval);
                window.location.href = '/payment/result/' + merchantOid;
              } else if (d.status === 'failed') {
                clearInterval(pollInterval);
                statusEl.textContent = 'Odeme basarisiz oldu.';
                containerEl.className = 'bg-red-50 border border-red-200 rounded-lg p-3 flex items-center gap-3 mb-4';
              }
            })
            .catch(function() {});
        }, 2000);

        setTimeout(function() {
          clearInterval(pollInterval);
          statusEl.textContent = 'Odeme henuz onaylanmadi. Sayfayi yenileyerek tekrar kontrol edebilirsin.';
        }, 5 * 60 * 1000);
      })();
    </script>
  </div>
<% } else { %>

<%
  var planName = (typeof payment !== 'undefined' && payment && payment.metadata && payment.metadata.planName)
    ? payment.metadata.planName
    : (typeof offerId !== 'undefined' ? offerId : 'Data Plan');
  var displayAmount = parseFloat(amount).toFixed(2);
  var displayCurrency = (typeof currency !== 'undefined' && currency) ? currency : 'USD';
  var subtotal = (parseFloat(amount) / 1.20).toFixed(2);
  var tax = (parseFloat(amount) - parseFloat(subtotal)).toFixed(2);
%>

<div class="max-w-lg mx-auto space-y-5">

    <% if (showMethodSelector) { %>
    <!-- Order Summary (compact) -->
    <div class="card p-4 mb-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-[var(--brand-light)] flex items-center justify-center">
          <i data-lucide="globe" class="w-5 h-5 text-[var(--brand-primary)]"></i>
        </div>
        <div class="flex-1">
          <p class="font-semibold text-sm"><%= payment.metadata?.planName || 'eSIM Plan' %></p>
          <p class="text-xs text-[var(--text-secondary)]">Order #<%= payment.merchantOid %></p>
        </div>
        <p class="font-bold text-lg"><%= currency || 'USD' %> <%= Number(amount).toFixed(2) %></p>
      </div>
    </div>

    <form id="paymentMethodForm" method="post" action="/payment/create" hx-boost="false">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <input type="hidden" name="packageId" value="<%= offerId %>">
      <input type="hidden" name="vendor" value="<%= payment.metadata?.vendor || 'airalo' %>">
      <input type="hidden" name="amount" value="<%= amount %>">
      <input type="hidden" name="currency" value="<%= currency %>">
      <input type="hidden" name="planName" value="<%= payment.metadata?.planName || '' %>">
      <input type="hidden" name="provider" id="selectedProvider" value="paddle">
      <input type="hidden" name="paymentType" id="selectedPaymentType" value="qr">

      <p class="text-sm font-semibold mb-3" style="color:var(--text-primary);">Odeme Yontemi</p>

      <!-- Paddle option (default selected) -->
      <div id="optPaddle" onclick="selectProvider('paddle')"
           style="border:2px solid var(--brand-primary, #4f46e5);border-radius:12px;padding:14px;margin-bottom:8px;cursor:pointer;background:rgba(79,70,229,0.05);">
        <div style="display:flex;align-items:center;gap:12px;">
          <div id="rdPaddle" style="width:20px;height:20px;border-radius:50%;border:2px solid var(--brand-primary, #4f46e5);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <div id="rdPaddleDot" style="width:10px;height:10px;border-radius:50%;background:var(--brand-primary, #4f46e5);"></div>
          </div>
          <div style="flex:1;display:flex;align-items:center;justify-content:space-between;">
            <span style="font-weight:600;font-size:14px;">Visa, Mastercard, Apple Pay</span>
            <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
              <!-- Visa -->
              <svg width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="border-radius:4px;">
                <rect width="38" height="24" rx="4" fill="#1A1F71"/>
                <path d="M16.2 16.5l1.8-10.5h2.1l-1.8 10.5H16.2zm9.3-10.2c-.4-.2-1.1-.4-1.9-.4-2.1 0-3.6 1.1-3.6 2.6 0 1.2 1 1.8 1.8 2.2.8.4 1.1.6 1.1 1 0 .5-.7.8-1.3.8-.9 0-1.3-.1-2.1-.5l-.3-.1-.3 1.8c.5.2 1.5.4 2.5.4 2.2 0 3.7-1.1 3.7-2.7 0-.9-.5-1.6-1.7-2.2-.7-.4-1.1-.6-1.1-1 0-.3.4-.7 1.1-.7.7 0 1.1.1 1.5.3l.2.1.4-1.6zm5.2 0H29c-.5 0-.9.2-1.1.6l-3.1 7.4h2.2l.4-1.2h2.7l.2 1.2h1.9l-1.7-8zm-2.6 5.4l1.1-3 .6 3h-1.7zM14.5 6l-2 7.2-.2-1.1-.7-3.8c-.1-.5-.5-.6-1-.7H7.5v.2c.8.2 1.6.5 2.1.8l1.8 6.9h2.2L16.8 6h-2.3z" fill="#fff"/>
              </svg>
              <!-- Mastercard -->
              <svg width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="border-radius:4px;">
                <rect width="38" height="24" rx="4" fill="#252525"/>
                <circle cx="15" cy="12" r="7" fill="#EB001B"/>
                <circle cx="23" cy="12" r="7" fill="#F79E1B"/>
                <path d="M19 6.8a7 7 0 0 1 2.6 5.2A7 7 0 0 1 19 17.2a7 7 0 0 1-2.6-5.2A7 7 0 0 1 19 6.8z" fill="#FF5F00"/>
              </svg>
              <!-- Apple Pay -->
              <svg width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="border-radius:4px;">
                <rect width="38" height="24" rx="4" fill="#000"/>
                <path d="M13.2 8.4c.3-.4.5-.9.5-1.4-.5 0-1.1.3-1.4.7-.3.3-.6.9-.5 1.4.5 0 1-.3 1.4-.7zm.4.8c-.8 0-1.5.4-1.8.4-.4 0-1-.4-1.6-.4-.8 0-1.6.5-2 1.2-.9 1.5-.2 3.7.6 4.9.4.6.9 1.3 1.5 1.2.6 0 .8-.4 1.6-.4.7 0 .9.4 1.6.4.6 0 1.1-.6 1.5-1.2.5-.7.7-1.4.7-1.4-.8-.3-1-1.1-1-1.9s.5-1.4 1-1.7c-.5-.6-1.2-.9-1.8-1-.2-.1-.3-.1-.3-.1zm5.7-.6v7.7h1.2v-2.6h1.7c1.5 0 2.6-1 2.6-2.5s-1-2.5-2.5-2.5h-3zm1.2 1h1.4c1 0 1.6.5 1.6 1.5s-.6 1.5-1.6 1.5h-1.4V9.6zm6.6 6.8c.8 0 1.5-.4 1.8-1h0v.9h1.1v-3.8c0-1.1-.9-1.9-2.3-1.9-1.3 0-2.2.7-2.3 1.8h1.1c.1-.5.6-.9 1.2-.9.8 0 1.2.4 1.2 1v.5l-1.6.1c-1.5.1-2.3.7-2.3 1.7 0 1 .8 1.7 2.1 1.7zm.3-1c-.7 0-1.1-.3-1.1-.8 0-.6.4-.8 1.3-.9l1.4-.1v.5c0 .8-.7 1.3-1.6 1.3z" fill="#fff"/>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- TurInvoice option -->
      <div id="optTur" onclick="selectProvider('turinvoice')"
           style="border:2px solid var(--border-primary, #e2e8f0);border-radius:12px;padding:14px;cursor:pointer;background:transparent;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div id="rdTur" style="width:20px;height:20px;border-radius:50%;border:2px solid var(--border-primary, #cbd5e1);flex-shrink:0;">
            <div id="rdTurDot" style="width:10px;height:10px;border-radius:50%;background:var(--brand-primary, #4f46e5);display:none;margin:3px auto;"></div>
          </div>
          <div style="flex:1;display:flex;align-items:center;justify-content:space-between;">
            <div>
              <span style="font-weight:600;font-size:14px;">СБП / MIR</span>
              <span style="display:block;font-size:12px;color:var(--text-secondary, #94a3b8);">Российские банковские карты</span>
            </div>
            <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
              <!-- SBP -->
              <svg width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="border-radius:4px;">
                <rect width="38" height="24" rx="4" fill="#fff" stroke="#e2e8f0" stroke-width=".5"/>
                <path d="M11 7l3.5 2.1v3.8L11 15v-3.9L7.5 13v-3.8L11 7z" fill="#5B57A2"/>
                <path d="M14.5 9.1L11 11.1v3.9l3.5-2V9.1z" fill="#D90751"/>
                <path d="M7.5 9.2V13L11 11.1V7L7.5 9.2z" fill="#FAB718"/>
                <path d="M14.5 9.1L11 7v4.1l3.5-2z" fill="#ED6F26"/>
                <path d="M7.5 13L11 15v-3.9L7.5 13z" fill="#63B22F"/>
                <text x="18" y="14.5" font-family="Arial,sans-serif" font-size="7" font-weight="700" fill="#1a1a1a">СБП</text>
              </svg>
              <!-- MIR -->
              <svg width="38" height="24" viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="border-radius:4px;">
                <rect width="38" height="24" rx="4" fill="#fff" stroke="#e2e8f0" stroke-width=".5"/>
                <path d="M5 9h3.5l1.8 3.8L12 9h3.5v6H13v-4l-1.5 4h-1.5L8.5 11v4H5V9z" fill="#0F754E"/>
                <path d="M17 9h2.5v6H17V9z" fill="#0F754E"/>
                <path d="M21 9h3c1.5 0 2.5.8 2.5 2s-.7 1.8-1.5 2l2 2H24l-2-2v2h-1V9zm2.5 1.5v1.5h.8c.5 0 .7-.3.7-.7 0-.5-.3-.8-.7-.8h-.8z" fill="#0F754E"/>
                <path d="M5 8.5h4.5c0 0 1.5 0 2.3 1.5.8-1.5 2.3-1.5 2.3-1.5" stroke="url(#mirGrad)" stroke-width="1" fill="none"/>
                <defs><linearGradient id="mirGrad" x1="5" y1="8" x2="14" y2="8"><stop stop-color="#00A0E5"/><stop offset="1" stop-color="#0F754E"/></linearGradient></defs>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <!-- Submit button (always visible) -->
      <button type="submit" id="paySubmitBtn"
              style="width:100%;margin-top:16px;padding:14px;border:none;border-radius:10px;background:var(--brand-primary, #4f46e5);color:white;font-size:15px;font-weight:700;cursor:pointer;">
        <%= currency %> <%= Number(amount).toFixed(2) %> Ode &rarr;
      </button>

      <p style="text-align:center;margin-top:10px;font-size:12px;color:var(--text-secondary, #94a3b8);display:flex;align-items:center;justify-content:center;gap:4px;">
        <span style="color:#10b981;">&#128274;</span> Guvenli odeme
      </p>
    </form>

    <script>
      function selectProvider(method) {
        document.getElementById('selectedProvider').value = method;
        var optP = document.getElementById('optPaddle');
        var optT = document.getElementById('optTur');
        var rdPaddle = document.getElementById('rdPaddle');
        var rdTur = document.getElementById('rdTur');
        var dotP = document.getElementById('rdPaddleDot');
        var dotT = document.getElementById('rdTurDot');

        if (method === 'paddle') {
          optP.style.borderColor = 'var(--brand-primary, #4f46e5)';
          optP.style.background = 'rgba(79,70,229,0.05)';
          optT.style.borderColor = 'var(--border-primary, #e2e8f0)';
          optT.style.background = 'transparent';
          rdPaddle.style.borderColor = 'var(--brand-primary, #4f46e5)';
          dotP.style.display = 'block';
          rdTur.style.borderColor = 'var(--border-primary, #cbd5e1)';
          dotT.style.display = 'none';
        } else {
          optT.style.borderColor = 'var(--brand-primary, #4f46e5)';
          optT.style.background = 'rgba(79,70,229,0.05)';
          optP.style.borderColor = 'var(--border-primary, #e2e8f0)';
          optP.style.background = 'transparent';
          rdTur.style.borderColor = 'var(--brand-primary, #4f46e5)';
          dotT.style.display = 'block';
          rdPaddle.style.borderColor = 'var(--border-primary, #cbd5e1)';
          dotP.style.display = 'none';
        }
      }
    </script>
    <% } %>

  <% if (!isMethodSelection) { %>
  <!-- Order Summary -->
  <div class="card fade-up stagger-1">
    <div class="p-5">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl bg-[var(--brand-light)] flex items-center justify-center flex-shrink-0">
          <i data-lucide="shopping-bag" class="w-5 h-5 text-[var(--brand-primary)]"></i>
        </div>
        <div class="min-w-0">
          <h2 class="text-base font-bold text-[var(--text-primary)]"><%= planName %></h2>
          <p class="text-xs text-[var(--text-secondary)]">Order #<%= payment.merchantOid %></p>
        </div>
      </div>

      <!-- Price Breakdown -->
      <div class="space-y-3 mt-4">
        <div class="flex justify-between items-center">
          <span class="text-sm text-[var(--text-secondary)]">Subtotal</span>
          <span class="text-sm text-[var(--text-primary)]">$<%= subtotal %> <%= displayCurrency %></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-sm text-[var(--text-secondary)]">Tax (20%)</span>
          <span class="text-sm text-[var(--text-primary)]">$<%= tax %> <%= displayCurrency %></span>
        </div>
        <div class="border-t border-[var(--border-subtle)] pt-3">
          <div class="flex justify-between items-center">
            <span class="text-base font-bold text-[var(--text-primary)]">Total</span>
            <span class="text-lg font-bold text-[var(--brand-primary)]">$<%= displayAmount %> <%= displayCurrency %></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Payment Status Area -->
  <div class="card text-center py-8 fade-up stagger-2" id="paymentStatus">
    <div id="statusLoading">
      <div class="w-14 h-14 rounded-full bg-[var(--surface-2)] flex items-center justify-center mx-auto mb-4">
        <i data-lucide="loader-2" class="w-7 h-7 text-[var(--brand-primary)] animate-spin"></i>
      </div>
      <h3 class="text-base font-semibold text-[var(--text-primary)] mb-1">Opening Secure Payment</h3>
      <p class="text-sm text-[var(--text-secondary)]">Please wait...</p>
    </div>

    <div id="statusReady" style="display:none;">
      <div class="w-14 h-14 rounded-full bg-[var(--brand-light)] flex items-center justify-center mx-auto mb-4">
        <i data-lucide="lock" class="w-7 h-7 text-[var(--brand-primary)]"></i>
      </div>
      <h3 class="text-base font-semibold text-[var(--text-primary)] mb-1">Secure Payment Ready</h3>
      <p class="text-sm text-[var(--text-secondary)] mb-5">Your payment form was closed. Click below to reopen.</p>
      <button id="reopenBtn" onclick="openCheckout()" class="btn btn-primary btn-lg btn-block">
        <i data-lucide="credit-card" class="w-4 h-4"></i> Complete Payment - $<%= displayAmount %>
      </button>
    </div>

    <div id="statusError" style="display:none;">
      <div class="w-14 h-14 rounded-full bg-red-100 dark:bg-red-500/20 flex items-center justify-center mx-auto mb-4">
        <i data-lucide="alert-circle" class="w-7 h-7 text-red-500"></i>
      </div>
      <h3 class="text-base font-semibold text-[var(--text-primary)] mb-1">Payment Unavailable</h3>
      <p class="text-sm text-[var(--text-secondary)] mb-5" id="errorMsg">Could not load payment form. Please try again.</p>
      <a href="/offers" class="btn btn-secondary inline-flex items-center gap-2">
        <i data-lucide="arrow-left" class="w-4 h-4"></i> Back to Plans
      </a>
    </div>
  </div>

  <!-- Security Note -->
  <p class="text-center text-xs text-[var(--text-tertiary)] fade-up stagger-3">
    <i data-lucide="shield-check" class="w-3.5 h-3.5 inline-block -mt-0.5 mr-0.5"></i>
    Secure payment -- processed by Paddle
  </p>
</div>
  <% } /* end of !isMethodSelection */ %>

<% if (!skipPaddleJs) { %>
<script src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
<script>
(function () {
  var merchantOid = '<%= payment.merchantOid %>';
  var transactionId = '<%= paddleTransactionId %>';
  var clientToken = '<%= paddleClientToken %>';
  var environment = '<%= paddleEnvironment %>';
  var userEmail = '<%= locals.user && locals.user.email ? locals.user.email : "" %>';

  function showStatus(id) {
    ['statusLoading', 'statusReady', 'statusError'].forEach(function (s) {
      document.getElementById(s).style.display = 'none';
    });
    document.getElementById(id).style.display = 'block';
    if (typeof lucide !== 'undefined') lucide.createIcons();
  }

  function openCheckout() {
    var checkoutSettings = { transactionId: transactionId };
    if (userEmail) {
      checkoutSettings.customer = { email: userEmail };
    }
    Paddle.Checkout.open(checkoutSettings);
  }

  window.openCheckout = openCheckout;

  if (!clientToken) {
    console.error('Paddle: PADDLE_CLIENT_TOKEN is not configured');
    document.getElementById('errorMsg').textContent = 'Payment not configured (missing client token).';
    showStatus('statusError');
    return;
  }

  try {
    // Must be called BEFORE Paddle.Initialize() for sandbox
    if (environment === 'sandbox') {
      Paddle.Environment.set('sandbox');
    }

    Paddle.Initialize({
      token: clientToken,
      eventCallback: function (data) {
        console.log('Paddle event:', data.name, data);
        if (data.name === 'checkout.completed') {
          window.location.href = '/payment/result/' + merchantOid;
        } else if (data.name === 'checkout.closed') {
          showStatus('statusReady');
        } else if (data.name === 'checkout.loaded') {
          showStatus('statusReady');
        } else if (data.name === 'checkout.error') {
          var msg = (data.data && data.data.message) || 'Could not load payment form. Please try again.';
          console.error('Paddle checkout.error:', data);
          document.getElementById('errorMsg').textContent = msg;
          showStatus('statusError');
        }
      }
    });
    openCheckout();
  } catch (e) {
    console.error('Paddle initialize error:', e);
    document.getElementById('errorMsg').textContent = e.message || 'Failed to initialize payment. Please try again.';
    showStatus('statusError');
  }
})();
</script>
<% } /* end of skipPaddleJs */ %>

<% } /* end of isTurInvoiceQr else */ %>

<%- include('partials/footer') %>
