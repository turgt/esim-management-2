<%- include('partials/header', {title: 'Purchase Status', user: locals.user, backUrl: '/purchases'}) %>

<%
  /* ── Resolve current status string ── */
  var currentStatusVal = (typeof status !== 'undefined' && status)
    ? status.status
    : (typeof dbStatus !== 'undefined' ? dbStatus : '');

  var isDone    = ['DONE','ACCEPTED','completed'].includes(currentStatusVal);
  var isPending = ['PENDING','pending','processing','installing','AUTHORIZED','IN_PROGRESS'].includes(currentStatusVal);
  var isFailed  = ['FAILED','CANCELLED','REJECTED','ERROR','failed'].includes(currentStatusVal);

  /* ── Resolve detail values (vendor-agnostic) ── */
  var txId      = (typeof status !== 'undefined' && status) ? status.transactionId : (esim ? esim.transactionId : '-');
  var offerId   = (typeof status !== 'undefined' && status) ? status.offerId : (esim ? esim.offerId : '-');
  var provider  = (typeof status !== 'undefined' && status && status.brandName) ? status.brandName : (esim && esim.brandName ? esim.brandName : null);
  var country   = (typeof status !== 'undefined' && status && status.country) ? status.country : (esim && esim.country ? esim.country : null);
  var duration  = (typeof status !== 'undefined' && status && status.durationDays) ? status.durationDays : (esim && esim.durationDays ? esim.durationDays : null);
  var dataUnlimited = (typeof status !== 'undefined' && status) ? status.dataUnlimited : false;
  var dataGB    = (typeof status !== 'undefined' && status && status.dataGB) ? status.dataGB : (esim ? esim.dataGB : null);
  var iccid     = esim && esim.iccid ? esim.iccid : null;
  var purchaseDate = esim ? esim.createdAt : null;

  /* ── Usage data (Airalo) ── */
  var hasUsage  = typeof usageData !== 'undefined' && usageData && usageData.total;
  var usedMB    = hasUsage ? (usageData.total - usageData.remaining) : 0;
  var totalMB   = hasUsage ? usageData.total : 0;
  var usagePct  = hasUsage ? Math.round((usedMB / totalMB) * 100) : 0;
%>

<!-- Status Banner -->
<% if (isDone) { %>
<div class="status-banner status-banner-done fade-up stagger-1">
  <div class="status-icon">
    <i data-lucide="check-circle" class="w-6 h-6"></i>
  </div>
  <div>
    <div class="status-banner-title">Data Ready</div>
    <div class="status-banner-msg">Your eSIM has been activated and is ready to use</div>
  </div>
</div>
<% } else if (isPending) { %>
<div class="status-banner status-banner-pending fade-up stagger-1">
  <div class="status-icon">
    <i data-lucide="loader" class="w-6 h-6 animate-spin"></i>
  </div>
  <div>
    <div class="status-banner-title">Processing</div>
    <div class="status-banner-msg">Your eSIM is being set up, this usually takes a few minutes</div>
  </div>
</div>
<% } else if (isFailed) { %>
<div class="status-banner status-banner-failed fade-up stagger-1">
  <div class="status-icon">
    <i data-lucide="x-circle" class="w-6 h-6"></i>
  </div>
  <div>
    <div class="status-banner-title">Activation Failed</div>
    <div class="status-banner-msg">Please contact support for assistance</div>
  </div>
</div>
<% } else { %>
<div class="status-banner status-banner-progress fade-up stagger-1">
  <div class="status-icon">
    <i data-lucide="loader" class="w-6 h-6 animate-spin"></i>
  </div>
  <div>
    <div class="status-banner-title"><%= currentStatusVal || 'Processing' %></div>
    <div class="status-banner-msg">Your eSIM is being prepared</div>
  </div>
</div>
<% } %>

<!-- Details Grid -->
<div class="detail-grid fade-up stagger-2">
  <% if (country) { %>
  <div class="detail-item">
    <div class="detail-label">Country</div>
    <div class="detail-value"><%= country %></div>
  </div>
  <% } %>
  <div class="detail-item">
    <div class="detail-label">Data</div>
    <div class="detail-value"><%= dataUnlimited ? 'Unlimited' : (dataGB ? dataGB + ' GB' : '-') %></div>
  </div>
  <% if (duration) { %>
  <div class="detail-item">
    <div class="detail-label">Duration</div>
    <div class="detail-value"><%= duration %> days</div>
  </div>
  <% } %>
  <% if (provider) { %>
  <div class="detail-item">
    <div class="detail-label">Operator</div>
    <div class="detail-value"><%= provider %></div>
  </div>
  <% } %>
  <% if (iccid) { %>
  <div class="detail-item">
    <div class="detail-label">ICCID</div>
    <div class="detail-value detail-mono"><%= iccid %></div>
  </div>
  <% } %>
  <div class="detail-item">
    <div class="detail-label">Purchase Date</div>
    <div class="detail-value"><%= purchaseDate ? new Date(purchaseDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '-' %></div>
  </div>
</div>

<!-- Data Usage Progress (Airalo with usage data) -->
<% if (hasUsage) { %>
<div class="progress-wrap fade-up stagger-3">
  <div class="progress-header">
    <div class="progress-title">Data Usage</div>
    <div class="progress-value"><%= usedMB %> MB / <%= totalMB %> MB</div>
  </div>
  <div class="progress-bar">
    <div class="progress-fill" style="width: <%= usagePct %>%;"></div>
  </div>
  <div class="progress-label"><%= usagePct %>% used</div>
</div>
<% } %>

<!-- Action Buttons -->
<div class="flex flex-col sm:flex-row gap-3 fade-up stagger-4" style="margin-bottom:24px;">
  <% if (isQrReady) { %>
  <a href="/qrcode/<%= txId %>" class="flex-1 btn btn-primary btn-lg">
    <i data-lucide="qr-code" class="w-4 h-4"></i>
    View QR Code
  </a>
  <% } %>
  <% if (typeof vendor !== 'undefined' && vendor === 'airalo' && isDone && esim && esim.id) { %>
  <a href="/payment/topup/<%= esim.id %>" class="flex-1 btn btn-secondary btn-lg">
    <i data-lucide="plus" class="w-4 h-4"></i>
    Top-up
  </a>
  <% } %>
  <% if (!isQrReady) { %>
  <button onclick="location.reload()" class="flex-1 btn btn-secondary btn-lg">
    <i data-lucide="refresh-cw" class="w-4 h-4"></i>
    Refresh Status
  </button>
  <% } %>
</div>

<!-- Activity Timeline -->
<div class="timeline fade-up stagger-5">
  <div class="timeline-title">Activity</div>

  <% if (typeof status !== 'undefined' && status && status.log && status.log.length > 0) { %>
    <% status.log.forEach(function(entry) { %>
    <%
      var entryDone   = ['DONE','ACCEPTED','completed'].includes(entry.status);
      var entryFailed = ['FAILED','CANCELLED','REJECTED','ERROR','failed'].includes(entry.status);
    %>
    <div class="timeline-item">
      <div class="timeline-dot <%= entryDone ? 'timeline-dot-ok' : (entryFailed ? 'timeline-dot-warn' : 'timeline-dot-ok') %>">
        <% if (entryDone) { %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        <% } else if (entryFailed) { %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        <% } else { %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
        <% } %>
      </div>
      <div>
        <div class="timeline-text"><%= entry.status %><% if (entry.statusMessage) { %> &mdash; <%= entry.statusMessage %><% } %></div>
        <div class="timeline-time"><%= new Date(entry.dateTime).toLocaleString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></div>
      </div>
    </div>
    <% }) %>
  <% } else { %>
    <!-- Basic status info when no activity log -->
    <div class="timeline-item">
      <div class="timeline-dot <%= isDone ? 'timeline-dot-ok' : 'timeline-dot-warn' %>">
        <% if (isDone) { %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        <% } else { %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
        <% } %>
      </div>
      <div>
        <div class="timeline-text"><%= isDone ? 'eSIM activated' : (isFailed ? 'Activation failed' : 'Order processing') %></div>
        <div class="timeline-time"><%= purchaseDate ? new Date(purchaseDate).toLocaleString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-' %></div>
      </div>
    </div>
  <% } %>
</div>

<script>
var _refreshTimer = null;
var _countdownTimer = null;

function stopAutoRefresh() {
  clearInterval(_refreshTimer);
  clearInterval(_countdownTimer);
}

document.addEventListener('DOMContentLoaded', function() {
  var params = new URLSearchParams(window.location.search);
  if (params.get('purchased') === 'true') {
    showToast('Data purchased successfully!', 'success');
    history.replaceState(null, '', window.location.pathname);
  }

  var currentStatus = '<%= currentStatusVal %>';
  var pendingStates = ['pending', 'processing', 'installing', 'PENDING', 'AUTHORIZED', 'IN_PROGRESS'];
  if (pendingStates.includes(currentStatus)) {
    var refreshCount = 0;
    _refreshTimer = setInterval(function() {
      refreshCount++;
      if (refreshCount >= 10) { stopAutoRefresh(); return; }
      window.location.reload();
    }, 30000);
  }
});
window.addEventListener('beforeunload', stopAutoRefresh);
</script>

<%- include('partials/footer') %>
