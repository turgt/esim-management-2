<%- include('../partials/header', {title: 'Emails', user: locals.user}) %>

<div class="mb-8 flex items-center justify-between">
  <div>
    <p class="text-sm text-[var(--text-secondary)] mb-1">Email Management</p>
    <h1 class="text-page-title">Emails</h1>
  </div>
  <button onclick="openComposeModal()" class="btn btn-primary inline-flex items-center gap-2">
    <i data-lucide="pencil" class="w-4 h-4"></i>
    Compose
  </button>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
  <div class="stat-card">
    <div class="stat-icon bg-[var(--brand-light)]">
      <i data-lucide="mail" class="w-5 h-5 text-[var(--brand-primary)]"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Total</p>
      <p class="stat-value"><%= stats.totalAll %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-sky-50 dark:bg-sky-500/10">
      <i data-lucide="inbox" class="w-5 h-5 text-sky-600 dark:text-sky-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Inbound</p>
      <p class="stat-value text-sky-600 dark:text-sky-400"><%= stats.totalInbound %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-emerald-50 dark:bg-emerald-500/10">
      <i data-lucide="send" class="w-5 h-5 text-emerald-600 dark:text-emerald-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Delivered</p>
      <p class="stat-value text-emerald-600 dark:text-emerald-400"><%= stats.totalDelivered %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-amber-50 dark:bg-amber-500/10">
      <i data-lucide="clock" class="w-5 h-5 text-amber-600 dark:text-amber-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Sent</p>
      <p class="stat-value"><%= stats.totalSent %></p>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-icon bg-rose-50 dark:bg-rose-500/10">
      <i data-lucide="alert-triangle" class="w-5 h-5 text-rose-600 dark:text-rose-400"></i>
    </div>
    <div class="stat-content">
      <p class="stat-label">Bounced</p>
      <p class="stat-value text-rose-600 dark:text-rose-400"><%= stats.totalBounced %></p>
    </div>
  </div>
</div>

<!-- Filters -->
<form method="get" class="mb-6">
  <div class="flex flex-col sm:flex-row gap-3">
    <div class="flex-1 input-icon-wrapper">
      <i data-lucide="search" class="input-icon w-4 h-4"></i>
      <input type="text" name="search" value="<%= search %>" placeholder="Search by email or subject..." class="input">
    </div>
    <label for="emailTypeFilter" class="sr-only">Email Type</label>
    <select name="type" id="emailTypeFilter" class="input !w-auto">
      <option value="">All Types</option>
      <option value="inbound" <%= typeFilter === 'inbound' ? 'selected' : '' %>>Inbound</option>
      <option value="verification" <%= typeFilter === 'verification' ? 'selected' : '' %>>Verification</option>
      <option value="welcome" <%= typeFilter === 'welcome' ? 'selected' : '' %>>Welcome</option>
      <option value="password_reset" <%= typeFilter === 'password_reset' ? 'selected' : '' %>>Password Reset</option>
      <option value="payment_success" <%= typeFilter === 'payment_success' ? 'selected' : '' %>>Payment Success</option>
      <option value="payment_failed" <%= typeFilter === 'payment_failed' ? 'selected' : '' %>>Payment Failed</option>
      <option value="esim_assigned" <%= typeFilter === 'esim_assigned' ? 'selected' : '' %>>eSIM Assigned</option>
      <option value="esim_activation_failed" <%= typeFilter === 'esim_activation_failed' ? 'selected' : '' %>>Activation Failed</option>
      <option value="custom" <%= typeFilter === 'custom' ? 'selected' : '' %>>Custom</option>
    </select>
    <label for="emailStatusFilter" class="sr-only">Email Status</label>
    <select name="status" id="emailStatusFilter" class="input !w-auto">
      <option value="">All Status</option>
      <option value="received" <%= statusFilter === 'received' ? 'selected' : '' %>>Received</option>
      <option value="sent" <%= statusFilter === 'sent' ? 'selected' : '' %>>Sent</option>
      <option value="delivered" <%= statusFilter === 'delivered' ? 'selected' : '' %>>Delivered</option>
      <option value="opened" <%= statusFilter === 'opened' ? 'selected' : '' %>>Opened</option>
      <option value="clicked" <%= statusFilter === 'clicked' ? 'selected' : '' %>>Clicked</option>
      <option value="bounced" <%= statusFilter === 'bounced' ? 'selected' : '' %>>Bounced</option>
      <option value="failed" <%= statusFilter === 'failed' ? 'selected' : '' %>>Failed</option>
    </select>
    <button type="submit" class="btn btn-secondary">Filter</button>
    <% if (search || typeFilter || statusFilter) { %>
    <a href="/admin/emails" class="btn btn-secondary">Clear</a>
    <% } %>
  </div>
</form>

<!-- Emails Table -->
<div class="table-container">
  <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
          <th>Direction</th>
          <th>From / To</th>
          <th>Subject</th>
          <th>Type</th>
          <th>Status</th>
          <th>Date</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (emails.length > 0) { %>
        <% emails.forEach(function(e) { %>
        <tr>
          <td>
            <% if (e.type === 'inbound') { %>
            <span class="badge badge-info inline-flex items-center gap-1"><i data-lucide="inbox" class="w-3 h-3"></i>In</span>
            <% } else { %>
            <span class="badge badge-neutral inline-flex items-center gap-1"><i data-lucide="send" class="w-3 h-3"></i>Out</span>
            <% } %>
          </td>
          <td>
            <% if (e.type === 'inbound') { %>
            <p class="font-medium text-[var(--text-primary)] text-sm"><%= e.metadata && e.metadata.from ? e.metadata.from : '-' %></p>
            <p class="text-xs text-[var(--text-tertiary)]">to: <%= e.to %></p>
            <% } else { %>
            <p class="font-medium text-[var(--text-primary)] text-sm"><%= e.to %></p>
            <% if (e.user) { %>
            <p class="text-xs text-[var(--text-tertiary)]"><%= e.user.displayName || e.user.username %></p>
            <% } %>
            <% } %>
          </td>
          <td class="max-w-[200px]">
            <p class="text-sm text-[var(--text-primary)] truncate"><%= e.subject %></p>
          </td>
          <td>
            <span class="text-xs text-[var(--text-secondary)]"><%= e.type %></span>
          </td>
          <td>
            <% if (e.status === 'received') { %>
            <span class="badge badge-info"><span class="badge-dot bg-sky-500"></span>Received</span>
            <% } else if (e.status === 'delivered') { %>
            <span class="badge badge-success"><span class="badge-dot bg-emerald-500"></span>Delivered</span>
            <% } else if (e.status === 'opened') { %>
            <span class="badge badge-success">Opened</span>
            <% } else if (e.status === 'clicked') { %>
            <span class="badge badge-success">Clicked</span>
            <% } else if (e.status === 'sent') { %>
            <span class="badge badge-warning"><span class="badge-dot bg-amber-500"></span>Sent</span>
            <% } else if (e.status === 'bounced') { %>
            <span class="badge badge-danger"><span class="badge-dot bg-rose-500"></span>Bounced</span>
            <% } else if (e.status === 'failed') { %>
            <span class="badge badge-danger">Failed</span>
            <% } else { %>
            <span class="badge badge-neutral"><%= e.status %></span>
            <% } %>
          </td>
          <td class="text-xs text-[var(--text-tertiary)]"><%= new Date(e.createdAt).toLocaleString('en-GB') %></td>
          <td>
            <a href="/admin/emails/<%= e.id %>" class="btn btn-secondary btn-sm">
              <i data-lucide="eye" class="w-3.5 h-3.5"></i>
            </a>
          </td>
        </tr>
        <% }) %>
        <% } else { %>
        <tr>
          <td colspan="7" class="text-center py-12 text-sm text-[var(--text-tertiary)]">
            <i data-lucide="mail" class="w-8 h-8 mx-auto mb-2 opacity-40"></i>
            <p>No emails found</p>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if (pagination.totalPages > 1) { %>
<%- include('../partials/pagination', { pagination }) %>
<% } %>

<!-- Compose Email Modal -->
<div id="composeModal" class="fixed inset-0 z-50 hidden bg-black/50 flex items-center justify-center p-4" onclick="closeComposeModal()">
  <div class="card w-full max-w-2xl max-h-[90vh] flex flex-col" role="dialog" aria-modal="true" aria-labelledby="composeModalTitle" onclick="event.stopPropagation()">
    <div class="card-header flex-shrink-0">
      <h2 id="composeModalTitle" class="card-title flex items-center gap-2">
        <i data-lucide="pencil" class="w-4 h-4"></i> Compose Email
      </h2>
      <button onclick="closeComposeModal()" aria-label="Close compose dialog" class="text-[var(--text-tertiary)] hover:text-[var(--text-primary)]">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>
    </div>
    <div class="p-5 space-y-4 overflow-y-auto flex-1">
      <div id="composeError" class="hidden alert alert-error text-sm"></div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label for="composeTo" class="block text-sm font-medium mb-1">To</label>
          <input id="composeTo" type="email" placeholder="recipient@example.com" class="input w-full">
        </div>
        <div>
          <label for="composeSubject" class="block text-sm font-medium mb-1">Subject</label>
          <input id="composeSubject" type="text" placeholder="Subject" maxlength="200" class="input w-full">
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div class="space-y-2">
          <div>
            <label for="composeFromName" class="block text-sm font-medium mb-1">From Name <span class="text-[var(--text-tertiary)] font-normal">(optional)</span></label>
            <input id="composeFromName" type="text" placeholder="DataPatch" maxlength="100" class="input w-full">
          </div>
          <div>
            <label for="composeFrom" class="block text-sm font-medium mb-1">From Email <span class="text-[var(--text-tertiary)] font-normal">(optional)</span></label>
            <input id="composeFrom" type="email" placeholder="<%= smtpFrom %>" class="input w-full">
          </div>
        </div>
        <div>
          <label for="composeTemplate" class="block text-sm font-medium mb-1">Template <span class="text-[var(--text-tertiary)] font-normal">(optional)</span></label>
          <select id="composeTemplate" class="input w-full" onchange="applyComposeTemplate(this.value)">
            <option value="">— No template —</option>
            <option value="esim_assigned">eSIM Assigned</option>
            <option value="welcome">Welcome</option>
            <option value="payment_success">Payment Successful</option>
            <option value="action_required">Action Required</option>
          </select>
        </div>
      </div>
      <div>
        <div class="flex items-center justify-between mb-1">
          <label class="block text-sm font-medium">Message</label>
          <div class="flex rounded-md border border-[var(--border)] overflow-hidden text-xs">
            <button type="button" id="tabWrite" onclick="switchTab('write')" class="px-3 py-1 bg-[var(--brand-primary)] text-white font-medium">Write</button>
            <button type="button" id="tabPreview" onclick="switchTab('preview')" class="px-3 py-1 text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)]">Preview</button>
          </div>
        </div>
        <div id="quillEditorWrap">
          <div id="quillEditor" style="min-height:200px;background:#fff;border-radius:0 0 4px 4px;"></div>
        </div>
        <div id="previewWrap" class="hidden border border-[var(--border)] rounded-md overflow-hidden" style="height:320px;">
          <iframe id="previewFrame" class="w-full h-full border-0" title="Email preview"></iframe>
        </div>
      </div>
    </div>
    <div class="flex justify-end gap-2 p-4 border-t border-[var(--border)] flex-shrink-0">
      <button onclick="closeComposeModal()" class="btn btn-secondary">Cancel</button>
      <button onclick="submitCompose()" id="composeSendBtn" class="btn btn-primary inline-flex items-center gap-2">
        <i data-lucide="send" class="w-4 h-4" id="composeSendIcon"></i>
        <span id="composeSendLabel">Send Email</span>
      </button>
    </div>
  </div>
</div>

<!-- Toast notification -->
<div id="composeToast" class="fixed top-4 right-4 z-[60] hidden max-w-sm"></div>

<!-- Quill CDN (loaded only on this page) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css">
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>

<script>
(function () {
  var quill;

  window.openComposeModal = function () {
    document.getElementById('composeModal').classList.remove('hidden');
    if (!quill) {
      quill = new Quill('#quillEditor', {
        theme: 'snow',
        modules: {
          toolbar: [
            ['bold', 'italic', 'underline'],
            ['link'],
            [{ list: 'ordered' }, { list: 'bullet' }],
            ['clean']
          ]
        }
      });
    }
    lucide.createIcons();
    document.getElementById('composeTo').focus();
  };

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !document.getElementById('composeModal').classList.contains('hidden')) {
      closeComposeModal();
    }
  });

  window.closeComposeModal = function () {
    document.getElementById('composeModal').classList.add('hidden');
    var errorEl = document.getElementById('composeError');
    errorEl.textContent = '';
    errorEl.classList.add('hidden');
    document.getElementById('composeTo').value = '';
    document.getElementById('composeFromName').value = '';
    document.getElementById('composeFrom').value = '';
    document.getElementById('composeSubject').value = '';
    document.getElementById('composeTemplate').value = '';
    lastAppliedTemplate = null;
    if (quill) { quill.setText(''); }
    switchTab('write');
  };

  var lastAppliedTemplate = null;

  var COMPOSE_TEMPLATES = {
    esim_assigned: {
      subject: 'Your eSIM is Ready',
      body: 'Hello,\n\nYour eSIM has been assigned and is ready to use. Please check your account for the QR code and activation instructions.\n\nIf you have any questions, feel free to reply to this email.\n\nBest regards,\nDataPatch Team'
    },
    welcome: {
      subject: 'Welcome to DataPatch',
      body: 'Hello,\n\nWelcome to DataPatch! Your account has been created successfully.\n\nYou can now browse available eSIM plans and make purchases from your dashboard.\n\nBest regards,\nDataPatch Team'
    },
    payment_success: {
      subject: 'Payment Confirmed',
      body: 'Hello,\n\nYour payment has been successfully processed. Your order is now being prepared.\n\nYou will receive another email once your eSIM is ready.\n\nBest regards,\nDataPatch Team'
    },
    action_required: {
      subject: 'Action Required',
      body: 'Hello,\n\nYour attention is required regarding your DataPatch account. Please log in to your account and review the pending action.\n\nIf you have any questions, feel free to reply to this email.\n\nBest regards,\nDataPatch Team'
    }
  };

  window.applyComposeTemplate = function (key) {
    var subjectEl = document.getElementById('composeSubject');
    if (!key) {
      if (lastAppliedTemplate) {
        if (subjectEl.value === lastAppliedTemplate.subject) { subjectEl.value = ''; }
        if (quill) { quill.setText(''); }
        lastAppliedTemplate = null;
      }
      return;
    }
    if (!COMPOSE_TEMPLATES[key]) return;
    var tpl = COMPOSE_TEMPLATES[key];
    subjectEl.value = tpl.subject;
    if (quill) { quill.setText(tpl.body); }
    lastAppliedTemplate = tpl;
    switchTab('write');
  };

  window.switchTab = function (tab) {
    var writeWrap = document.getElementById('quillEditorWrap');
    var previewWrap = document.getElementById('previewWrap');
    var tabWrite = document.getElementById('tabWrite');
    var tabPreview = document.getElementById('tabPreview');
    var activeClass = ['bg-[var(--brand-primary)]', 'text-white', 'font-medium'];
    var inactiveClass = ['text-[var(--text-secondary)]', 'hover:bg-[var(--bg-secondary)]'];

    if (tab === 'write') {
      writeWrap.classList.remove('hidden');
      previewWrap.classList.add('hidden');
      tabWrite.className = 'px-3 py-1 bg-[var(--brand-primary)] text-white font-medium';
      tabPreview.className = 'px-3 py-1 text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)]';
    } else {
      writeWrap.classList.add('hidden');
      previewWrap.classList.remove('hidden');
      tabWrite.className = 'px-3 py-1 text-[var(--text-secondary)] hover:bg-[var(--bg-secondary)]';
      tabPreview.className = 'px-3 py-1 bg-[var(--brand-primary)] text-white font-medium';
      var body = quill ? quill.root.innerHTML : '';
      fetch('/admin/emails/preview', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>'
        },
        body: JSON.stringify({ body: body })
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.html) {
            document.getElementById('previewFrame').srcdoc = data.html;
          }
        })
        .catch(function () {});
    }
  };

  window.submitCompose = async function () {
    var to = document.getElementById('composeTo').value.trim();
    var fromName = document.getElementById('composeFromName').value.trim();
    var from = document.getElementById('composeFrom').value.trim();
    var subject = document.getElementById('composeSubject').value.trim();
    var body = quill ? quill.root.innerHTML : '';
    var bodyText = quill ? quill.getText().trim() : '';
    var errorEl = document.getElementById('composeError');
    var sendBtn = document.getElementById('composeSendBtn');
    var sendIcon = document.getElementById('composeSendIcon');
    var sendLabel = document.getElementById('composeSendLabel');

    errorEl.textContent = '';
    errorEl.classList.add('hidden');

    if (!to || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(to)) {
      errorEl.textContent = 'Enter a valid email address.';
      errorEl.classList.remove('hidden');
      return;
    }
    if (!subject) {
      errorEl.textContent = 'Subject is required.';
      errorEl.classList.remove('hidden');
      return;
    }
    if (!bodyText) {
      errorEl.textContent = 'Message body cannot be empty.';
      errorEl.classList.remove('hidden');
      return;
    }

    sendBtn.disabled = true;
    sendIcon.style.display = 'none';
    sendLabel.textContent = 'Sending…';

    try {
      var res = await fetch('/admin/emails/compose', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>'
        },
        body: JSON.stringify({ to, from: from || undefined, fromName: fromName || undefined, subject, body })
      });
      var data = await res.json();

      if (data.success) {
        closeComposeModal();
        showComposeToast('Email sent successfully.', 'success');
      } else {
        errorEl.textContent = data.error || 'Failed to send email.';
        errorEl.classList.remove('hidden');
      }
    } catch (e) {
      errorEl.textContent = 'Network error. Please try again.';
      errorEl.classList.remove('hidden');
    } finally {
      sendBtn.disabled = false;
      sendIcon.style.display = '';
      sendLabel.textContent = 'Send Email';
      lucide.createIcons();
    }
  };

  function showComposeToast(message, type) {
    var toast = document.getElementById('composeToast');
    toast.className = 'fixed top-4 right-4 z-[60] max-w-sm alert ' +
      (type === 'success' ? 'alert-success' : 'alert-error');
    toast.textContent = message;
    toast.classList.remove('hidden');
    setTimeout(function () { toast.classList.add('hidden'); }, 3000);
  }
}());
</script>

<%- include('../partials/footer') %>
