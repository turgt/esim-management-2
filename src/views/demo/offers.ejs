<div class="v2-content">
  <h1 class="v2-page-title v2-anim">Planlar</h1>

  <!-- Filters -->
  <div class="v2-filters v2-anim">
    <% filters.forEach((f, i) => { %>
    <button class="v2-chip <%= i === 0 ? 'active' : '' %>" onclick="setFilter(this)"><%= f %></button>
    <% }) %>
  </div>

  <!-- Sort -->
  <div class="v2-sort v2-anim">
    <span class="v2-sort-label"><%= plans.length %> plan bulundu</span>
    <select>
      <option>Fiyat (artan)</option>
      <option>Fiyat (azalan)</option>
      <option>Data (cok → az)</option>
      <option>Sure (uzun → kisa)</option>
    </select>
  </div>

  <!-- Offers -->
  <div class="v2-offers">
    <% plans.forEach((plan, i) => { %>
    <a href="/demo/status" class="v2-offer v2-anim<%= i === 0 ? ' featured' : '' %>">
      <div class="v2-offer-top">
        <div class="v2-offer-flag"><%= plan.flag %></div>
        <div>
          <div class="v2-offer-name"><%= plan.country %> <span class="v2-badge v2-badge-<%= plan.network.toLowerCase() %>"><%= plan.network %></span></div>
          <div class="v2-offer-meta"><%= plan.data %> · <%= plan.duration %></div>
        </div>
      </div>
      <div class="v2-offer-foot">
        <div class="v2-offer-price"><%= plan.price %></div>
        <span class="v2-offer-cta">Satin Al →</span>
      </div>
    </a>
    <% }) %>
  </div>
</div>

<script>
function setFilter(el) {
  document.querySelectorAll('.v2-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
}
</script>
