<div class="demo-login-wrapper">
  <div class="demo-login-card demo-animate-in">
    <div class="demo-login-logo demo-gradient-text">DataPatch</div>
    <p class="demo-login-subtitle">Hesabına giriş yap</p>

    <form action="/demo/offers" method="get">
      <div class="demo-input-group">
        <label class="demo-input-label">E-posta veya Kullanıcı Adı</label>
        <input type="text" class="demo-input" placeholder="ornek@email.com" value="demo@datapatch.co">
      </div>

      <div class="demo-input-group">
        <label class="demo-input-label">Şifre</label>
        <input type="password" class="demo-input" placeholder="••••••••" value="demo1234">
      </div>

      <a href="#" class="demo-forgot-link">Şifremi unuttum</a>

      <button type="submit" class="demo-btn demo-btn-primary demo-btn-block">Giriş Yap</button>
    </form>

    <div class="demo-login-footer">
      Hesabın yok mu? <a href="#">Kayıt Ol</a>
    </div>
  </div>
</div>
